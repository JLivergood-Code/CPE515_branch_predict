    // C4.1.5.5 SME2 multi-vec contiguous load (scalar plus immediate,
    // two registers)
    StaticInstPtr
    decodeSmeMVContigLoadSI2Regs(ExtMachInst machInst)
    {
        RegIndex zt = (RegIndex)((uint8_t) bits(machInst, 4, 1) << 1);
        RegIndex rn = makeSP((RegIndex) (uint8_t) bits(machInst, 9, 5));
        uint64_t imm = sext<4>(bits(machInst, 19, 16)) << 1;
        RegIndex png = (RegIndex)(0b1000 + (uint8_t) bits(machInst, 12, 10));
        uint8_t msz = bits(machInst, 14, 13);
        uint8_t nt = bits(machInst, 0);

        return decodeSveContigConseLoadSIInsts(
            msz, machInst, zt, png, rn, imm, 2, nt);
