                machInst, Rv, off3, Zn, Zn+1, Zn+2, Zn+3, Zm, i1);
          case 0x5: // op=1 opc=01
            return new SmeSvdotI16I64MIdx4Reg<int16_t, int16_t, int64_t>(
                machInst, Rv, off3, Zn, Zn+1, Zn+2, Zn+3, Zm, i1);
          case 0x7: // op=1 opc=11
