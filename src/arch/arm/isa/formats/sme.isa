    // C4.1.32.7 SME2 multi-vec ZIP two registers
    StaticInstPtr
    decodeSme2MultiVecZip2Regs(ExtMachInst machInst)
    {
        uint8_t op = (uint8_t)bits(machInst, 0);
        RegIndex Zd = (RegIndex)(bits(machInst, 4, 1) << 1);
        RegIndex Zn = (RegIndex)bits(machInst, 9, 5);
        RegIndex Zm = (RegIndex)bits(machInst, 20, 16);
        uint8_t size = (uint8_t)bits(machInst, 23, 22);

        switch (op) {
          case 0x0: // op=0
            return decodeSme2MVDestrBinOp2Regs<SmeZip2Reg>(
                    size, machInst, Zd, Zd+1, Zn, Zm);
          case 0x1: // op=1
            return decodeSme2MVDestrBinOp2Regs<SmeUzp2Reg>(
                    size, machInst, Zd, Zd+1, Zn, Zm);
        }
        return new Unknown64(machInst);
    }

    // C4.1.32.8 SME2 multi-vec saturating shift right narrow four registers
    StaticInstPtr
    decodeSme2MultiVecSatShiftRightNarrow4Regs(ExtMachInst machInst)
    {
        uint8_t n_op_u = ((uint8_t)bits(machInst, 10) << 2) |
                        (uint8_t)bits(machInst, 6, 5);
        RegIndex Zd = (RegIndex)(bits(machInst, 4, 0));
        RegIndex Zn = (RegIndex)(bits(machInst, 9, 7) << 2);
        uint8_t imm5 = (uint8_t)(bits(machInst, 20, 16));
        uint8_t tsize = (uint8_t)(bits(machInst, 23, 22));
        uint8_t shift = 0;
        if (bits(tsize, 1) == 1) {
            shift = 8 * 16 - (tsize << 5 | imm5);
        } else if (bits(tsize, 0) == 1) {
            shift = 8 * 8 - (tsize << 5 | imm5);
        }

        switch (n_op_u) {
          case 0x0: // N=0 op=0 U=0
            if (bits(tsize, 1) == 1) {
                return new SmeSqrshr4Reg<int64_t, int16_t>(
                    machInst, Zd, Zn, Zn+1, Zn+2, Zn+3, shift);
            } else if (bits(tsize, 0) == 1) {
                return new SmeSqrshr4Reg<int32_t, int8_t>(
                    machInst, Zd, Zn, Zn+1, Zn+2, Zn+3, shift);
            }
            break;
          case 0x1: // N=0 op=0 U=1
            if (bits(tsize, 1) == 1) {
                return new SmeUqrshr4Reg<uint64_t, uint16_t>(
                    machInst, Zd, Zn, Zn+1, Zn+2, Zn+3, shift);
            } else if (bits(tsize, 0) == 1) {
                return new SmeUqrshr4Reg<uint32_t, uint8_t>(
                    machInst, Zd, Zn, Zn+1, Zn+2, Zn+3, shift);
            }
            break;
          case 0x2: // N=0 op=1 U=0
            if (bits(tsize, 1) == 1) {
                return new SmeSqrshru4Reg<int64_t, int16_t>(
                    machInst, Zd, Zn, Zn+1, Zn+2, Zn+3, shift);
            } else if (bits(tsize, 0) == 1) {
                return new SmeSqrshru4Reg<int32_t, int8_t>(
                    machInst, Zd, Zn, Zn+1, Zn+2, Zn+3, shift);
            }
            break;
          case 0x4: // N=1 op=0 U=0
            if (bits(tsize, 1) == 1) {
                return new SmeSqrshrn4Reg<int64_t, int16_t>(
                    machInst, Zd, Zn, Zn+1, Zn+2, Zn+3, shift);
            } else if (bits(tsize, 0) == 1) {
                return new SmeSqrshrn4Reg<int32_t, int8_t>(
                    machInst, Zd, Zn, Zn+1, Zn+2, Zn+3, shift);
            }
            break;
          case 0x5: // N=1 op=0 U=1
            if (bits(tsize, 1) == 1) {
                return new SmeUqrshrn4Reg<uint64_t, uint16_t>(
                    machInst, Zd, Zn, Zn+1, Zn+2, Zn+3, shift);
            } else if (bits(tsize, 0) == 1) {
                return new SmeUqrshrn4Reg<uint32_t, uint8_t>(
                    machInst, Zd, Zn, Zn+1, Zn+2, Zn+3, shift);
            }
            break;
          case 0x6: // N=1 op=1 U=0
            if (bits(tsize, 1) == 1) {
                return new SmeSqrshrun4Reg<int64_t, int16_t>(
                    machInst, Zd, Zn, Zn+1, Zn+2, Zn+3, shift);
            } else if (bits(tsize, 0) == 1) {
                return new SmeSqrshrun4Reg<int32_t, int8_t>(
                    machInst, Zd, Zn, Zn+1, Zn+2, Zn+3, shift);
            }
            break;
        }
        return new Unknown64(machInst);
    }

    // C4.1.32 SME2 Multi-vector - SVE Constructive Binary
    StaticInstPtr
    decodeSme2MVSveConstrBin(ExtMachInst machInst)
    {
        uint8_t op0 = (uint8_t)bits(machInst, 23, 22);
        uint8_t op1 = (uint8_t)bits(machInst, 12, 10);
        uint8_t op2 = (uint8_t)bits(machInst, 1);

        switch (op1) {
          case 0x0:    // op1=000
            return decodeSme2MultiVecFclamp2Regs(machInst);
          case 0x1:    // op1=001
            return decodeSme2MultiVecClamp2Regs(machInst);
          case 0x2:    // op1=010
            if (op2 == 0) {     // op1=010 op2=0
                return decodeSme2MultiVecFclamp4Regs(machInst);
            }
            break;
          case 0x3:    // op1=011
            if (op2 == 0) {     // op1=011 op2=0
                return decodeSme2MultiVecClamp4Regs(machInst);
            }
            break;
          case 0x4:    // op1=100
            return decodeSme2MultiVecZip2Regs(machInst);
          case 0x5:    // op1=101
            if (op0 == 0x0) {   // op0=00 op1=101
                return decodeSme2MultiVecQuadZip2Regs(machInst);
            } else if (op0 == 0x3) {    // op0=11 op1=101
                return decodeSme2MultiVecSatShiftRightNarrow2Regs(machInst);
            }
            break;
          case 0x6: case 0x7:   // op1=11x
            return decodeSme2MultiVecSatShiftRightNarrow4Regs(machInst);
        }
        return new Unknown64(machInst);
    }

    // C4.1.33.1 SME2 multi-vec FP to int convert two registers
    StaticInstPtr
    decodeSme2MultiVecFp2IntCvt2Regs(ExtMachInst machInst)
    {
        uint8_t u = (uint8_t)bits(machInst, 5);
        RegIndex Zd = (RegIndex)(bits(machInst, 4, 1) << 1);
        RegIndex Zn = (RegIndex)(bits(machInst, 9, 6) << 1);

        switch (u) {
          case 0x0: // U=0
            return new SmeFcvtzs2Reg<uint32_t>(machInst, Zd, Zd+1, Zn, Zn+1);
          case 0x1: // U=1
            return new SmeFcvtzu2Reg<uint32_t>(machInst, Zd, Zd+1, Zn, Zn+1);
        }
        return new Unknown64(machInst);
    }

    // C4.1.33.2 SME2 multi-vec int to FP two registers
    StaticInstPtr
    decodeSme2MultiVecInt2FpCvt2Regs(ExtMachInst machInst)
    {
        uint8_t u = (uint8_t)bits(machInst, 5);
        RegIndex Zd = (RegIndex)(bits(machInst, 4, 1) << 1);
