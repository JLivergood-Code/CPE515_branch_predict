            RegIndex Zd = (RegIndex)(uint32_t)(bits(machInst, 4, 2) << 2);
            return decodeSme2MVPredBinOp4Regs<SmeSel4Reg>(
                    esize, machInst, Zd, Zd+1, Zd+2, Zd+3, Png,
                    Zn, Zn+1, Zn+2, Zn+3, Zm, Zm+1, Zm+2, Zm+3);
        } else if ((bits(op0, 0) == 0) && (bits(op1, 0) == 0) &&
                    (bits(op2, 0) == 0)) {
            // op0=x0 op1=x0 op2=x0
            RegIndex Zn = (RegIndex)(uint32_t)(bits(machInst, 9, 6) << 1);
            RegIndex Zm = (RegIndex)(uint32_t)(bits(machInst, 20, 17) << 1);
            RegIndex Zd = (RegIndex)(uint32_t)(bits(machInst, 4, 1) << 1);
            return decodeSme2MVPredBinOp2Regs<SmeSel2Reg>(
                    esize, machInst, Zd, Zd+1, Png, Zn, Zn+1, Zm, Zm+1);
        }
        return new Unknown64(machInst);
    }

    // C4.1.32.1 SME2 multi-vec quadwords ZIP two registers
    StaticInstPtr
    decodeSme2MultiVecQuadZip2Regs(ExtMachInst machInst)
    {
        uint8_t op = (uint8_t)bits(machInst, 0);
        RegIndex Zd = (RegIndex)(bits(machInst, 4, 1) << 1);
        RegIndex Zn = (RegIndex)bits(machInst, 9, 5);
        RegIndex Zm = (RegIndex)bits(machInst, 20, 16);

        switch (op) {
          case 0x0: // op=0
            return new SmeZip2Reg<__uint128_t>(machInst, Zd, Zd+1, Zn, Zm);
          case 0x1: // op=1
            return new SmeUzp2Reg<__uint128_t>(machInst, Zd, Zd+1, Zn, Zm);
        }
        return new Unknown64(machInst);
    }

    // C4.1.32.2 SME2 multi-vec saturating shift right narrow two registers
    StaticInstPtr
    decodeSme2MultiVecSatShiftRightNarrow2Regs(ExtMachInst machInst)
    {
        uint8_t op_u = ((uint8_t)bits(machInst, 20) << 1) |
                        (uint8_t)bits(machInst, 5);
        RegIndex Zd = (RegIndex)(bits(machInst, 4, 0));
        RegIndex Zn = (RegIndex)(bits(machInst, 9, 6) << 1);
        uint8_t imm4 = (uint8_t)(bits(machInst, 19, 16));
        uint8_t shift = 16 - imm4;

        switch (op_u) {
          case 0x0: // op=0 U=0
            return new SmeSqrshr2Reg<int32_t, int16_t>(
                machInst, Zd, Zn, Zn+1, shift);
          case 0x1: // op=0 U=1
            return new SmeUqrshr2Reg<uint32_t, uint16_t>(
                machInst, Zd, Zn, Zn+1, shift);
          case 0x2: // op=1 U=0
            return new SmeSqrshru2Reg<int32_t, int16_t>(
                machInst, Zd, Zn, Zn+1, shift);
        }
        return new Unknown64(machInst);
    }

    // C4.1.32.3 SME2 multi-vec FCLAMP two registers
    StaticInstPtr
    decodeSme2MultiVecFclamp2Regs(ExtMachInst machInst)
    {
        uint8_t op = (uint8_t)bits(machInst, 0);
        RegIndex Zd = (RegIndex)(bits(machInst, 4, 1) << 1);
        RegIndex Zn = (RegIndex)(bits(machInst, 9, 5));
        RegIndex Zm = (RegIndex)(bits(machInst, 20, 16));
        uint8_t esize = (uint8_t)(bits(machInst, 23, 22));

        switch (op) {
          case 0x0: // U=0
            if (esize == 0) {
                return new SmeBfclamp2Reg<uint16_t>(
                    machInst, Zd, Zd+1, Zn, Zm);
            } else {
                return decodeSme2Fclamp2Regs<SmeFclamp2Reg>(
                    esize, machInst, Zd, Zd+1, Zn, Zm);
            }
        }
        return new Unknown64(machInst);
    }

    // C4.1.32.4 SME2 multi-vec CLAMP two registers
    StaticInstPtr
    decodeSme2MultiVecClamp2Regs(ExtMachInst machInst)
    {
        uint8_t U = (uint8_t)bits(machInst, 0);
        RegIndex Zd = (RegIndex)(bits(machInst, 4, 1) << 1);
        RegIndex Zn = (RegIndex)(bits(machInst, 9, 5));
        RegIndex Zm = (RegIndex)(bits(machInst, 20, 16));
        uint8_t esize = (uint8_t)(bits(machInst, 23, 22));

        switch (U) {
          case 0x0: // U=0
            return decodeSme2Clamp2RegsSign<SmeSclamp2Reg>(
                esize, machInst, Zd, Zd+1, Zn, Zm);
          case 0x1: // U=1
            return decodeSme2Clamp2Regs<SmeUclamp2Reg>(
                esize, machInst, Zd, Zd+1, Zn, Zm);
        }
        return new Unknown64(machInst);
    }

    // C4.1.32.5 SME2 multi-vec FCLAMP four registers
    StaticInstPtr
    decodeSme2MultiVecFclamp4Regs(ExtMachInst machInst)
    {
        uint8_t op = (uint8_t)bits(machInst, 0);
        RegIndex Zd = (RegIndex)(bits(machInst, 4, 2) << 2);
        RegIndex Zn = (RegIndex)(bits(machInst, 9, 5));
        RegIndex Zm = (RegIndex)(bits(machInst, 20, 16));
        uint8_t esize = (uint8_t)(bits(machInst, 23, 22));

        switch (op) {
          case 0x0: // U=0
            if (esize == 0) {
                return new SmeBfclamp4Reg<uint16_t>(
                    machInst, Zd, Zd+1, Zd+2, Zd+3, Zn, Zm);
            } else {
                return decodeSme2Fclamp4Regs<SmeFclamp4Reg>(
                    esize, machInst, Zd, Zd+1, Zd+2, Zd+3, Zn, Zm);
            }
        }
        return new Unknown64(machInst);
    }

    // C4.1.32.6 SME2 multi-vec CLAMP four registers
    StaticInstPtr
    decodeSme2MultiVecClamp4Regs(ExtMachInst machInst)
    {
        uint8_t U = (uint8_t)bits(machInst, 0);
        RegIndex Zd = (RegIndex)(bits(machInst, 4, 2) << 2);
        RegIndex Zn = (RegIndex)(bits(machInst, 9, 5));
        RegIndex Zm = (RegIndex)(bits(machInst, 20, 16));
        uint8_t esize = (uint8_t)(bits(machInst, 23, 22));

        switch (U) {
          case 0x0: // U=0
            return decodeSme2Clamp4RegsSign<SmeSclamp4Reg>(
                esize, machInst, Zd, Zd+1, Zd+2, Zd+3, Zn, Zm);
          case 0x1: // U=1
            return decodeSme2Clamp4Regs<SmeUclamp4Reg>(
                esize, machInst, Zd, Zd+1, Zd+2, Zd+3, Zn, Zm);
