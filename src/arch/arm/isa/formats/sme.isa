        StaticInstPtr decodeSme2ZeroLookupTable(ExtMachInst);
        StaticInstPtr decodeSme2MoveLookupTable(ExtMachInst);
        StaticInstPtr decodeSme2ExpandLookupTableNonContig(ExtMachInst);
        StaticInstPtr decodeSme2ExpandLookupTableContig(ExtMachInst);
        StaticInstPtr decodeSmeMoveIntoArray(ExtMachInst);
        StaticInstPtr decodeSmeMoveFromArray(ExtMachInst);
        StaticInstPtr decodeSmeAddVecToArray(ExtMachInst);
        StaticInstPtr decodeSme2MVMultiAndSingleArrayVecTwoRegs(ExtMachInst);
        StaticInstPtr decodeSme2MVMultiAndSingleArrayVecFourRegs(ExtMachInst);
        StaticInstPtr decodeSme2MVMultiArrayTwoRegs(ExtMachInst);
        StaticInstPtr decodeSme2MVMultiArrayFourRegs(ExtMachInst);
        StaticInstPtr decodeSme2MVMultiVecIndexedOneReg(ExtMachInst);
        StaticInstPtr decodeSme2MVMultiVecIndexedTwoRegs(ExtMachInst);
