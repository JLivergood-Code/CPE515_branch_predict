          case 0x0: // U=0
            return new SmeScvtf2Reg<uint32_t>(machInst, Zd, Zd+1, Zn, Zn+1);
          case 0x1: // U=1
            return new SmeUcvtf2Reg<uint32_t>(machInst, Zd, Zd+1, Zn, Zn+1);
        }
        return new Unknown64(machInst);
    }

    // C4.1.33.3 SME2 multi-vec FP to int convert four registers
    StaticInstPtr
    decodeSme2MultiVecFp2IntCvt4Regs(ExtMachInst machInst)
    {
        uint8_t u = (uint8_t)bits(machInst, 5);
        RegIndex Zd = (RegIndex)(bits(machInst, 4, 2) << 2);
