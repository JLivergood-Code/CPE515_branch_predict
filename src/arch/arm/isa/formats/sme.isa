    // C4.1.5 SME2 Multi-vector - Memory (Contiguous)
    StaticInstPtr
    decodeSme2MVMemContig(ExtMachInst machInst)
    {
        uint8_t op0_op1 = (bits(machInst, 22, 20) << 1) | bits(machInst, 15);

        switch (op0_op1) {
          case 0x0: case 0x2:   // op0=00x op1=0
            return decodeSmeMVContigLoadSS2Regs(machInst);
          case 0x1: case 0x3:   // op0=00x op1=1
            return decodeSmeMVContigLoadSS4Regs(machInst);
          case 0x4: case 0x6:   // op0=01x op1=0
            return decodeSmeMVContigStoreSS2Regs(machInst);
          case 0x5: case 0x7:   // op0=01x op1=1
            return decodeSmeMVContigStoreSS4Regs(machInst);
          case 0x8:             // op0=100 op1=0
            return decodeSmeMVContigLoadSI2Regs(machInst);
          case 0x9:             // op0=100 op1=1
            return decodeSmeMVContigLoadSI4Regs(machInst);
          case 0xc:             // op0=110 op1=0
            return decodeSmeMVContigStoreSI2Regs(machInst);
          case 0xd:             // op0=110 op1=1
            return decodeSmeMVContigStoreSI4Regs(machInst);
        }
        return new Unknown64(machInst);
    }

    // C4.1.6.1 SME2 multi-vec non-contiguous load (scalar plus scalar,
    // two registers)
    StaticInstPtr
    decodeSmeMVNonContigLoadSS2Regs(ExtMachInst machInst)
    {
        RegIndex zt = (RegIndex)((uint32_t)(bits(machInst, 4) << 4) |
                                (uint32_t)(bits(machInst, 2, 0)));
        RegIndex rn = makeSP((RegIndex) (uint8_t) bits(machInst, 9, 5));
        RegIndex rm = (RegIndex) (uint8_t) bits(machInst, 20, 16);
        RegIndex png = (RegIndex)(0b1000 + (uint8_t) bits(machInst, 12, 10));
        uint8_t msz = bits(machInst, 14, 13);
        uint8_t nt = bits(machInst, 3);

        return decodeSmeNonContigLoadSSInsts(
            msz, machInst, zt, png, rn, rm, 2, nt);
    }

