    // C4.1.23.9 SME2 multi-vec indexed FP8 two-way dot product to FP16 two
    // registers
    // C4.1.23 SME2 Multi-vector - Indexed (Two registers)
    StaticInstPtr
    decodeSme2MVMultiVecIndexedTwoRegs(ExtMachInst machInst)
    {
        uint8_t op0 = (uint32_t)bits(machInst, 23, 22);
        uint8_t op1 = (uint32_t)bits(machInst, 12, 11);
        uint8_t op2 = (uint32_t)bits(machInst, 5);
        uint8_t op3 = (uint32_t)bits(machInst, 4, 3);

        switch (op0) {
          case 0x0: // op0=00
            if (bits(op1, 1) == 0) {
                // op0=00 op1=0x
                return decodeSme2MultiVecIdxLongLongMla2Srcs32(machInst);
            } else {
                // op0=00 op1=1x
                return decodeSme2MultiVecTerIdx2Regs16(machInst);
            }
            break;
          case 0x1: // op0=01
            // op0=01
            // SME2 multi-vec ternary indexed two registers 32-bit
            return decodeSme2MultiVecTerIdx2Regs32(machInst);
          case 0x2: // op0=10
            if (op2 == 0) {    // op0=10 op2=0
                if (op1 == 00) {
                    // op0=10 op1=00 op2=0
                    return decodeSme2MultiVecIdxLongLongMla2Srcs64(machInst);
                } else if (bits(op1, 1) == 1) {
                    // op0=10 op1=1x op2=00x
                    return decodeSme2MultiVecIdxLongFma2Srcs(machInst);
                }
            } else {            // op0=10 op2=1
                if (bits(op1, 1) == 0 && op3 == 0x0) {
                    // op0=10 op1=0x op2=1 op3=00
                    // FMLALL (multiple and indexed vector) —
                    // Two ZA quad-vectors
                } else if (bits(op1, 1) == 1 && bits(op3, 1) == 1) {
                    // op0=10 op1=1x op2=1 op3=1x
                    // FMLAL (multiple and indexed vector, FP8 to FP16) —
                    // Two ZA double-vectors
                    return new Unknown64(machInst);
                }
            }
            break;
          case 0x3: // op0=11
            if (op2 == 0) {    // op0=11 op2=0
                if (op1 == 0) {
                    // op0=11 op1=00 op2=0
                    // SME2 multi-vec ternary indexed two registers 64-bit
                    return decodeSme2MultiVecTerIdx2Regs64(machInst);
                } else if (op1 == 1) {
                    // op0=11 op1=01 op2=0
                    // SME2 multi-vec indexed FP8 two-way vertical dot product
                    // to single precision two registers
                    return new Unknown64(machInst);
                } else {
                    // op0=11 op1=1x op2=0
                    return decodeSme2MultiVecIdxLongMla2Srcs(machInst);
                }
            } else {    // op0=11 op2=1
                if (bits(op3, 1) == 0) {
                    // op0=11 op2=1 op3=0x
                    // SME2 multi-vec indexed FP8 two-way dot product to
                    // FP16 two registers
                    return new Unknown64(machInst);
                }
            }
            break;
        }
        return new Unknown64(machInst);
    }

    // C4.1.24.1 SME2 multi-vec indexed long long MLA four sources 32-bit
    StaticInstPtr
    decodeSme2MultiVecIdxLongLongMla4Srcs32(ExtMachInst machInst)
    {
        uint8_t op_U_S = (uint8_t)bits(machInst, 5, 3);
        RegIndex Zn = (RegIndex)(uint32_t)(bits(machInst, 9, 7) << 2);
        RegIndex Zm = (RegIndex)(uint32_t)(bits(machInst, 19, 16));
        RegIndex Rv = (RegIndex)(0b1000 + (uint32_t)bits(machInst, 14, 13));
        uint8_t off1 = (uint8_t)bits(machInst, 0) << 2;
        uint8_t i4 = ((uint8_t)bits(machInst, 11, 10) << 2) |
                        (uint8_t)bits(machInst, 2, 1);

        switch (op_U_S) {
          case 0x0: // op=0 U=0 S=0
            return new SmeSmlallI8I32MIdx4Reg<int8_t, int8_t, int32_t>(
                machInst, Rv, off1, Zn, Zn+1, Zn+2, Zn+3, Zm, i4);
          case 0x1: // op=0 U=0 S=1
            return new SmeSmlsllI8I32MIdx4Reg<int8_t, int8_t, int32_t>(
                machInst, Rv, off1, Zn, Zn+1, Zn+2, Zn+3, Zm, i4);
          case 0x2: // op=0 U=1 S=0
            return new SmeUmlallI8I32MIdx4Reg<uint8_t, uint8_t, uint32_t>(
                machInst, Rv, off1, Zn, Zn+1, Zn+2, Zn+3, Zm, i4);
          case 0x3: // op=0 U=1 S=1
            return new SmeUmlsllI8I32MIdx4Reg<uint8_t, uint8_t, uint32_t>(
                machInst, Rv, off1, Zn, Zn+1, Zn+2, Zn+3, Zm, i4);
          case 0x4: // op=1 U=0 S=0
            return new SmeUsmlallMIdx4Reg<uint8_t, int8_t, int32_t>(
                machInst, Rv, off1, Zn, Zn+1, Zn+2, Zn+3, Zm, i4);
          case 0x6: // op=1 U=1 S=0
            return new SmeSumlallMIdx4Reg<int8_t, uint8_t, int32_t>(
                machInst, Rv, off1, Zn, Zn+1, Zn+2, Zn+3, Zm, i4);
        }
        return new Unknown64(machInst);
    }

    // C4.1.24.2 SME2 multi-vec ternary indexed four registers 16-bit
