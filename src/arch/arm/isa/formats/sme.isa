                    machInst, Rv, off1, Zn, Zn+1, Zm, Zm+1);
            }
          case 0x1: // U=0 S=0 op=1
            if (sz == 0) {
                return new SmeUsmlallMVec2Reg<uint8_t, int8_t, int32_t>(
                    machInst, Rv, off1, Zn, Zn+1, Zm, Zm+1);
            }
            break;
          case 0x2: // U=0 S=1 op=0
            if (sz) {
                return new SmeSmlsllI16I64MVec2Reg<int16_t, int16_t, int64_t>(
                    machInst, Rv, off1, Zn, Zn+1, Zm, Zm+1);
            } else {
