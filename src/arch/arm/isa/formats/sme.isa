    // C4.1.23.7 SME2 multi-vec indexed FP8 two-way vertical dot product to
    // single precision two registers
    // C4.1.23.8 SME2 multi-vec indexed long MLA two sources
    StaticInstPtr
    decodeSme2MultiVecIdxLongMla2Srcs(ExtMachInst machInst)
    {
        uint8_t U_S = (uint8_t)bits(machInst, 4, 3);
        RegIndex Zn = (RegIndex)(uint32_t)(bits(machInst, 9, 6) << 1);
        RegIndex Zm = (RegIndex)(uint32_t)(bits(machInst, 19, 16));
        RegIndex Rv = (RegIndex)(0b1000 + (uint32_t)bits(machInst, 14, 13));
        uint8_t off2 = (uint8_t)bits(machInst, 1, 0) << 1;
        uint8_t i3 = ((uint8_t)bits(machInst, 11, 10) << 1) |
                        (uint8_t)bits(machInst, 2);

        switch (U_S) {
          case 0x0: // U=0 S=0
            return new SmeSmlalMIdx2Reg<int16_t, int16_t, int32_t>(
                machInst, Rv, off2, Zn, Zn+1, Zm, i3);
          case 0x1: // U=0 S=1
            return new SmeSmlslMIdx2Reg<int16_t, int16_t, int32_t>(
                machInst, Rv, off2, Zn, Zn+1, Zm, i3);
          case 0x2: // U=1 S=0
            return new SmeUmlalMIdx2Reg<uint16_t, uint16_t, uint32_t>(
                machInst, Rv, off2, Zn, Zn+1, Zm, i3);
          case 0x3: // U=1 S=1
            return new SmeUmlslMIdx2Reg<uint16_t, uint16_t, uint32_t>(
                machInst, Rv, off2, Zn, Zn+1, Zm, i3);
        }
        return new Unknown64(machInst);
