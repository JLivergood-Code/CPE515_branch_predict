{
    StaticInstPtr decodeSmeMgmt(ExtMachInst);
    StaticInstPtr decodeSmeInst(ExtMachInst);

        StaticInstPtr decodeSmeFpOuterProd32(ExtMachInst);
        StaticInstPtr decodeSme2OuterProdMisc(ExtMachInst);
        StaticInstPtr decodeSme2MVMemContig(ExtMachInst);
        StaticInstPtr decodeSme2MVMemStride(ExtMachInst);
        StaticInstPtr decodeSmeIntOuterProd32(ExtMachInst);
        StaticInstPtr decodeSmeOuterProd64(ExtMachInst);
