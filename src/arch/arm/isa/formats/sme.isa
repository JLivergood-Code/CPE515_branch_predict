output decoder {{
namespace Aarch64
{
    // NOTE: This is called from a different decode tree (aarch64.isa).
    // For neatness and clarity we keep the code here order to keep all
    // SME things together.
    StaticInstPtr
    decodeSmeMgmt(ExtMachInst machInst)
    {
        const uint8_t imm = (uint8_t)bits(machInst, 10, 8);

        if (bits(machInst, 8)) {
            return new SmeSmstart(machInst, imm);
        } else {
            return new SmeSmstop(machInst, imm);
        }
    }

    StaticInstPtr
    decodeSmeInst(ExtMachInst machInst)
    {
        // Starting point for decoding: bits 31:25=1xx0000

        if (isSmeFpOuterProd32(machInst) && (bits(machInst, 3, 2) == 0b00))
            return decodeSmeFpOuterProd32(machInst);
        if (isSme2FpOuterProdMisc(machInst) && (bits(machInst, 3, 2) == 0b10))
            return decodeSme2OuterProdMisc(machInst);
        if (isSme2MVMemContig(machInst))
            return decodeSme2MVMemContig(machInst);
        if (isSme2MVMemStride(machInst))
            return decodeSme2MVMemStride(machInst);
        if (isSmeIntOuterProd32(machInst) && (bits(machInst, 2) == 0b0))
            return decodeSmeIntOuterProd32(machInst);
        if (isSmeOuterProd64(machInst) && (bits(machInst, 3) == 0b0))
            return decodeSmeOuterProd64(machInst);
        if (isSmeZeroArray(machInst)) return decodeSmeZeroArray(machInst);
        if (isSme2MultiZero(machInst)) return decodeSme2MultiZero(machInst);
        if (isSme2ZeroLookupTable(machInst))
            return decodeSme2ZeroLookupTable(machInst);
        if (isSme2MoveLookupTable(machInst))
            return decodeSme2MoveLookupTable(machInst);
        if (isSme2ExpandLookupTableNonContig(machInst))
            return decodeSme2ExpandLookupTableNonContig(machInst);
        if (isSme2ExpandLookupTableContig(machInst))
            return decodeSme2ExpandLookupTableContig(machInst);
        if (isSmeMoveIntoArray(machInst) && (bits(machInst, 4) == 0b0))
            return decodeSmeMoveIntoArray(machInst);
        if (isSmeMoveFromArray(machInst))
            return decodeSmeMoveFromArray(machInst);
        if (isSmeAddVecToArray(machInst) && (bits(machInst, 3) == 0b0))
            return decodeSmeAddVecToArray(machInst);
        if (isSme2MVMultiAndSingleArrayVecTwoRegs(machInst))
            return decodeSme2MVMultiAndSingleArrayVecTwoRegs(machInst);
        if (isSme2MVMultiAndSingleArrayVecFourRegs(machInst))
            return decodeSme2MVMultiAndSingleArrayVecFourRegs(machInst);
        if (isSme2MVMultiArrayTwoRegs(machInst))
            return decodeSme2MVMultiArrayTwoRegs(machInst);
        if (isSme2MVMultiArrayFourRegs(machInst))
            return decodeSme2MVMultiArrayFourRegs(machInst);
        if (isSme2MVMultiVecIndexedOneReg(machInst))
            return decodeSme2MVMultiVecIndexedOneReg(machInst);
        if (isSme2MVMultiVecIndexedTwoRegs(machInst))
            return decodeSme2MVMultiVecIndexedTwoRegs(machInst);
        if (isSme2MVMultiVecIndexedFourRegs(machInst))
            return decodeSme2MVMultiVecIndexedFourRegs(machInst);
        if (isSme2MVMultiAndSingleSveDestrTwoRegs(machInst))
            return decodeSme2MVMultiAndSingleSveDestrTwoRegs(machInst);
        if (isSme2MVMultiAndSingleSveDestrFourRegs(machInst) &&
                (bits(machInst, 1) == 0b0))
            return decodeSme2MVMultiAndSingleSveDestrFourRegs(machInst);
        if (isSme2MVMultiVecSveDestrFourRegs(machInst) &&
                (bits(machInst, 1) == 0b0))
            return decodeSme2MVMultiVecSveDestrFourRegs(machInst);
        if (isSme2MVMultiVecSveSatMulFourRegs(machInst) &&
                (bits(machInst, 1) == 0b0))
            return decodeSme2MVMultiVecSveSatMulFourRegs(machInst);
        if (isSme2MVMultiVecSveDestrTwoRegs(machInst))
            return decodeSme2MVMultiVecSveDestrTwoRegs(machInst);
        if (isSme2MVMultiVecSveSatMulTwoRegs(machInst))
            return decodeSme2MVMultiVecSveSatMulTwoRegs(machInst);
        if (isSme2MVMultiVecSveSel(machInst))
            return decodeSme2MVMultiVecSveSel(machInst);
        if (isSme2MVSveConstrBin(machInst))
            return decodeSme2MVSveConstrBin(machInst);
        if (isSme2MVSveConstrUnary(machInst))
            return decodeSme2MVSveConstrUnary(machInst);

        if (bits(machInst, 30, 29) == 0b11) {
            return decodeSmeMemory(machInst);
        }

        // We should not get here
        return new Unknown64(machInst);
    }

    // C4.1.3.1 SME FP32 outer product
    StaticInstPtr
    decodeSmeFp32OuterProd(ExtMachInst machInst)
    {
        const uint32_t S = (uint32_t)bits(machInst, 4, 4);

        const RegIndex Zm = (RegIndex)(uint32_t)(bits(machInst, 20, 16));
        const RegIndex Zn = (RegIndex)(uint32_t)(bits(machInst, 9, 5));
        const RegIndex Pn = (RegIndex)(uint32_t)(bits(machInst, 12, 10));
        const RegIndex Pm = (RegIndex)(uint32_t)(bits(machInst, 15, 13));
        const RegIndex ZAda = (RegIndex)(uint32_t)(bits(machInst, 1, 0));

        if (S == 0) {
            return new SmeFmopaSp<uint32_t, uint32_t>(
                machInst, ZAda, Zn, Pn, Pm, Zm);
        } else {
            return new SmeFmopsSp<uint32_t, uint32_t>(
                machInst, ZAda, Zn, Pn, Pm, Zm);
        }
        return new Unknown64(machInst);
    }

    // C4.1.3.2 SME BF16 widening outer product
    StaticInstPtr
    decodeSmeBf16WidenOuterProd(ExtMachInst machInst)
    {
        const uint32_t S = (uint32_t)bits(machInst, 4, 4);

        const RegIndex Zm = (RegIndex)(uint32_t)(bits(machInst, 20, 16));
        const RegIndex Zn = (RegIndex)(uint32_t)(bits(machInst, 9, 5));
        const RegIndex Pn = (RegIndex)(uint32_t)(bits(machInst, 12, 10));
        const RegIndex Pm = (RegIndex)(uint32_t)(bits(machInst, 15, 13));
        const RegIndex ZAda = (RegIndex)(uint32_t)(bits(machInst, 1, 0));

        if (S == 0) {
            return new SmeBfmopaWiden<uint16_t, uint32_t>(
                machInst, ZAda, Zn, Pn, Pm, Zm);
        } else {
            return new SmeBfmopsWiden<uint16_t, uint32_t>(
                machInst, ZAda, Zn, Pn, Pm, Zm);
        }
        return new Unknown64(machInst);
    }

    // C4.1.3.3 SME FP16 widening outer product
    StaticInstPtr
    decodeSmeFp16WidenOuterProd(ExtMachInst machInst)
    {
        const uint32_t S = (uint32_t)bits(machInst, 4, 4);

        const RegIndex Zm = (RegIndex)(uint32_t)(bits(machInst, 20, 16));
        const RegIndex Zn = (RegIndex)(uint32_t)(bits(machInst, 9, 5));
        const RegIndex Pn = (RegIndex)(uint32_t)(bits(machInst, 12, 10));
        const RegIndex Pm = (RegIndex)(uint32_t)(bits(machInst, 15, 13));
        const RegIndex ZAda = (RegIndex)(uint32_t)(bits(machInst, 1, 0));

        if (S == 0) {
            return new SmeFmopaHpSp<uint16_t, uint32_t>(
                machInst, ZAda, Zn, Pn, Pm, Zm);
        } else {
            return new SmeFmopsHpSp<uint16_t, uint32_t>(
                machInst, ZAda, Zn, Pn, Pm, Zm);
        }
        return new Unknown64(machInst);
    }

    // C4.1.3 SME FP Outer Product - 32 bit
    StaticInstPtr
    decodeSmeFpOuterProd32(ExtMachInst machInst)
    {
        uint8_t op0_op1 = (uint8_t)(bits(machInst, 24) << 1) |
                            (uint8_t)bits(machInst, 21);
        switch (op0_op1) {
          case 0x0: // op0=0 op1=0
            return decodeSmeFp32OuterProd(machInst);
          case 0x1: // op0=0 op1=1
            {
                uint8_t op2 = (uint8_t)bits(machInst, 3);
                if (op2 == 0x0) {   // op0=0 op1=1 op2=0
                    // FMOPA (widening, 4-way)
                    return new Unknown64(machInst);
                }
            }
            break;
          case 0x2: // op0=1 op1=0
            return decodeSmeBf16WidenOuterProd(machInst);
          case 0x3: // op0=1 op1=1
            return decodeSmeFp16WidenOuterProd(machInst);
        }
        return new Unknown64(machInst);
    }

    // C4.1.4.1 SME2 32-bit binary outer product
    StaticInstPtr
    decodeSme232bitBinOuterProd(ExtMachInst machInst)
    {
        const uint32_t S = (uint32_t)bits(machInst, 4, 4);

        const RegIndex Zm = (RegIndex)(uint32_t)(bits(machInst, 20, 16));
        const RegIndex Zn = (RegIndex)(uint32_t)(bits(machInst, 9, 5));
        const RegIndex Pn = (RegIndex)(uint32_t)(bits(machInst, 12, 10));
        const RegIndex Pm = (RegIndex)(uint32_t)(bits(machInst, 15, 13));
        const RegIndex ZAda = (RegIndex)(uint32_t)(bits(machInst, 1, 0));

        if (S == 0) {
            return new SmeBmopa<uint32_t, uint32_t, uint32_t>(
                machInst, ZAda, Zn, Pn, Pm, Zm);
        } else {
            return new SmeBmops<uint32_t, uint32_t, uint32_t>(
                machInst, ZAda, Zn, Pn, Pm, Zm);
        }
        return new Unknown64(machInst);
    }

    // C4.1.4.2 SME2 FP16 non-widening outer product
    StaticInstPtr
    decodeSmeFp16NonWidenOuterProd(ExtMachInst machInst)
    {
        const uint32_t S = (uint32_t)bits(machInst, 4, 4);

        const RegIndex Zm = (RegIndex)(uint32_t)(bits(machInst, 20, 16));
        const RegIndex Zn = (RegIndex)(uint32_t)(bits(machInst, 9, 5));
        const RegIndex Pn = (RegIndex)(uint32_t)(bits(machInst, 12, 10));
        const RegIndex Pm = (RegIndex)(uint32_t)(bits(machInst, 15, 13));
        const RegIndex ZAda = (RegIndex)(uint32_t)(bits(machInst, 0));

        if (S == 0) {
            return new SmeFmopaHp<uint16_t, uint16_t>(
                machInst, ZAda, Zn, Pn, Pm, Zm);
        } else {
            return new SmeFmopsHp<uint16_t, uint16_t>(
                machInst, ZAda, Zn, Pn, Pm, Zm);
        }
        return new Unknown64(machInst);
    }

    // C4.1.4.3 SME2 BF16 non-widening outer product
    StaticInstPtr
    decodeSmeBf16NonWidenOuterProd(ExtMachInst machInst)
    {
        const uint32_t S = (uint32_t)bits(machInst, 4, 4);

        const RegIndex Zm = (RegIndex)(uint32_t)(bits(machInst, 20, 16));
        const RegIndex Zn = (RegIndex)(uint32_t)(bits(machInst, 9, 5));
        const RegIndex Pn = (RegIndex)(uint32_t)(bits(machInst, 12, 10));
        const RegIndex Pm = (RegIndex)(uint32_t)(bits(machInst, 15, 13));
        const RegIndex ZAda = (RegIndex)(uint32_t)(bits(machInst, 0));

        if (S == 0) {
            return new SmeBfmopa<uint16_t, uint16_t>(
                machInst, ZAda, Zn, Pn, Pm, Zm);
        } else {
            return new SmeBfmops<uint16_t, uint16_t>(
                machInst, ZAda, Zn, Pn, Pm, Zm);
        }
        return new Unknown64(machInst);
    }

    // C4.1.4 SME2 Outer Product - Misc
    StaticInstPtr
    decodeSme2OuterProdMisc(ExtMachInst machInst)
    {
        uint8_t op0_op1 = (uint8_t)(bits(machInst, 24) << 1) |
                            (uint8_t)bits(machInst, 21);
        switch (op0_op1) {
          case 0x0: // op0=0 op1=0
            return decodeSme232bitBinOuterProd(machInst);
          case 0x1: // op0=0 op1=1
            {
                uint8_t op2_op3 = (uint8_t)(bits(machInst, 4) << 1) |
                            (uint8_t)bits(machInst, 1);
                if (op2_op3 == 0x0) {   // op0=0 op1=1 op2=0 op3=0
                    // FMOPA (widening, 2-way, FP8 to FP16)
                    return new Unknown64(machInst);
                }
            }
            break;
          case 0x2: // op0=1 op1=0
            if (bits(machInst, 1) == 0) { // op0=1 op1=0 op3=0
                return decodeSmeFp16NonWidenOuterProd(machInst);
            }
            break;
          case 0x3: // op0=1 op1=1
            if (bits(machInst, 1) == 0) { // op0=1 op1=1 op3=0
                return decodeSmeBf16NonWidenOuterProd(machInst);
            }
            break;
        }
        return new Unknown64(machInst);
    }

    // C4.1.5.1 SME2 multi-vec contiguous load (scalar plus scalar,
    // two registers)
    StaticInstPtr
    decodeSmeMVContigLoadSS2Regs(ExtMachInst machInst)
    {
        RegIndex zt = (RegIndex)((uint8_t) bits(machInst, 4, 1) << 1);
        RegIndex rn = makeSP((RegIndex) (uint8_t) bits(machInst, 9, 5));
        RegIndex rm = (RegIndex) (uint8_t) bits(machInst, 20, 16);
        RegIndex png = (RegIndex)(0b1000 + (uint8_t) bits(machInst, 12, 10));
        uint8_t msz = bits(machInst, 14, 13);
        uint8_t nt = bits(machInst, 0);

        return decodeSveContigConseLoadSSInsts(
            msz, machInst, zt, png, rn, rm, 2, nt);
    }

    // C4.1.5.2 SME2 multi-vec contiguous load (scalar plus scalar,
