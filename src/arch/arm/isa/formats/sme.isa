                machInst, Rv, off1, Zn, Zn+1, Zn+2, Zn+3, Zm, i3);
          case 0x2: // U=1 S=0
            return new SmeUmlallI16I64MIdx4Reg<uint16_t, uint16_t, uint64_t>(
                machInst, Rv, off1, Zn, Zn+1, Zn+2, Zn+3, Zm, i3);
          case 0x3: // U=1 S=1
            return new SmeUmlsllI16I64MIdx4Reg<uint16_t, uint16_t, uint64_t>(
                machInst, Rv, off1, Zn, Zn+1, Zn+2, Zn+3, Zm, i3);
