                machInst, Rv, off3, Zn, Zn+1, Zn+2, Zn+3, Zm, i1);
          case 0x1: // op=0 opc=01
            return new SmeSdotI16I64MIdx4Reg<int16_t, int16_t, int64_t>(
                machInst, Rv, off3, Zn, Zn+1, Zn+2, Zn+3, Zm, i1);
          case 0x2: // op=0 opc=10
            return new SmeFmlsDpMIdx4Reg<uint64_t, uint64_t, uint64_t>(
                machInst, Rv, off3, Zn, Zn+1, Zn+2, Zn+3, Zm, i1);
          case 0x3: // op=0 opc=11
