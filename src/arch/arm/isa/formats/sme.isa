    // C4.1.18 SME2 Multi-vector - Multiple and Single Array Vectors
    // (Two registers)
    StaticInstPtr
    decodeSme2MVMultiAndSingleArrayVecTwoRegs(ExtMachInst machInst)
    {
        uint8_t op0 = (uint8_t)bits(machInst, 22);
        uint8_t op1 = (uint8_t)bits(machInst, 12, 10);
        uint8_t op2 = (uint8_t)bits(machInst, 4, 2);
        uint8_t op3 = (uint8_t)bits(machInst, 1);

        switch (op1) {
          case 0x0:    // op1=000
            if (op0 == 0x0 && op2 == 0x0 && op3 == 0x1) {
                // op0=0 op1=000 op2=000 op3=1
                // FMLALL (multiple and single vector) — Two ZA quad-vectors
                return new Unknown64(machInst);
            } else if (op3 == 0x0) {
                // op1=000 op3=0
                return decodeSme2SingleMultiLongLongMla2Srcs(machInst);
            }
            break;
          case 0x1:    // op1=001
            return decodeSme2SingleMultiLongLongMla1Src(machInst);
          case 0x2:    // op1=010
            if (op0 == 0) {     // op0=0 op1=010
                return decodeSme2SingleMultiLongFma2Srcs(machInst);
            } else {            // op0=1 op1=010
                return decodeSme2SingleMultiLongMla2Srcs(machInst);
            }
            break;
          case 0x3:    // op1=011
            if (op0 == 0) {     // op0=0 op1=011
                return decodeSme2SingleMultiLongFma1Src(machInst);
            } else {            // op0=1 op1=011
                return decodeSme2SingleMultiLongMla1Src(machInst);
            }
            break;
          case 0x4:    // op1=100
            if (op0 == 0) {     // op0=0 op1=100
                return decodeSme2SingleMultiFpDotProd2Regs(machInst);
            }
            break;
          case 0x5:    // op1=101
            if (bits(op2, 1) == 1) {
                if (op0 == 0) { // op0=0 op1=101 op2=x1x
                    return decodeSme2SingleMultiMixDotProd2Regs(machInst);
                } else {        // op0=1 op1=101 op2=x1x
                    return decodeSme2SingleMultiTwoWayDotProd2Regs(machInst);
                }
            } else {            // op1=101 op2=x0x
                return decodeSme2SingleMultiFourWayDotProd2Regs(machInst);
            }
            break;
          case 0x6:     // op1=110
            if (bits(op2, 2) == 0) {    // op1=110 op2=0xx
                return decodeSme2SingleMultiTerFp2Regs(machInst);
            } else {                    // op1=110 op2=1xx
                return decodeSme2SingleMultiTerInt2Regs(machInst);
            }
            break;
          case 0x7:     // op1=111
            if (bits(op2, 2) == 0) {    // op1=111 op2=0xx
                return decodeSme2SingleMultiTerFp162Regs(machInst);
            }
            break;
        }
        return new Unknown64(machInst);
    }

    // C4.1.19.1 SME2 single-multi long FMA four sources
    StaticInstPtr
    decodeSme2SingleMultiLongFma4Srcs(ExtMachInst machInst)
    {
        uint8_t op_S_o2 = (uint8_t)bits(machInst, 4, 2);
        RegIndex Zn1 = (RegIndex)(uint32_t)(bits(machInst, 9, 5));
        RegIndex Zn2 = (RegIndex)(uint32_t)((Zn1 + 1) % 32);
        RegIndex Zn3 = (RegIndex)(uint32_t)((Zn1 + 2) % 32);
        RegIndex Zn4 = (RegIndex)(uint32_t)((Zn1 + 3) % 32);
        RegIndex Zm = (RegIndex)(uint32_t)(bits(machInst, 19, 16));
        RegIndex Rv = (RegIndex)(0b1000 + (uint32_t)bits(machInst, 14, 13));
        uint8_t off2 = (uint8_t)bits(machInst, 1, 0) << 1;

        switch (op_S_o2) {
          case 0x0: // op=0 S=0 o2=0
            return new SmeFmlalMSgl4Reg<uint16_t, uint16_t, uint32_t>(
                machInst, Rv, off2, Zn1, Zn2, Zn3, Zn4, Zm);
          case 0x1:
            // FMLAL (multiple and single vector, FP8 to FP16)
            return new Unknown64(machInst);
          case 0x2: // op=0 S=1 o2=0
            return new SmeFmlslMSgl4Reg<uint16_t, uint16_t, uint32_t>(
                machInst, Rv, off2, Zn1, Zn2, Zn3, Zn4, Zm);
          case 0x4: // op=1 S=0 o2=0
            return new SmeBfmlalMSgl4Reg<uint16_t, uint16_t, uint32_t>(
                machInst, Rv, off2, Zn1, Zn2, Zn3, Zn4, Zm);
          case 0x6: // op=1 S=1 o2=0
            return new SmeBfmlslMSgl4Reg<uint16_t, uint16_t, uint32_t>(
                machInst, Rv, off2, Zn1, Zn2, Zn3, Zn4, Zm);
        }
        return new Unknown64(machInst);
    }

    // C4.1.19.2 SME2 single-multi FP dot product four registers
    StaticInstPtr
    decodeSme2SingleMultiFpDotProd4Regs(ExtMachInst machInst)
    {
        uint8_t opc = (uint8_t)bits(machInst, 4, 3);
        RegIndex Zn1 = (RegIndex)(uint32_t)(bits(machInst, 9, 5));
        RegIndex Zn2 = (RegIndex)(uint32_t)((Zn1 + 1) % 32);
        RegIndex Zn3 = (RegIndex)(uint32_t)((Zn1 + 2) % 32);
        RegIndex Zn4 = (RegIndex)(uint32_t)((Zn1 + 3) % 32);
        RegIndex Zm = (RegIndex)(uint32_t)(bits(machInst, 19, 16));
        RegIndex Rv = (RegIndex)(0b1000 + (uint32_t)bits(machInst, 14, 13));
        uint8_t off3 = (uint8_t)bits(machInst, 2, 0);

        switch (opc) {
          case 0x0: // opc=00
            return new SmeFdotHpSpMSgl4Reg<uint16_t, uint16_t, uint32_t>(
                machInst, Rv, off3, Zn1, Zn2, Zn3, Zn4, Zm);
          case 0x1: // opc=01
            // FDOT (2-way, multiple and single vector, FP8 to FP16)
            return new Unknown64(machInst);
          case 0x2: // opc=10
            return new SmeBfdotMSgl4Reg<uint16_t, uint16_t, uint32_t>(
                machInst, Rv, off3, Zn1, Zn2, Zn3, Zn4, Zm);
          case 0x3: // opc=11
            // FDOT (4-way, multiple and single vector)
            return new Unknown64(machInst);
        }
        return new Unknown64(machInst);
    }

    // C4.1.19.3 SME2 single-multi mixed dot product four registers
