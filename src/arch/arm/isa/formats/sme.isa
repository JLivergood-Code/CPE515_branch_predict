                        machInst, Rv, off1, Zn1, Zn2, Zm);
            } else {
                return new SmeUmlallI8I32MSgl2Reg<uint8_t, uint8_t, uint32_t>(
                    machInst, Rv, off1, Zn1, Zn2, Zm);
            }
          case 0x5: // U=1 S=0 op=1
            if (sz == 0) {
                return new SmeSumlallMSgl2Reg<int8_t, uint8_t, int32_t>(
                    machInst, Rv, off1, Zn1, Zn2, Zm);
            }
            break;
          case 0x6: // U=1 S=1 op=0
            if (sz) {
                return new
                    SmeUmlsllI16I64MSgl2Reg<uint16_t, uint16_t, uint64_t>(
                        machInst, Rv, off1, Zn1, Zn2, Zm);
