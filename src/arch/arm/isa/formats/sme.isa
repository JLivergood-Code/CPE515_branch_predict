          case 0x5: // op=0 opc2=101
            return new SmeUsvdotMIdx4Reg<uint8_t, int8_t, int32_t>(
                machInst, Rv, off3, Zn, Zn+1, Zn+2, Zn+3, Zm, i2);
          case 0x6: // op=0 opc2=110
            return new SmeUvdotI8I32MIdx4Reg<uint8_t, uint8_t, uint32_t>(
                machInst, Rv, off3, Zn, Zn+1, Zn+2, Zn+3, Zm, i2);
          case 0x7: // op=0 opc2=111
            return new SmeSuvdotMIdx4Reg<int8_t, uint8_t, int32_t>(
                machInst, Rv, off3, Zn, Zn+1, Zn+2, Zn+3, Zm, i2);
          case 0x8: // op=1 opc2=000
            return new SmeSdotI16I32MIdx4Reg<int16_t, int16_t, int32_t>(
                machInst, Rv, off3, Zn, Zn+1, Zn+2, Zn+3, Zm, i2);
          case 0x9: // op=1 opc2=001
            return new SmeFdotHpSpMIdx4Reg<uint16_t, uint16_t, uint32_t>(
                machInst, Rv, off3, Zn, Zn+1, Zn+2, Zn+3, Zm, i2);
          case 0xa: // op=1 opc2=010
            return new SmeUdotI16I32MIdx4Reg<uint16_t, uint16_t, uint32_t>(
                machInst, Rv, off3, Zn, Zn+1, Zn+2, Zn+3, Zm, i2);
          case 0xb: // op=1 opc2=011
            return new SmeBfdotMIdx4Reg<uint16_t, uint16_t, uint32_t>(
                machInst, Rv, off3, Zn, Zn+1, Zn+2, Zn+3, Zm, i2);
          case 0xc: // op=1 opc2=100
            return new SmeSdotI8I32MIdx4Reg<int8_t, int8_t, int32_t>(
                machInst, Rv, off3, Zn, Zn+1, Zn+2, Zn+3, Zm, i2);
          case 0xd: // op=1 opc2=101
            return new SmeUsdotMIdx4Reg<uint8_t, int8_t, int32_t>(
                machInst, Rv, off3, Zn, Zn+1, Zn+2, Zn+3, Zm, i2);
          case 0xe: // op=1 opc2=110
            return new SmeUdotI8I32MIdx4Reg<uint8_t, uint8_t, uint32_t>(
                machInst, Rv, off3, Zn, Zn+1, Zn+2, Zn+3, Zm, i2);
          case 0xf: // op=1 opc2=111
            return new SmeSudotMIdx4Reg<int8_t, uint8_t, int32_t>(
                machInst, Rv, off3, Zn, Zn+1, Zn+2, Zn+3, Zm, i2);
        }
        return new Unknown64(machInst);
    }

    // C4.1.24.4 SME2 multi-vec indexed long long MLA four sources 64-bit
