        RegIndex Zdn = (RegIndex)(bits(machInst, 4, 1) << 1);
        RegIndex Zm = (RegIndex)(bits(machInst, 19, 16));
        unsigned esize = bits(machInst, 23, 22);

        switch (opc_u) {
          case 0x2: // opc=001 U=0
            return decodeSme2MSDestrBinOp2RegsSign<SmeSrshlMSgl2Reg>(
                esize, machInst, Zdn, Zdn+1, Zm);
          case 0x3: // opc=001 U=1
