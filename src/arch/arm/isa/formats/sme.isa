    // C4.1.24.3 SME2 multi-vec ternary indexed four registers 32-bit
    StaticInstPtr
    decodeSme2MultiVecTerIdx4Regs32(ExtMachInst machInst)
    {
        uint8_t op_opc2 = ((uint8_t)bits(machInst, 12) << 3) |
                            (uint8_t)bits(machInst, 5, 3);
        RegIndex Zn = (RegIndex)(uint32_t)(bits(machInst, 9, 7) << 2);
        RegIndex Zm = (RegIndex)(uint32_t)(bits(machInst, 19, 16));
        RegIndex Rv = (RegIndex)(0b1000 + (uint32_t)bits(machInst, 14, 13));
        uint8_t off3 = (uint8_t)bits(machInst, 2, 0);
        uint8_t i2 = (uint8_t)bits(machInst, 11, 10);

        switch (op_opc2) {
          case 0x0: // op=0 opc2=000
            return new SmeFmlaSpMIdx4Reg<uint32_t, uint32_t, uint32_t>(
                machInst, Rv, off3, Zn, Zn+1, Zn+2, Zn+3, Zm, i2);
          case 0x1: // op=0 opc2=001
            // FDOT (4-way, multiple and indexed vector)
            return new Unknown64(machInst);
          case 0x2: // op=0 opc2=010
            return new SmeFmlsSpMIdx4Reg<uint32_t, uint32_t, uint32_t>(
                machInst, Rv, off3, Zn, Zn+1, Zn+2, Zn+3, Zm, i2);
          case 0x4: // op=0 opc2=100
