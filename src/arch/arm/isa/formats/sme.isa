    // C4.1.22 SME2 Multi-vector - Indexed (One register)
    StaticInstPtr
    decodeSme2MVMultiVecIndexedOneReg(ExtMachInst machInst)
    {
        uint8_t op0 = bits(machInst, 23, 22);
        uint8_t op1 = bits(machInst, 12);
        uint8_t op2 = bits(machInst, 4, 2);

        switch (op0) {
          case 0x0: // op0=00
            return decodeSme2MultiVecIdxLongLongMla1Src32(machInst);
          case 0x1: // op0=01
            if (op2 == 0) { // op0=01 op2=000
                // FMLALL (multiple and indexed vector) — One ZA quad-vector
                return new Unknown64(machInst);
            }
            break;
          case 0x2: // op0=10
            if (op1 == 0) {
                if (bits(op2, 0) == 0) {    // op0=10 op1=0 op2=xx0
                    return decodeSme2MultiVecIdxLongLongMla1Src64(machInst);
                }
            } else {    // op0=10 op1=1
                return decodeSme2MultiVecIdxLongFma1Src(machInst);
            }
            break;
          case 0x3: // op0=11
            if (op1 == 1) { // op0=11 op1=1
                return decodeSme2MultiVecIdxLongMla1Src(machInst);
            }
            break;
        }
        return new Unknown64(machInst);
