    // C4.1.19.6 SME2 single-multi long long MLA four sources
    StaticInstPtr
    decodeSme2SingleMultiLongLongMla4Srcs(ExtMachInst machInst)
    {
        uint8_t U_S_op = (uint8_t)bits(machInst, 4, 2);
        RegIndex Zn1 = (RegIndex)(uint32_t)(bits(machInst, 9, 5));
        RegIndex Zn2 = (RegIndex)(uint32_t)((Zn1 + 1) % 32);
        RegIndex Zn3 = (RegIndex)(uint32_t)((Zn1 + 2) % 32);
        RegIndex Zn4 = (RegIndex)(uint32_t)((Zn1 + 3) % 32);
        RegIndex Zm = (RegIndex)(uint32_t)(bits(machInst, 19, 16));
        RegIndex Rv = (RegIndex)(0b1000 + (uint32_t)bits(machInst, 14, 13));
        uint8_t off1 = (uint8_t)bits(machInst, 0) << 2;
        uint8_t sz = (uint8_t)bits(machInst, 22);

        switch (U_S_op) {
          case 0x0: // U=0 S=0 op=0
            if (sz) {
                return new SmeSmlallI16I64MSgl4Reg<int16_t, int16_t, int64_t>(
                    machInst, Rv, off1, Zn1, Zn2, Zn3, Zn4, Zm);
            } else {
                return new SmeSmlallI8I32MSgl4Reg<int8_t, int8_t, int32_t>(
                    machInst, Rv, off1, Zn1, Zn2, Zn3, Zn4, Zm);
            }
          case 0x1: // U=0 S=0 op=1
            if (sz == 0) {
                return new SmeUsmlallMSgl4Reg<uint8_t, int8_t, int32_t>(
                    machInst, Rv, off1, Zn1, Zn2, Zn3, Zn4, Zm);
            }
            break;
          case 0x2: // U=0 S=1 op=0
            if (sz) {
                return new SmeSmlsllI16I64MSgl4Reg<int16_t, int16_t, int64_t>(
                    machInst, Rv, off1, Zn1, Zn2, Zn3, Zn4, Zm);
            } else {
                return new SmeSmlsllI8I32MSgl4Reg<int8_t, int8_t, int32_t>(
                    machInst, Rv, off1, Zn1, Zn2, Zn3, Zn4, Zm);
            }
          case 0x4: // U=1 S=0 op=0
            if (sz) {
                return new
                    SmeUmlallI16I64MSgl4Reg<uint16_t, uint16_t, uint64_t>(
                        machInst, Rv, off1, Zn1, Zn2, Zn3, Zn4, Zm);
            } else {
                return new SmeUmlallI8I32MSgl4Reg<uint8_t, uint8_t, uint32_t>(
                    machInst, Rv, off1, Zn1, Zn2, Zn3, Zn4, Zm);
            }
          case 0x5: // U=1 S=0 op=1
            if (sz == 0) {
                return new SmeSumlallMSgl4Reg<int8_t, uint8_t, int32_t>(
                    machInst, Rv, off1, Zn1, Zn2, Zn3, Zn4, Zm);
            }
            break;
          case 0x6: // U=1 S=1 op=0
            if (sz) {
                return new
                    SmeUmlsllI16I64MSgl4Reg<uint16_t, uint16_t, uint64_t>(
                        machInst, Rv, off1, Zn1, Zn2, Zn3, Zn4, Zm);
            } else {
                return new SmeUmlsllI8I32MSgl4Reg<uint8_t, uint8_t, uint32_t>(
                    machInst, Rv, off1, Zn1, Zn2, Zn3, Zn4, Zm);
            }
        }
        return new Unknown64(machInst);
    }

