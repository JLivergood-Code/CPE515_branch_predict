        switch (u) {
          case 0x0: // U=0
            return new SmeFcvtzs4Reg<uint32_t>(
                machInst, Zd, Zd+1, Zd+2, Zd+3, Zn, Zn+1, Zn+2, Zn+3);
          case 0x1: // U=1
            return new SmeFcvtzu4Reg<uint32_t>(
                machInst, Zd, Zd+1, Zd+2, Zd+3, Zn, Zn+1, Zn+2, Zn+3);
        }
        return new Unknown64(machInst);
    }

    // C4.1.33.4 SME2 multi-vec int to FP four registers
    StaticInstPtr
    decodeSme2MultiVecInt2FpCvt4Regs(ExtMachInst machInst)
    {
        uint8_t u = (uint8_t)bits(machInst, 5);
        RegIndex Zd = (RegIndex)(bits(machInst, 4, 2) << 2);
        RegIndex Zn = (RegIndex)(bits(machInst, 9, 7) << 2);

        switch (u) {
          case 0x0: // U=0
            return new SmeScvtf4Reg<uint32_t>(
                machInst, Zd, Zd+1, Zd+2, Zd+3, Zn, Zn+1, Zn+2, Zn+3);
          case 0x1: // U=1
            return new SmeUcvtf4Reg<uint32_t>(
                machInst, Zd, Zd+1, Zd+2, Zd+3, Zn, Zn+1, Zn+2, Zn+3);
        }
        return new Unknown64(machInst);
    }

    // C4.1.33.5 SME2 multi-vec FP8 down convert four registers
    // C4.1.33.6 SME2 multi-vec quadwords ZIP four registers
    StaticInstPtr
    decodeSme2MultiVecQuadZip4Regs(ExtMachInst machInst)
    {
        uint8_t op = (uint8_t)bits(machInst, 1);
        RegIndex Zd = (RegIndex)(bits(machInst, 4, 2) << 2);
        RegIndex Zn = (RegIndex)(bits(machInst, 9, 7) << 2);

        switch (op) {
          case 0x0: // op=0
            return new SmeZip4Reg<__uint128_t>(
                machInst, Zd, Zd+1, Zd+2, Zd+3, Zn, Zn+1, Zn+2, Zn+3);
          case 0x1: // op=1
            return new SmeUzp4Reg<__uint128_t>(
                machInst, Zd, Zd+1, Zd+2, Zd+3, Zn, Zn+1, Zn+2, Zn+3);
        }
        return new Unknown64(machInst);
    }

    // C4.1.33.7 SME2 multi-vec FP down convert two registers
    StaticInstPtr
    decodeSme2MultiVecFpDownCvt2Regs(ExtMachInst machInst)
    {
        uint8_t op_N = ((uint8_t)bits(machInst, 22) << 1) |
                        (uint8_t)bits(machInst, 5);
        RegIndex Zd = (RegIndex)(bits(machInst, 4, 0));
        RegIndex Zn = (RegIndex)(bits(machInst, 9, 6) << 1);

        switch (op_N) {
          case 0x0: // op=0 N=0
            return new SmeFcvt2Reg<uint32_t, uint16_t>(
                machInst, Zd, Zn, Zn+1);
          case 0x1: // op=0 N=1
            return new SmeFcvtn2Reg<uint32_t, uint16_t>(
                machInst, Zd, Zn, Zn+1);
          case 0x2: // op=1 N=0
            return new SmeBfcvt2Reg<uint32_t, uint16_t>(
                machInst, Zd, Zn, Zn+1);
          case 0x3: // op=1 N=0
            return new SmeBfcvtn2Reg<uint32_t, uint16_t>(
                machInst, Zd, Zn, Zn+1);
        }
        return new Unknown64(machInst);
    }

    // C4.1.33.8 SME2 multi-vec int down convert two registers
    StaticInstPtr
    decodeSme2MultiVecIntDownCvt2Regs(ExtMachInst machInst)
    {
        uint8_t op_u = ((uint8_t)bits(machInst, 22) << 1) |
                        (uint8_t)bits(machInst, 5);
        RegIndex Zd = (RegIndex)(bits(machInst, 4, 0));
        RegIndex Zn = (RegIndex)(bits(machInst, 9, 6) << 1);

        switch (op_u) {
          case 0x0: // op=0 U=0
            return new SmeSqcvt2Reg<int32_t, int16_t>(
                machInst, Zd, Zn, Zn+1);
          case 0x1: // op=0 U=1
            return new SmeUqcvt2Reg<uint32_t, uint16_t>(
                machInst, Zd, Zn, Zn+1);
          case 0x2: // op=1 U=0
            return new SmeSqcvtu2Reg<int32_t, int16_t>(
                machInst, Zd, Zn, Zn+1);
        }
        return new Unknown64(machInst);
    }

    // C4.1.33.9 SME2 multi-vec FP8 down convert two registers
    // C4.1.33.10 SME2 multi-vec convert two registers
    StaticInstPtr
    decodeSme2MultiVecCvt2Regs(ExtMachInst machInst)
    {
        uint8_t L = (uint8_t)bits(machInst, 0);
        RegIndex Zd = (RegIndex)(bits(machInst, 4, 1) << 1);
        RegIndex Zn = (RegIndex)(bits(machInst, 9, 5));

        switch (L) {
          case 0x0: // L=0
            return new SmeFcvtWiden2Reg<uint16_t, uint32_t>(
                    machInst, Zd, Zd+1, Zn);
          case 0x1: // L=1
            return new SmeFcvtl2Reg<uint16_t, uint32_t>(
                    machInst, Zd, Zd+1, Zn);
        }
        return new Unknown64(machInst);
    }

    // C4.1.33.11 SME2 multi-vec unpack two registers
    StaticInstPtr
    decodeSme2MultiVecUnpack2Regs(ExtMachInst machInst)
    {
        uint8_t U = (uint8_t)bits(machInst, 0);
        RegIndex Zd = (RegIndex)(bits(machInst, 4, 1) << 1);
        RegIndex Zn = (RegIndex)(bits(machInst, 9, 5));
        uint8_t size = (uint8_t)bits(machInst, 23, 22);

        switch (U) {
          case 0x0: // U=0
            switch (size) {
              case 0x1:
                return new SmeSunpk2Reg<int8_t, int16_t>(
                        machInst, Zd, Zd+1, Zn);
              case 0x2:
                return new SmeSunpk2Reg<int16_t, int32_t>(
                        machInst, Zd, Zd+1, Zn);
              case 0x3:
                return new SmeSunpk2Reg<int32_t, int64_t>(
                        machInst, Zd, Zd+1, Zn);
            }
            break;
          case 0x1: // U=1
            switch (size) {
              case 0x1:
                return new SmeUunpk2Reg<uint8_t, uint16_t>(
                        machInst, Zd, Zd+1, Zn);
              case 0x2:
                return new SmeUunpk2Reg<uint16_t, uint32_t>(
                        machInst, Zd, Zd+1, Zn);
              case 0x3:
                return new SmeUunpk2Reg<uint32_t, uint64_t>(
                        machInst, Zd, Zd+1, Zn);
            }
            break;
        }
        return new Unknown64(machInst);
    }

    // C4.1.33.12 SME2 multi-vec FP8 up convert two registers
    // C4.1.33.13 SME2 multi-vec FRINT two registers
    StaticInstPtr
    decodeSme2MultiVecFrint2Regs(ExtMachInst machInst)
    {
        uint8_t opc = (uint8_t)bits(machInst, 18, 16);
        RegIndex Zd = (RegIndex)(bits(machInst, 4, 1) << 1);
        RegIndex Zn = (RegIndex)(bits(machInst, 9, 6) << 1);
        uint8_t esize = (uint8_t)bits(machInst, 23, 22);

        if (esize != 0x2) {
            return new Unknown64(machInst);
        }

        switch (opc) {
          case 0x0: // opc=000
            return new SmeFrintn2Reg<uint32_t>(machInst, Zd, Zd+1, Zn, Zn+1);
          case 0x1: // opc=001
            return new SmeFrintp2Reg<uint32_t>(machInst, Zd, Zd+1, Zn, Zn+1);
          case 0x2: // opc=010
            return new SmeFrintm2Reg<uint32_t>(machInst, Zd, Zd+1, Zn, Zn+1);
          case 0x4: // opc=100
            return new SmeFrinta2Reg<uint32_t>(machInst, Zd, Zd+1, Zn, Zn+1);
        }
        return new Unknown64(machInst);
    }

    // C4.1.33.14 SME2 multi-vec int down convert four registers
    StaticInstPtr
    decodeSme2MultiVecIntDownCvt4Regs(ExtMachInst machInst)
    {
        uint8_t op_n_u = ((uint8_t)bits(machInst, 22) << 2) |
                        (uint8_t)bits(machInst, 6, 5);
        RegIndex Zd = (RegIndex)(bits(machInst, 4, 0));
        RegIndex Zn = (RegIndex)(bits(machInst, 9, 7) << 2);
        unsigned sz = bits(machInst, 23);

        switch (op_n_u) {
          case 0x0: // op=0 N=0 U=0
            if (sz) {
                return new SmeSqcvt4Reg<int64_t, int16_t>(
                    machInst, Zd, Zn, Zn+1, Zn+2, Zn+3);
            } else {
                return new SmeSqcvt4Reg<int32_t, int8_t>(
                    machInst, Zd, Zn, Zn+1, Zn+2, Zn+3);
            }
          case 0x1: // op=0 N=0 U=1
            if (sz) {
                return new SmeUqcvt4Reg<uint64_t, uint16_t>(
                    machInst, Zd, Zn, Zn+1, Zn+2, Zn+3);
            } else {
                return new SmeUqcvt4Reg<uint32_t, uint8_t>(
                    machInst, Zd, Zn, Zn+1, Zn+2, Zn+3);
            }
          case 0x2: // op=0 N=1 U=0
            if (sz) {
                return new SmeSqcvtn4Reg<int64_t, int16_t>(
                    machInst, Zd, Zn, Zn+1, Zn+2, Zn+3);
            } else {
                return new SmeSqcvtn4Reg<int32_t, int8_t>(
                    machInst, Zd, Zn, Zn+1, Zn+2, Zn+3);
            }
          case 0x3: // op=0 N=1 U=1
            if (sz) {
                return new SmeUqcvtn4Reg<uint64_t, uint16_t>(
                    machInst, Zd, Zn, Zn+1, Zn+2, Zn+3);
            } else {
                return new SmeUqcvtn4Reg<uint32_t, uint8_t>(
                    machInst, Zd, Zn, Zn+1, Zn+2, Zn+3);
            }
          case 0x4: // op=1 N=0 U=0
            if (sz) {
                return new SmeSqcvtu4Reg<int64_t, int16_t>(
                    machInst, Zd, Zn, Zn+1, Zn+2, Zn+3);
            } else {
                return new SmeSqcvtu4Reg<int32_t, int8_t>(
                    machInst, Zd, Zn, Zn+1, Zn+2, Zn+3);
            }
          case 0x6: // op=1 N=1 U=0
            if (sz) {
                return new SmeSqcvtun4Reg<int64_t, int16_t>(
                    machInst, Zd, Zn, Zn+1, Zn+2, Zn+3);
            } else {
                return new SmeSqcvtun4Reg<int32_t, int8_t>(
                    machInst, Zd, Zn, Zn+1, Zn+2, Zn+3);
            }
        }
        return new Unknown64(machInst);
    }

    // C4.1.33.15 SME2 multi-vec unpack four registers
    StaticInstPtr
    decodeSme2MultiVecUnpack4Regs(ExtMachInst machInst)
    {
        uint8_t U = (uint8_t)bits(machInst, 0);
        RegIndex Zd = (RegIndex)(bits(machInst, 4, 2) << 2);
        RegIndex Zn = (RegIndex)(bits(machInst, 9, 6) << 1);
        uint8_t size = (uint8_t)bits(machInst, 23, 22);

        switch (U) {
          case 0x0: // U=0
            switch (size) {
              case 0x1:
                return new SmeSunpk4Reg<int8_t, int16_t>(
                        machInst, Zd, Zd+1, Zd+2, Zd+3, Zn, Zn+1);
              case 0x2:
                return new SmeSunpk4Reg<int16_t, int32_t>(
                        machInst, Zd, Zd+1, Zd+2, Zd+3, Zn, Zn+1);
              case 0x3:
                return new SmeSunpk4Reg<int32_t, int64_t>(
                        machInst, Zd, Zd+1, Zd+2, Zd+3, Zn, Zn+1);
            }
            break;
          case 0x1: // U=1
            switch (size) {
              case 0x1:
                return new SmeUunpk4Reg<uint8_t, uint16_t>(
                        machInst, Zd, Zd+1, Zd+2, Zd+3, Zn, Zn+1);
              case 0x2:
                return new SmeUunpk4Reg<uint16_t, uint32_t>(
                        machInst, Zd, Zd+1, Zd+2, Zd+3, Zn, Zn+1);
              case 0x3:
                return new SmeUunpk4Reg<uint32_t, uint64_t>(
                        machInst, Zd, Zd+1, Zd+2, Zd+3, Zn, Zn+1);
            }
            break;
        }
        return new Unknown64(machInst);
    }

    // C4.1.33.16 SME2 multi-vec ZIP four registers
    StaticInstPtr
    decodeSme2MultiVecZip4Regs(ExtMachInst machInst)
    {
        uint8_t op = (uint8_t)bits(machInst, 1);
        RegIndex Zd = (RegIndex)(bits(machInst, 4, 2) << 2);
        RegIndex Zn = (RegIndex)(bits(machInst, 9, 7) << 2);
        uint8_t size = (uint8_t)bits(machInst, 23, 22);

        switch (op) {
          case 0x0: // op=0
            return decodeSme2MVDestrBinOp4Regs<SmeZip4Reg>(size,
                    machInst, Zd, Zd+1, Zd+2, Zd+3, Zn, Zn+1, Zn+2, Zn+3);
          case 0x1: // op=1
            return decodeSme2MVDestrBinOp4Regs<SmeUzp4Reg>(size,
                    machInst, Zd, Zd+1, Zd+2, Zd+3, Zn, Zn+1, Zn+2, Zn+3);
        }
        return new Unknown64(machInst);
    }

    // C4.1.33.17 SME2 multi-vec FRINT four registers
    StaticInstPtr
    decodeSme2MultiVecFrint4Regs(ExtMachInst machInst)
    {
        uint8_t opc = (uint8_t)bits(machInst, 18, 16);
        RegIndex Zd = (RegIndex)(bits(machInst, 4, 2) << 2);
        RegIndex Zn = (RegIndex)(bits(machInst, 9, 7) << 2);
        uint8_t esize = (uint8_t)bits(machInst, 23, 22);

        if (esize != 0x2) {
            return new Unknown64(machInst);
        }

        switch (opc) {
          case 0x0: // opc=000
            return new SmeFrintn4Reg<uint32_t>(
                machInst, Zd, Zd+1, Zd+2, Zd+3, Zn, Zn+1, Zn+2, Zn+3);
          case 0x1: // opc=001
            return new SmeFrintp4Reg<uint32_t>(
                machInst, Zd, Zd+1, Zd+2, Zd+3, Zn, Zn+1, Zn+2, Zn+3);
          case 0x2: // opc=010
            return new SmeFrintm4Reg<uint32_t>(
                machInst, Zd, Zd+1, Zd+2, Zd+3, Zn, Zn+1, Zn+2, Zn+3);
          case 0x4: // opc=100
            return new SmeFrinta4Reg<uint32_t>(
                machInst, Zd, Zd+1, Zd+2, Zd+3, Zn, Zn+1, Zn+2, Zn+3);
        }
        return new Unknown64(machInst);
    }

    // C4.1.33 SME2 Multi-vector - SVE Constructive Unary
    StaticInstPtr
    decodeSme2MVSveConstrUnary(ExtMachInst machInst)
    {
        uint8_t op0 = (uint8_t)bits(machInst, 23, 22);
        uint8_t op1_op2 = (uint8_t)bits(machInst, 20, 16);
        uint8_t op3 = (uint8_t)bits(machInst, 6, 5);
        uint8_t op4 = (uint8_t)bits(machInst, 1, 0);

        switch (op1_op2) {
          case 0x00:    // op1=000 op2=00
            if (bits(op0, 1) == 0) {
                // op0=0x op1=000 op2=00
                return decodeSme2MultiVecFpDownCvt2Regs(machInst);
            } else if (op0 == 0x2) {
                // op0=10 op1=000 op2=00
                return decodeSme2MultiVecCvt2Regs(machInst);
            }
            break;
          case 0x01:    // op1=000 op2=01
            if ((op0 == 0x0) && bits(op4, 0) == 0) {
                // op0=00 op1=000 op2=01 op4=x0
                return decodeSme2MultiVecFp2IntCvt2Regs(machInst);
            }
            break;
          case 0x02:    // op1=000 op2=10
            if (op0 == 0x0 && bits(op4, 0) == 0) {
                // op0=00 op1=000 op2=10 op4=x0
                return decodeSme2MultiVecInt2FpCvt2Regs(machInst);
            }
            break;
          case 0x03:    // op1=000 op2=11
            if (bits(op0, 1) == 0) {
                // op0=0x op1=000 op2=11
                // SME2 multi-vec int down convert two registers
                return decodeSme2MultiVecIntDownCvt2Regs(machInst);
            }
            break;
          case 0x04:    // op1=001 op2=00
            if (bits(op0, 1) == 0 && bits(op3, 0) == 0) {
                // op0=0x op1=001 op2=00 op3=x0
                // SME2 multi-vec FP8 down convert two registers
                return new Unknown64(machInst);
            }
            break;
          case 0x05:    // op1=001 op2=01
            return decodeSme2MultiVecUnpack2Regs(machInst);
          case 0x06:    // op1=001 op2=10
            // SME2 multi-vec FP8 up convert two registers
            return new Unknown64(machInst);
          case 0x08: case 0x09: case 0x0a: case 0x0b:
          case 0x0c: case 0x0d: case 0x0e: case 0x0f:   // op1=01x
            if (bits(op3, 0) == 0 && bits(op4, 0) == 0) {
                // op1=01x op3=x0 op4=x0
                return decodeSme2MultiVecFrint2Regs(machInst);
            }
            break;
          case 0x11:    // op1=100 op2=01
            if (op0 == 0x0 && bits(op3, 1) == 0 && op4 == 0x0) {
                // op0=00 op1=000 op2=01 op3=0x op4=00
                return decodeSme2MultiVecFp2IntCvt4Regs(machInst);
            }
            break;
          case 0x12:    // op1=100 op2=10
            if (op0 == 0x0 && bits(op3, 1) == 0 && op4 == 0x0) {
                // op0=00 op1=000 op2=10 op3=0x op4=00
                return decodeSme2MultiVecInt2FpCvt4Regs(machInst);
            }
            break;
          case 0x13:    // op1=100 op2=11
            return decodeSme2MultiVecIntDownCvt4Regs(machInst);
          case 0x14:    // op1=101 op2=00
            if (op0 == 0x0 && bits(op3, 1) == 0) {
                // op0=00 op1=101 op2=00 op3=0x
                // SME2 multi-vec FP8 down convert four registers
                return new Unknown64(machInst);
            }
            break;
          case 0x15:    // op1=101 op2=01
            if (bits(op3, 0) == 0 && bits(op4, 1) == 0) {
                // op1=101 op2=01 op3=x0 op4=0x
                return decodeSme2MultiVecUnpack4Regs(machInst);
            }
            break;
          case 0x16:    // op1=101 op2=10
            if (op3 == 0x0 && bits(op4, 0) == 0) {
                // op1=101 op2=10 op3=00 op4=x0
                return decodeSme2MultiVecZip4Regs(machInst);
            }
            break;
          case 0x17:    // op1=101 op2=11
            if (op0 == 0x0 && op3 == 0x0 && bits(op4, 0) == 0) {
                // op0=00 op1=101 op2=11 op3=00 op4=x0
                return decodeSme2MultiVecQuadZip4Regs(machInst);
            }
            break;
          case 0x18: case 0x19: case 0x1a: case 0x1b:
          case 0x1c: case 0x1d: case 0x1e: case 0x1f:   // op1=11x
            if (op3 == 0x0 && op4 == 0x0) {
                // op1=11x op3=00 op4=00
                return decodeSme2MultiVecFrint4Regs(machInst);
            }
            break;
        }
        return new Unknown64(machInst);
    }

    // C4.1.34.1 SME load array vector (elements)
    StaticInstPtr
    decodeSmeLoadArrayVecElem(ExtMachInst machInst)
    {
        uint8_t msz = (uint8_t)bits(machInst, 23, 22);
        bool V = (bool)bits(machInst, 15);
        RegIndex Rn = makeSP((RegIndex)(uint32_t)bits(machInst, 9, 5));
        RegIndex Rm = (RegIndex)(uint32_t)(bits(machInst, 20, 16));
        RegIndex Rs = (RegIndex)(uint32_t)(bits(machInst, 14, 13) + 12);
        uint32_t ZAt_imm = (uint32_t)bits(machInst, 3, 0);
        RegIndex Pg = (RegIndex)(uint32_t)(bits(machInst, 12, 10));

        switch(msz)
        {
          case 0b00:
            return new SmeLd1b<uint8_t>(
                    machInst, ZAt_imm / 16, ZAt_imm % 16, Rn, Pg, Rs, Rm, V);
          case 0b01:
            return new SmeLd1h<uint16_t>(
                    machInst, ZAt_imm / 8, ZAt_imm % 8, Rn, Pg, Rs, Rm, V);
          case 0b10:
            return new SmeLd1w<uint32_t>(
                    machInst, ZAt_imm / 4, ZAt_imm % 4, Rn, Pg, Rs, Rm, V);
          case 0b11:
            return new SmeLd1d<uint64_t>(
                    machInst, ZAt_imm / 2, ZAt_imm % 2, Rn, Pg, Rs, Rm, V);
        }
        return new Unknown64(machInst);
    }

    // C4.1.34.2 SME store array vector (elements)
    StaticInstPtr
    decodeSmeStoreArrayVecElem(ExtMachInst machInst)
    {
        uint8_t msz = (uint8_t)bits(machInst, 23, 22);
        bool V = (bool)bits(machInst, 15);
        RegIndex Rn = makeSP((RegIndex)(uint32_t)bits(machInst, 9, 5));
        RegIndex Rm = (RegIndex)(uint32_t)(bits(machInst, 20, 16));
        RegIndex Rs = (RegIndex)(uint32_t)(bits(machInst, 14, 13) + 12);
        uint32_t ZAt_imm = (uint32_t)bits(machInst, 3, 0);
        RegIndex Pg = (RegIndex)(uint32_t)(bits(machInst, 12, 10));

        switch(msz)
        {
          case 0b00:
            return new SmeSt1b<uint8_t>(
                    machInst, ZAt_imm / 16, ZAt_imm % 16, Rn, Pg, Rs, Rm, V);
          case 0b01:
            return new SmeSt1h<uint16_t>(
                    machInst, ZAt_imm / 8, ZAt_imm % 8, Rn, Pg, Rs, Rm, V);
          case 0b10:
            return new SmeSt1w<uint32_t>(
                    machInst, ZAt_imm / 4, ZAt_imm % 4, Rn, Pg, Rs, Rm, V);
          case 0b11:
            return new SmeSt1d<uint64_t>(
                    machInst, ZAt_imm / 2, ZAt_imm % 2, Rn, Pg, Rs, Rm, V);
        }
        return new Unknown64(machInst);
    }

    // C4.1.34.3 SME save and restore array
    StaticInstPtr
    decodeSmeSaveRestoreArray(ExtMachInst machInst)
    {
        uint8_t op = (uint8_t)bits(machInst, 21);
        RegIndex Rn = makeSP((RegIndex)(uint32_t)bits(machInst, 9, 5));
        RegIndex Rv = (RegIndex)(uint32_t)(bits(machInst, 14, 13) + 12);
        uint32_t imm4 = (uint32_t)bits(machInst, 3, 0);

        if (op == 0) {
            return new SmeLdr(machInst, imm4, Rn, Rv);
        } else {
            return new SmeStr(machInst, imm4, Rn, Rv);
        }
        return new Unknown64(machInst);
    }

    // C4.1.34.4 SME2 lookup table load/store
    StaticInstPtr
    decodeSme2LutTableLdrStr(ExtMachInst machInst)
    {
        uint8_t opc = (uint8_t)bits(machInst, 21, 16);
        uint8_t opc2 = (uint8_t)bits(machInst, 1, 0);
        RegIndex Rn = makeSP((RegIndex)(uint32_t)bits(machInst, 9, 5));

        if (opc2 != 0x0) {
            return new Unknown64(machInst);
        }

        switch (opc) {
          case 0x1f:  // opc=011111
            return new SmeLdrTable(machInst, Rn);
          case 0x3f:  // opc=111111
            return new SmeStrTable(machInst, Rn);
        }
        return new Unknown64(machInst);
    }

    // C4.1.34 SME Memory
    StaticInstPtr
    decodeSmeMemory(ExtMachInst machInst)
    {
        uint8_t op0 = (uint8_t)bits(machInst, 24, 21);
        uint8_t op4 = (uint8_t)bits(machInst, 4, 2);

        if (bits(op4, 2) == 0x0) {  // op4=0xx
            switch (op0) {
              case 0x0: case 0x2: case 0x4: case 0x6:
                // op0=0xx0 op4=0xx
                return decodeSmeLoadArrayVecElem(machInst);
            case 0x1: case 0x3: case 0x5: case 0x7:   // op0=0xx1
                // op0=0xx1 op4=0xx
                return decodeSmeStoreArrayVecElem(machInst);
            case 0x8: case 0x9:   // op0=100x
                {
                    uint8_t op1 = (uint8_t)bits(machInst, 20, 16);
                    uint8_t op2 = (uint8_t)bits(machInst, 15);
                    uint8_t op3 = (uint8_t)bits(machInst, 14, 10);
                    if (op1 == 0x0 && op2 == 0x0 && bits(op3, 2, 0) == 0x0) {
                        // op0=100x op1=00000 op2=0 op3=xx000 op4=0xx
                        return decodeSmeSaveRestoreArray(machInst);
                    } else if (op2 == 0x1 && op3 == 0x0 && op4 == 0x0) {
                        // op0=100x op2=1 op3=00000 op4=000
                        return decodeSme2LutTableLdrStr(machInst);
                    }
                    break;
                }
            case 0xe:   // op0=1110 op4=0xx
                // LD1Q
                {
                    bool V = (bool)bits(machInst, 15);
                    RegIndex Rn = makeSP(
                        (RegIndex)(uint32_t)bits(machInst, 9, 5));
                    RegIndex Rm = (RegIndex)(uint32_t)(bits(machInst, 20, 16));
                    RegIndex Rs = (RegIndex)(uint32_t)(
                        bits(machInst, 14, 13) + 12);
                    uint32_t ZAt = (uint32_t)bits(machInst, 3, 0);
                    RegIndex Pg = (RegIndex)(uint32_t)(bits(machInst, 12, 10));

                    return new SmeLd1q<__uint128_t>(
                        machInst, ZAt, 0, Rn, Pg, Rs, Rm, V);
                }
            case 0xf:   // op0=1111 op4=0xx
                // ST1Q
                {
                    bool V = (bool)bits(machInst, 15);
                    RegIndex Rn = makeSP(
                        (RegIndex)(uint32_t)bits(machInst, 9, 5));
                    RegIndex Rm = (RegIndex)(uint32_t)(bits(machInst, 20, 16));
                    RegIndex Rs = (RegIndex)(uint32_t)(
                        bits(machInst, 14, 13) + 12);
                    uint32_t ZAt = (uint32_t)bits(machInst, 3, 0);
                    RegIndex Pg = (RegIndex)(uint32_t)(bits(machInst, 12, 10));

                    return new SmeSt1q<__uint128_t>(
                        machInst, ZAt, 0, Rn, Pg, Rs, Rm, V);
                }
            }
        }

        return new Unknown64(machInst);
    }

}
}};
