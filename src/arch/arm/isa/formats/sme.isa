                machInst, Rv, off3, Zn, Zn+1, Zn+2, Zn+3, Zm, i3);
          case 0x2: // op=1 S=0
            return new SmeBfmlaMIdx4Reg<uint16_t, uint16_t, uint16_t>(
                machInst, Rv, off3, Zn, Zn+1, Zn+2, Zn+3, Zm, i3);
          case 0x3: // op=1 S=1
