    // C4.1.20.4 SME2 multiple vectors two-way dot product two registers
    StaticInstPtr
    decodeSme2MultiVecTwoWayDotProd2Regs(ExtMachInst machInst)
    {
        uint8_t U = (uint8_t)bits(machInst, 4);
        RegIndex Zn = (RegIndex)(uint32_t)(bits(machInst, 9, 6) << 1);
        RegIndex Zm = (RegIndex)(uint32_t)(bits(machInst, 20, 17) << 1);
        RegIndex Rv = (RegIndex)(0b1000 + (uint32_t)bits(machInst, 14, 13));
        uint8_t off3 = (uint8_t)bits(machInst, 2, 0);

        switch (U) {
          case 0x0: // S=0
            return new SmeSdotI16I32MVec2Reg<int16_t, int16_t, int32_t>(
                machInst, Rv, off3, Zn, Zn+1, Zm, Zm+1);
          case 0x1: // S=1
            return new SmeUdotI16I32MVec2Reg<uint16_t, uint16_t, uint32_t>(
