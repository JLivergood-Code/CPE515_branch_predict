        RegIndex zt = (RegIndex)((uint32_t)(bits(machInst, 4) << 4) |
                                (uint32_t)(bits(machInst, 2, 0)));
        RegIndex rn = makeSP((RegIndex) (uint8_t) bits(machInst, 9, 5));
        uint64_t imm = sext<4>(bits(machInst, 19, 16)) << 1;
        RegIndex png = (RegIndex)(0b1000 + (uint8_t) bits(machInst, 12, 10));
        uint8_t msz = bits(machInst, 14, 13);
        uint8_t nt = bits(machInst, 3);

