    // C4.1.21 SME2 Multi-vector - Multiple Array Vectors (Four registers)
    StaticInstPtr
    decodeSme2MVMultiArrayFourRegs(ExtMachInst machInst)
    {
        uint8_t op0 = (uint8_t)bits(machInst, 22);
        uint8_t op1_op2 = (uint8_t)bits(machInst, 20, 17);
        uint8_t op3_op4 = ((uint8_t)bits(machInst, 12, 10) << 2) |
                            (uint8_t)bits(machInst, 6, 5);
        uint8_t op5 = (uint8_t)bits(machInst, 4, 2);
        uint8_t op6 = (uint8_t)bits(machInst, 1);

        switch (op3_op4) {
          case 0x00: // op3=000 op4=00
            if (bits(op1_op2, 0) == 0) {
                if (op6 == 0) {
                    // op2=x0 op3=000 op4=00 op6=0
                    return decodeSme2MultiVecLongLongMla4Srcs(machInst);
                }
            }
            break;
          case 0x01: // op3=000 op4=01
            if (bits(op1_op2, 0) == 0) {
                if (op0 == 0 && op5 == 0 && op6 == 0) {
                    // op0=0 op2=x0 op3=000 op4=01 op5=000 op6=0
                    // FMLALL (multiple vectors) — Four ZA quad-vectors
                    return new Unknown64(machInst);
                }
            }
            break;
          case 0x08: // op3=010 op4=00
            if (bits(op1_op2, 0) == 0) {
                if (op0 == 0 && bits(op5, 0) == 0) {
                    // op0=0 op2=x0 op3=010 op4=00 op5=xx0
                    return decodeSme2MultiVecLongFma4Srcs(machInst);
                } else if (op0 == 1 && bits(op5, 0) == 0) {
                    // op0=1 op2=x0 op3=010 op4=0 op5=xx0
                    return decodeSme2MultiVecLongMla4Srcs(machInst);
                }
            }
            break;
          case 0x09: // op3=010 op4=01
            if (bits(op1_op2, 0) == 0) {
                if (op0 == 0 && op5 == 0) {
                    // op0=0 op2=x0 op3=010 op4=01 op5=000
                    // FMLAL (multiple vectors, FP8 to FP16)
                    // — Four ZA double-vectors
                    return new Unknown64(machInst);
                }
            }
            break;
          case 0x10:   // op3=100 op4=00
            if (bits(op1_op2, 0) == 0) {
                if (op0 == 0 && bits(op5, 1) == 0) {
                    // op0=0 op2=x0 op3=100 op4=00 op5=x0x
                    return decodeSme2MultiVecFpDotProd4Regs(machInst);
                } else if (bits(op5, 1) == 1) {
                    // op2=x0 op3=100 op4=00 op5=x1x
                    return decodeSme2MultiVecTerFp164Regs(machInst);
                }
            }
            break;
          case 0x11:   // op3=100 op4=01
            if (bits(op1_op2, 0) == 0) {
                if (op0 == 0 && bits(op5, 1) == 0) {
                    // op0=0 op2=x0 op3=100 op4=01 op5=x0x
                    return decodeSme2MultiVecFpDotProd4Regs(machInst);
                }
            }
            break;
          case 0x14: // op3=101 op4=00
            if (bits(op1_op2, 0) == 0) {
                if (op0 == 0 && bits(op5, 2, 1) == 0x1) {
                    // op0=0 op2=x0 op3=101 op4=00 op5=01x
                    // USDOT (multiple vectors) — Four ZA single-vectors
                    RegIndex Zn =
                        (RegIndex)(uint32_t)(bits(machInst, 9, 7) << 2);
                    RegIndex Zm =
                        (RegIndex)(uint32_t)(bits(machInst, 20, 18) << 2);
                    RegIndex Rv =
                        (RegIndex)(0b1000 + (uint32_t)bits(machInst, 14, 13));
                    uint8_t off3 = (uint8_t)bits(machInst, 2, 0);

                    return new SmeUsdotMVec4Reg<uint8_t, int8_t, int32_t>(
                        machInst, Rv, off3, Zn, Zn+1, Zn+2, Zn+3,
                        Zm, Zm+1, Zm+2, Zm+3);
                } else if (op0 == 1 && bits(op5, 1) == 1) {
                    // op0=1 op2=x0 op3=101 op4=00 op5=x1x
                    return decodeSme2MultiVecTwoWayDotProd4Regs(machInst);
                } else if (bits(op5, 1) == 0) {
                    // op2=x0 op3=101 op4=00 op5=x0x
                    return decodeSme2MultiVecFourWayDotProd4Regs(machInst);
                }
            }
            break;
          case 0x18: // op3=110 op4=00
            if (bits(op1_op2, 0) == 0) {
                if (bits(op5, 2) == 0) {
                    // op2=x0 op3=110 op4=00 op5=0xx
                    return decodeSme2MultiVecTerFp4Regs(machInst);
                } else {
                    // op2=x0 op3=110 op4=00 op5=1xx
                    return decodeSme2MultiVecTerInt4Regs(machInst);
                }
            }
            break;
          case 0x1c: // op3=111 op4=00
            if (op1_op2 == 0x0 && bits(op5, 2) == 0) {
                // op1=00 op2=00 op3=111 op4=00 op5=0xx
                return decodeSme2MultiVecBinFp4Regs(machInst);
            } else if (op1_op2 == 0x0 && bits(op5, 2) == 1) {
                // op1=00 op2=00 op3=111 op4=00 op5=1xx
                // SME2 multiple vectors binary int four registers
                return decodeSme2MultiVecBinInt4Regs(machInst);
            } else if (op1_op2 == 0x2 && bits(op5, 2) == 0) {
                // op1=00 op2=10 op3=111 op4=00 op5=0xx
                return decodeSme2MultiVecBinFp164Regs(machInst);
            }
            break;
        }
        return new Unknown64(machInst);
    }

    // C4.1.22.1 SME2 multi-vec indexed long long MLA one source 32-bit
    StaticInstPtr
    decodeSme2MultiVecIdxLongLongMla1Src32(ExtMachInst machInst)
    {
        uint8_t U_S_op = (uint8_t)bits(machInst, 4, 2);
        RegIndex Zn = (RegIndex)(uint32_t)(bits(machInst, 9, 5));
        RegIndex Zm = (RegIndex)(uint32_t)(bits(machInst, 19, 16));
        RegIndex Rv = (RegIndex)(0b1000 + (uint32_t)bits(machInst, 14, 13));
        uint8_t off2 = (uint8_t)bits(machInst, 1, 0) << 2;
        uint8_t i4 = ((uint8_t)bits(machInst, 15) << 3) |
                        (uint8_t)bits(machInst, 12, 10);

        switch (U_S_op) {
          case 0x0: // U=0 S=0 op=0
            return new SmeSmlallI8I32MIdx1Reg<int8_t, int8_t, int32_t>(
                machInst, Rv, off2, Zn, Zm, i4);
          case 0x1: // U=0 S=0 op=0
            return new SmeUsmlallMIdx1Reg<uint8_t, int8_t, int32_t>(
                machInst, Rv, off2, Zn, Zm, i4);
          case 0x2: // U=0 S=1 op=0
            return new SmeSmlsllI8I32MIdx1Reg<int8_t, int8_t, int32_t>(
                machInst, Rv, off2, Zn, Zm, i4);
          case 0x4: // U=1 S=0 op=0
            return new SmeUmlallI8I32MIdx1Reg<uint8_t, uint8_t, uint32_t>(
                machInst, Rv, off2, Zn, Zm, i4);
          case 0x5: // U=1 S=0 op=1
            return new SmeSumlallMIdx1Reg<int8_t, uint8_t, int32_t>(
                machInst, Rv, off2, Zn, Zm, i4);
          case 0x6: // U=1 S=1 op=0
            return new SmeUmlsllI8I32MIdx1Reg<uint8_t, uint8_t, uint32_t>(
                machInst, Rv, off2, Zn, Zm, i4);
        }
        return new Unknown64(machInst);
    }

    // C4.1.22.2 SME2 multi-vec indexed long long MLA one source 64-bit
    StaticInstPtr
    decodeSme2MultiVecIdxLongLongMla1Src64(ExtMachInst machInst)
    {
        uint8_t U_S = (uint8_t)bits(machInst, 4, 3);
        RegIndex Zn = (RegIndex)(uint32_t)(bits(machInst, 9, 5));
        RegIndex Zm = (RegIndex)(uint32_t)(bits(machInst, 19, 16));
        RegIndex Rv = (RegIndex)(0b1000 + (uint32_t)bits(machInst, 14, 13));
        uint8_t off2 = (uint8_t)bits(machInst, 1, 0) << 2;
        uint8_t i3 = ((uint8_t)bits(machInst, 15) << 2) |
                        (uint8_t)bits(machInst, 11, 10);

