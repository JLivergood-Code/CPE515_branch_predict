                                (uint32_t)(bits(machInst, 2, 0)));
        RegIndex rn = makeSP((RegIndex) (uint8_t) bits(machInst, 9, 5));
        uint64_t imm = sext<4>(bits(machInst, 19, 16)) << 2;
        RegIndex png = (RegIndex)(0b1000 + (uint8_t) bits(machInst, 12, 10));
        uint8_t msz = bits(machInst, 14, 13);
        uint8_t nt = bits(machInst, 3);

        return decodeSmeNonContigtoreSIInsts(
            msz, machInst, zt, png, rn, imm, 4, nt);
    }

    // C4.1.6 SME2 Multi-vector - Memory (Strided)
    StaticInstPtr
    decodeSme2MVMemStride(ExtMachInst machInst)
    {
        uint8_t op0_op1 = (bits(machInst, 22, 20) << 1) | bits(machInst, 15);

        switch (op0_op1) {
          case 0x0: case 0x2:   // op0=00x op1=0
            return decodeSmeMVNonContigLoadSS2Regs(machInst);
          case 0x1: case 0x3:   // op0=00x op1=1
            return decodeSmeMVNonContigLoadSS4Regs(machInst);
          case 0x4: case 0x6:   // op0=01x op1=0
            return decodeSmeMVNonContigStoreSS2Regs(machInst);
          case 0x5: case 0x7:   // op0=01x op1=1
            return decodeSmeMVNonContigStoreSS4Regs(machInst);
          case 0x8:             // op0=100 op1=0
            return decodeSmeMVNonContigLoadSI2Regs(machInst);
          case 0x9:             // op0=100 op1=1
            return decodeSmeMVNonContigLoadSI4Regs(machInst);
          case 0xc:             // op0=110 op1=0
            return decodeSmeMVNonContigStoreSI2Regs(machInst);
          case 0xd:             // op0=110 op1=1
            return decodeSmeMVNonContigStoreSI4Regs(machInst);
        }
        return new Unknown64(machInst);
    }

    // C4.1.7.1 SME2 Int16 two-way outer product
    StaticInstPtr
    decodeSme2Int16TwoWayOuterProd(ExtMachInst machInst)
    {
        const uint32_t u0 = (uint32_t)bits(machInst, 24);
        const uint32_t S = (uint32_t)bits(machInst, 4);

        const RegIndex Zm = (RegIndex)(uint32_t)(bits(machInst, 20, 16));
        const RegIndex Zn = (RegIndex)(uint32_t)(bits(machInst, 9, 5));
        const RegIndex Pn = (RegIndex)(uint32_t)(bits(machInst, 12, 10));
        const RegIndex Pm = (RegIndex)(uint32_t)(bits(machInst, 15, 13));
        const RegIndex ZAda = (RegIndex)(uint32_t)(bits(machInst, 1, 0));

        if (u0 == 0) {
            if (S == 0) {
                return new SmeSmopaI16I32<int16_t, int16_t, int32_t>(
                    machInst, ZAda, Zn, Pn, Pm, Zm);
            } else {
                return new SmeSmopsI16I32<int16_t, int16_t, int32_t>(
                    machInst, ZAda, Zn, Pn, Pm, Zm);
            }
        } else {
            if (S == 0) {
                return new SmeUmopaI16I32<uint16_t, uint16_t, uint32_t>(
                    machInst, ZAda, Zn, Pn, Pm, Zm);
            } else {
                return new SmeUmopsI16I32<uint16_t, uint16_t, uint32_t>(
                    machInst, ZAda, Zn, Pn, Pm, Zm);
            }
        }

        return new Unknown64(machInst);
    }

    // C4.1.7.2 SME Int8 outer product
    StaticInstPtr
    decodeSmeInt8OuterProd(ExtMachInst machInst)
    {
        const uint32_t u0 = (uint32_t)bits(machInst, 24);
        const uint32_t u1 = (uint32_t)bits(machInst, 21);
        const uint32_t S = (uint32_t)bits(machInst, 4);

        const RegIndex Zm = (RegIndex)(uint32_t)(bits(machInst, 20, 16));
        const RegIndex Zn = (RegIndex)(uint32_t)(bits(machInst, 9, 5));
        const RegIndex Pn = (RegIndex)(uint32_t)(bits(machInst, 12, 10));
        const RegIndex Pm = (RegIndex)(uint32_t)(bits(machInst, 15, 13));
        const RegIndex ZAda = (RegIndex)(uint32_t)(bits(machInst, 1, 0));

        if (u0 == 0) {
            if (u1 == 0) {
                if (S == 0) {
                    return new SmeSmopaI8I32<int8_t, int8_t, int32_t>(
                        machInst, ZAda, Zn, Pn, Pm, Zm);
                } else {
                    return new SmeSmopsI8I32<int8_t, int8_t, int32_t>(
                        machInst, ZAda, Zn, Pn, Pm, Zm);
                }
            } else {
                if (S == 0) {
                    return new SmeSumopaI8I32<int8_t, uint8_t, int32_t>(
                        machInst, ZAda, Zn, Pn, Pm, Zm);
                } else {
                    return new SmeSumopsI8I32<int8_t, uint8_t, int32_t>(
                        machInst, ZAda, Zn, Pn, Pm, Zm);
                }
            }
        } else {
            if (u1 == 0) {
                if (S == 0) {
                    return new SmeUsmopaI8I32<uint8_t, int8_t, int32_t>(
                        machInst, ZAda, Zn, Pn, Pm, Zm);
                } else {
                    return new SmeUsmopsI8I32<uint8_t, int8_t, int32_t>(
                        machInst, ZAda, Zn, Pn, Pm, Zm);
                }
            } else {
                if (S == 0) {
                    return new SmeUmopaI8I32<uint8_t, uint8_t, uint32_t>(
                        machInst, ZAda, Zn, Pn, Pm, Zm);
                } else {
                    return new SmeUmopsI8I32<uint8_t, uint8_t, uint32_t>(
                        machInst, ZAda, Zn, Pn, Pm, Zm);
                }
            }
        }

        return new Unknown64(machInst);
    }

    // C4.1.7 SME Integer Outer Product - 32 bit
    StaticInstPtr
    decodeSmeIntOuterProd32(ExtMachInst machInst)
    {
        uint8_t op0 = (uint8_t)bits(machInst, 21);
        uint8_t op1 = (uint8_t)bits(machInst, 3);
        if (op1 == 0) { // op1=0
            return decodeSmeInt8OuterProd(machInst);
        } else if (op0 == 0) {  // op0=0 op1=1
            // SME2 Int16 two-way outer product
            return decodeSme2Int16TwoWayOuterProd(machInst);
        }
        return new Unknown64(machInst);
    }

    // C4.1.8.1 SME FP64 outer product
    StaticInstPtr
    decodeSmeFp64OuterProd(ExtMachInst machInst)
    {
        const uint32_t S = (uint32_t)bits(machInst, 4, 4);

        const RegIndex Zm = (RegIndex)(uint32_t)(bits(machInst, 20, 16));
        const RegIndex Zn = (RegIndex)(uint32_t)(bits(machInst, 9, 5));
        const RegIndex Pn = (RegIndex)(uint32_t)(bits(machInst, 12, 10));
        const RegIndex Pm = (RegIndex)(uint32_t)(bits(machInst, 15, 13));
        const RegIndex ZAda = (RegIndex)(uint32_t)(bits(machInst, 2, 0));

        if (S == 0) {
            return new SmeFmopaDp<uint64_t, uint64_t>(machInst, ZAda, Zn,
                                                    Pn, Pm, Zm);
        } else {
            return new SmeFmopsDp<uint64_t, uint64_t>(machInst, ZAda, Zn,
                                                    Pn, Pm, Zm);
        }

        return new Unknown64(machInst);
    }

    // C4.1.8.2 SME Int16 outer product
    StaticInstPtr
    decodeSmeInt16OuterProd(ExtMachInst machInst)
    {
        const uint32_t u0 = (uint32_t)bits(machInst, 24);
        const uint32_t u1 = (uint32_t)bits(machInst, 21);
        const uint32_t S = (uint32_t)bits(machInst, 4);

        const RegIndex Zm = (RegIndex)(uint32_t)(bits(machInst, 20, 16));
        const RegIndex Zn = (RegIndex)(uint32_t)(bits(machInst, 9, 5));
        const RegIndex Pn = (RegIndex)(uint32_t)(bits(machInst, 12, 10));
        const RegIndex Pm = (RegIndex)(uint32_t)(bits(machInst, 15, 13));
        const RegIndex ZAda = (RegIndex)(uint32_t)(bits(machInst, 2, 0));

        if (u0 == 0) {
            if (u1 == 0) {
                if (S == 0) {
                    return new SmeSmopaI16I64<int16_t, int16_t, int64_t>(
                        machInst, ZAda, Zn, Pn, Pm, Zm);
                } else {
                    return new SmeSmopsI16I64<int16_t, int16_t, int64_t>(
                        machInst, ZAda, Zn, Pn, Pm, Zm);
                }
            } else {
                if (S == 0) {
                    return new SmeSumopaI16I64<int16_t, uint16_t, int64_t>(
                        machInst, ZAda, Zn, Pn, Pm, Zm);
                } else {
                    return new SmeSumopsI16I64<int16_t, uint16_t, int64_t>(
                        machInst, ZAda, Zn, Pn, Pm, Zm);
                }
            }
        } else {
            if (u1 == 0) {
                if (S == 0) {
                    return new SmeUsmopaI16I64<uint16_t, int16_t, int64_t>(
                        machInst, ZAda, Zn, Pn, Pm, Zm);
                } else {
                    return new SmeUsmopsI16I64<uint16_t, int16_t, int64_t>(
                        machInst, ZAda, Zn, Pn, Pm, Zm);
                }
            } else {
                if (S == 0) {
                    return new SmeUmopaI16I64<uint16_t, uint16_t, uint64_t>(
                        machInst, ZAda, Zn, Pn, Pm, Zm);
                } else {
                    return new SmeUmopsI16I64<uint16_t, uint16_t, uint64_t>(
                        machInst, ZAda, Zn, Pn, Pm, Zm);
                }
            }
        }
        return new Unknown64(machInst);
    }

    // C4.1.8 SME Outer Product - 64 bit
    StaticInstPtr
    decodeSmeOuterProd64(ExtMachInst machInst)
    {
        uint8_t op0 = (uint8_t)bits(machInst, 29);
        uint8_t op1 = (uint8_t)bits(machInst, 24);
        uint8_t op2 = (uint8_t)bits(machInst, 21);
        if (op0 == 1) { // op0=1
            return decodeSmeInt16OuterProd(machInst);
        } else if (op1 == 0 && op2 == 0) {  // op0=0 op1=0 op2=0
            return decodeSmeFp64OuterProd(machInst);
        }
        return new Unknown64(machInst);
    }

    // C4.1.9 SME zero array
    StaticInstPtr
    decodeSmeZeroArray(ExtMachInst machInst)
    {
        uint32_t op0 = (uint32_t)bits(machInst, 17, 8);

        if (op0 == 0x0) {
            // ZERO (tiles)
            uint8_t imm8 = (uint8_t)bits(machInst, 7, 0);
            return new SmeZero<uint64_t>(machInst, imm8);
        }
        return new Unknown64(machInst);
    }

    // C4.1.10.1 SME multiple vectors zero array
    // C4.1.10 SME2 Multiple Zero
    StaticInstPtr
    decodeSme2MultiZero(ExtMachInst machInst)
    {
        uint32_t op0 = (uint32_t)bits(machInst, 12, 3);
        if (op0 != 0x0) {
            return new Unknown64(machInst);
        }

        uint8_t opc = (uint8_t)bits(machInst, 17, 15);
        RegIndex Rv = (RegIndex)(0b1000 + (uint8_t)bits(machInst, 14, 13));

        switch (opc) {
          case 0x0: // opc=000
            return new SmeZero1Reg2Grp<uint64_t>(
                machInst, Rv, (uint8_t)bits(machInst, 2, 0));
          case 0x1: // opc=001
            return new SmeZero2Reg1Grp<uint64_t>(
                machInst, Rv, (uint8_t)(bits(machInst, 2, 0) << 1));
          case 0x2: // opc=010
            if (bits(machInst, 2) == 0) {
                return new SmeZero2Reg2Grp<uint64_t>(
                    machInst, Rv, (uint8_t)(bits(machInst, 1, 0) << 1));
            }
            break;
          case 0x3: // opc=011
            if (bits(machInst, 2) == 0) {
                return new SmeZero2Reg4Grp<uint64_t>(
                    machInst, Rv, (uint8_t)(bits(machInst, 1, 0) << 1));
            }
            break;
          case 0x4: // opc=100
            return new SmeZero1Reg4Grp<uint64_t>(
                machInst, Rv, (uint8_t)bits(machInst, 2, 0));
          case 0x5: // opc=101
            if (bits(machInst, 2) == 0) {
                return new SmeZero4Reg1Grp<uint64_t>(
                    machInst, Rv, (uint8_t)(bits(machInst, 1, 0) << 2));
            }
            break;
          case 0x6: // opc=110
            if (bits(machInst, 2, 1) == 0) {
                return new SmeZero4Reg2Grp<uint64_t>(
                    machInst, Rv, (uint8_t)(bits(machInst, 0, 0) << 2));
            }
            break;
          case 0x7: // opc=111
            if (bits(machInst, 2, 1) == 0) {
                return new SmeZero4Reg4Grp<uint64_t>(
                    machInst, Rv, (uint8_t)(bits(machInst, 0, 0) << 2));
            }
            break;
        }
        return new Unknown64(machInst);
    }

    // C4.1.11.1 SME2 zero lookup table
    // C4.1.11.2 SME2 zero lookup table
    // C4.1.11 SME2 zero lookup table
    StaticInstPtr
    decodeSme2ZeroLookupTable(ExtMachInst machInst)
    {
        uint8_t op0 = bits(machInst, 17, 4);
        if (op0 != 0x0) {
            return new Unknown64(machInst);
        }

        uint8_t opc = bits(machInst, 3, 0);
        if (opc == 0x1) {
            return new SmeZeroLut(machInst);
        }
        return new Unknown64(machInst);
    }

    // C4.1.12.1 SME2 move from lookup table
    // C4.1.12.2 SME2 move into lookup table
    // C4.1.12.3 SME2 move vector to lookup table
    // C4.1.12 SME2 Move Lookup Table
    StaticInstPtr
    decodeSme2MoveLookupTable(ExtMachInst machInst)
    {
        return new Unknown64(machInst);
    }

    // C4.1.13.1 SME2 lookup table two source registers expand to four
    // non-contiguous destination registers
    StaticInstPtr
    decodeSme2Lut2SrcsTo4DestNonContig(ExtMachInst machInst)
    {
        uint8_t opc = (uint8_t)bits(machInst, 11, 10);
        RegIndex Zn = (RegIndex)(uint32_t)(bits(machInst, 9, 6) << 1);
        RegIndex Zd = (RegIndex)((uint32_t)(bits(machInst, 4) << 4) |
                                (uint32_t)(bits(machInst, 1, 0)));

        switch (opc) {
          case 0x0: // opc=00
            return new SmeLuti4to8bStride4Reg<uint8_t>(
                    machInst, Zd, Zd+4, Zd+8, Zd+12, Zn, Zn+1);
        }
        return new Unknown64(machInst);
    }

    // C4.1.13.2 SME2 lookup table expand four non-contiguous registers
    StaticInstPtr
    decodeSme2Lut4RegsNonContig(ExtMachInst machInst)
    {
        uint8_t opc = (uint8_t)bits(machInst, 18, 16);
        uint8_t opc2 = (uint8_t)bits(machInst, 11, 10);
        RegIndex Zn = (RegIndex)(uint32_t)(bits(machInst, 9, 5));
        RegIndex Zd = (RegIndex)((uint32_t)(bits(machInst, 4) << 4) |
                                (uint32_t)(bits(machInst, 1, 0)));
        uint8_t size = (uint8_t)bits(machInst, 13, 12);

        if (opc2 != 0x0) {
            return new Unknown64(machInst);
        }

        if (bits(opc, 2) == 1) {  // opc=1xx
            uint8_t i2 = (uint8_t)(bits(machInst, 17, 16));
            switch (size) {
              case 0x0:
                return new SmeLuti2Stride4Reg<uint8_t>(
                        machInst, Zd, Zd+4, Zd+8, Zd+12, Zn, i2);
              case 0x1:
                return new SmeLuti2Stride4Reg<uint16_t>(
                        machInst, Zd, Zd+4, Zd+8, Zd+12, Zn, i2);
              case 0x2:
                return new SmeLuti2Stride4Reg<uint32_t>(
                        machInst, Zd, Zd+4, Zd+8, Zd+12, Zn, i2);
            }
        } else if (bits(opc, 1) == 1) { // opc=01x
            uint8_t i1 = (uint8_t)(bits(machInst, 16));
            switch (size) {
              case 0x1:
                return new SmeLuti4Stride4Reg<uint16_t>(
                        machInst, Zd, Zd+4, Zd+8, Zd+12, Zn, i1);
              case 0x2:
                return new SmeLuti4Stride4Reg<uint32_t>(
                        machInst, Zd, Zd+4, Zd+8, Zd+12, Zn, i1);
            }
        }
        return new Unknown64(machInst);
    }

    // C4.1.13.3 SME2 lookup table expand two non-contiguous registers
    StaticInstPtr
    decodeSme2Lut2RegsNonContig(ExtMachInst machInst)
    {
        uint8_t opc = (uint8_t)bits(machInst, 18, 15);
        uint8_t opc2 = (uint8_t)bits(machInst, 11, 10);
        RegIndex Zn = (RegIndex)(uint32_t)(bits(machInst, 9, 5));
        RegIndex Zd = (RegIndex)((uint32_t)(bits(machInst, 4) << 4) |
                                (uint32_t)(bits(machInst, 2, 0)));
        uint8_t size = (uint8_t)bits(machInst, 13, 12);

        if (opc2 != 0x0) {
            return new Unknown64(machInst);
        }

        if (bits(opc, 3) == 1) {  // opc=1xxx
            uint8_t i3 = (uint8_t)(bits(machInst, 17, 15));
            switch (size) {
              case 0x0:
                return new SmeLuti2Stride2Reg<uint8_t>(
                    machInst, Zd, Zd+8, Zn, i3);
              case 0x1:
                return new SmeLuti2Stride2Reg<uint16_t>(
                    machInst, Zd, Zd+8, Zn, i3);
              case 0x2:
                return new SmeLuti2Stride2Reg<uint32_t>(
                    machInst, Zd, Zd+8, Zn, i3);
            }
        } else if (bits(opc, 2) == 1) { // opc=01xx
            uint8_t i2 = (uint8_t)(bits(machInst, 16, 15));
            switch (size) {
              case 0x0:
                return new SmeLuti4Stride2Reg<uint8_t>(
                    machInst, Zd, Zd+8, Zn, i2);
              case 0x1:
                return new SmeLuti4Stride2Reg<uint16_t>(
                    machInst, Zd, Zd+8, Zn, i2);
              case 0x2:
                return new SmeLuti4Stride2Reg<uint32_t>(
                    machInst, Zd, Zd+8, Zn, i2);
            }
        }
        return new Unknown64(machInst);
    }

    // C4.1.13 SME2 Expand Lookup Table (Non-contiguous)
    StaticInstPtr
    decodeSme2ExpandLookupTableNonContig(ExtMachInst machInst)
    {
        uint8_t op1_op3 = (bits(machInst, 15, 14) << 2) |
                          bits(machInst, 3, 2);

        if (op1_op3 == 0x0) { // op1=00 op3=00
            uint8_t op0 = bits(machInst, 18, 16);
            uint8_t op2 = bits(machInst, 5);
            if (op0 == 0x3 && op2 == 0) { // op0=011 op1=00 op2=0 op3=00
                return decodeSme2Lut2SrcsTo4DestNonContig(machInst);
            }
        } else if (op1_op3 == 0x8) {  // op1=10 op3=00
            return decodeSme2Lut4RegsNonContig(machInst);
        } else if (bits(op1_op3, 2, 1) == 0x2) {  // op1=x1 op3=0x
            return decodeSme2Lut2RegsNonContig(machInst);
        }
        return new Unknown64(machInst);
    }

    // C4.1.14.1 SME2 lookup table two source registers expand to four
    // contiguous destination registers
    StaticInstPtr
    decodeSme2Lut2SrcsTo4DestContig(ExtMachInst machInst)
    {
        uint8_t opc = (uint8_t)bits(machInst, 11, 10);
        RegIndex Zn = (RegIndex)(uint32_t)(bits(machInst, 9, 6) << 1);
        RegIndex Zd = (RegIndex)(uint32_t)(bits(machInst, 4, 2) << 2);

        switch (opc) {
          case 0x0: // opc=00
            return new SmeLuti4to8b4Reg<uint8_t>(
                    machInst, Zd, Zd+1, Zd+2, Zd+3, Zn, Zn+1);
        }
        return new Unknown64(machInst);
    }

    // C4.1.14.2 SME2 lookup table expand four contiguous registers
    StaticInstPtr
    decodeSme2Lut4RegsContig(ExtMachInst machInst)
    {
        uint8_t opc = (uint8_t)bits(machInst, 18, 16);
        uint8_t opc2 = (uint8_t)bits(machInst, 11, 10);
        RegIndex Zn = (RegIndex)(uint32_t)(bits(machInst, 9, 5));
        RegIndex Zd = (RegIndex)(uint32_t)(bits(machInst, 4, 2) << 2);
        uint8_t size = (uint8_t)bits(machInst, 13, 12);

        if (opc2 != 0x0) {
            return new Unknown64(machInst);
        }

        if (bits(opc, 2) == 1) {  // opc=1xx
            uint8_t i2 = (uint8_t)(bits(machInst, 17, 16));
            switch (size) {
              case 0x0:
                return new SmeLuti24Reg<uint8_t>(
                        machInst, Zd, Zd+1, Zd+2, Zd+3, Zn, i2);
              case 0x1:
                return new SmeLuti24Reg<uint16_t>(
                        machInst, Zd, Zd+1, Zd+2, Zd+3, Zn, i2);
              case 0x2:
                return new SmeLuti24Reg<uint32_t>(
                        machInst, Zd, Zd+1, Zd+2, Zd+3, Zn, i2);
            }
        } else if (bits(opc, 1) == 1) { // opc=01x
            uint8_t i1 = (uint8_t)(bits(machInst, 16));
            switch (size) {
              case 0x1:
                return new SmeLuti44Reg<uint16_t>(
                        machInst, Zd, Zd+1, Zd+2, Zd+3, Zn, i1);
              case 0x2:
                return new SmeLuti44Reg<uint32_t>(
                        machInst, Zd, Zd+1, Zd+2, Zd+3, Zn, i1);
            }
        }
        return new Unknown64(machInst);
    }

    // C4.1.14.3 SME2 lookup table expand two contiguous registers
    StaticInstPtr
    decodeSme2Lut2RegsContig(ExtMachInst machInst)
    {
        uint8_t opc = (uint8_t)bits(machInst, 18, 15);
        uint8_t opc2 = (uint8_t)bits(machInst, 11, 10);
        RegIndex Zn = (RegIndex)(uint32_t)(bits(machInst, 9, 5));
        RegIndex Zd = (RegIndex)(uint32_t)(bits(machInst, 4, 1) << 1);
        uint8_t size = (uint8_t)bits(machInst, 13, 12);

        if (opc2 != 0x0) {
            return new Unknown64(machInst);
        }

        if (bits(opc, 3) == 1) {  // opc=1xxx
            uint8_t i3 = (uint8_t)(bits(machInst, 17, 15));
            switch (size) {
              case 0x0:
                return new SmeLuti22Reg<uint8_t>(machInst, Zd, Zd+1, Zn, i3);
              case 0x1:
                return new SmeLuti22Reg<uint16_t>(machInst, Zd, Zd+1, Zn, i3);
              case 0x2:
                return new SmeLuti22Reg<uint32_t>(machInst, Zd, Zd+1, Zn, i3);
            }
        } else if (bits(opc, 2) == 1) { // opc=01xx
            uint8_t i2 = (uint8_t)(bits(machInst, 16, 15));
            switch (size) {
              case 0x0:
                return new SmeLuti42Reg<uint8_t>(machInst, Zd, Zd+1, Zn, i2);
              case 0x1:
                return new SmeLuti42Reg<uint16_t>(machInst, Zd, Zd+1, Zn, i2);
              case 0x2:
                return new SmeLuti42Reg<uint32_t>(machInst, Zd, Zd+1, Zn, i2);
            }
        }
        return new Unknown64(machInst);
    }

    // C4.1.14.4 SME2 lookup table expand one register
    StaticInstPtr
    decodeSme2Lut1Reg(ExtMachInst machInst)
    {
        uint8_t opc = (uint8_t)bits(machInst, 18, 14);
        uint8_t opc2 = (uint8_t)bits(machInst, 11, 10);
        RegIndex Zn = (RegIndex)(uint32_t)(bits(machInst, 9, 5));
        RegIndex Zd = (RegIndex)(uint32_t)(bits(machInst, 4, 0));
        uint8_t size = (uint8_t)bits(machInst, 13, 12);

        if (opc2 != 0x0) {
            return new Unknown64(machInst);
        }

        if (bits(opc, 4) == 1) {  // opc=1xxxx
            uint8_t i4 = (uint8_t)(bits(machInst, 17, 14));
            switch (size) {
              case 0x0:
                return new SmeLuti21Reg<uint8_t>(machInst, Zd, Zn, i4);
              case 0x1:
                return new SmeLuti21Reg<uint16_t>(machInst, Zd, Zn, i4);
              case 0x2:
                return new SmeLuti21Reg<uint32_t>(machInst, Zd, Zn, i4);
            }
        } else if (bits(opc, 3) == 1) { // opc=01xxx
            uint8_t i3 = (uint8_t)(bits(machInst, 16, 14));
            switch (size) {
              case 0x0:
                return new SmeLuti41Reg<uint8_t>(machInst, Zd, Zn, i3);
              case 0x1:
                return new SmeLuti41Reg<uint16_t>(machInst, Zd, Zn, i3);
              case 0x2:
                return new SmeLuti41Reg<uint32_t>(machInst, Zd, Zn, i3);
            }
        }
        return new Unknown64(machInst);
    }

    // C4.1.14 SME2 Expand Lookup Table (Contiguous)
    StaticInstPtr
    decodeSme2ExpandLookupTableContig(ExtMachInst machInst)
    {
        uint8_t op0 = bits(machInst, 22);
        uint8_t op1_op3 = (bits(machInst, 18, 14) << 2) |
                          bits(machInst, 1, 0);

        if (op0 == 1) {
            return decodeSme2Lut1Reg(machInst);
        } else if (op1_op3 == 0x30) { // op0=0 op1=01100 op3=00
            uint8_t op2 = bits(machInst, 5);
            if (op2 == 0) { // op0=0 op1=01100 op2=0 op3=00
                return decodeSme2Lut2SrcsTo4DestContig(machInst);
            }
        } else if (bits(op1_op3, 3, 0) == 0x8) {  // op0=0 op1=xxx10 op3=00
            return decodeSme2Lut4RegsContig(machInst);
        } else if (bits(op1_op3, 2) == 1 && bits(op1_op3, 0) == 0) {
            // op0=0 op1=xxxx1 op3=x0
            return decodeSme2Lut2RegsContig(machInst);
        }
        return new Unknown64(machInst);
    }

    // C4.1.15.1 SME move vector to array
    StaticInstPtr
    decodeSmeMoveVecToArray(ExtMachInst machInst)
    {
        uint8_t size_Q = ((uint8_t)bits(machInst, 23, 22) << 1) |
                            (uint8_t)bits(machInst, 16);
        RegIndex Zn = (RegIndex)(uint32_t)(bits(machInst, 9, 5));
        RegIndex Ws = (RegIndex)(uint32_t)(bits(machInst, 14, 13) + 12);
        RegIndex Pg = (RegIndex)(uint32_t)(bits(machInst, 12, 10));
        RegIndex ZAd_imm = (RegIndex)(uint32_t)(bits(machInst, 3, 0));
        bool V = (bool)bits(machInst, 15);

        switch (size_Q) {
          case 0x0: // size=00 Q=0
            return new SmeMovaInsert<uint8_t>(
                    machInst, ZAd_imm / 16, ZAd_imm % 16, Zn, Pg, Ws, V);
          case 0x2: // size=01 Q=0
            return new SmeMovaInsert<uint16_t>(
                    machInst, ZAd_imm / 8, ZAd_imm % 8, Zn, Pg, Ws, V);
          case 0x4: // size=10 Q=0
            return new SmeMovaInsert<uint32_t>(
                    machInst, ZAd_imm / 4, ZAd_imm % 4, Zn, Pg, Ws, V);
          case 0x6: // size=11 Q=0
            return new SmeMovaInsert<uint64_t>(
                    machInst, ZAd_imm / 2, ZAd_imm % 2, Zn, Pg, Ws, V);
          case 0x7: // size=11 Q=1
            return new SmeMovaInsert<__uint128_t>(
                    machInst, ZAd_imm / 1, ZAd_imm % 1, Zn, Pg, Ws, V);
        }
        return new Unknown64(machInst);
    }

    // C4.1.15.2 SME2 move vector to tile, two registers
    StaticInstPtr
    decodeSmeMoveVecToTile2Regs(ExtMachInst machInst)
    {
        uint8_t size = (uint8_t)bits(machInst, 23, 22);
        RegIndex Zn = (RegIndex)(uint32_t)(bits(machInst, 9, 6) << 1);
        RegIndex Ws = (RegIndex)(uint32_t)(bits(machInst, 14, 13) + 12);
        RegIndex ZAd_imm = (RegIndex)(uint32_t)(bits(machInst, 2, 0));
        bool V = (bool)bits(machInst, 15);

        switch (size) {
          case 0x0: // size=00
            return new SmeMovaInsert2Reg<uint8_t>(machInst,
                    ZAd_imm / 8, Ws, (ZAd_imm % 8) << 1, Zn, Zn+1, V);
          case 0x1: // size=01
            return new SmeMovaInsert2Reg<uint16_t>(machInst,
                    ZAd_imm / 4, Ws, (ZAd_imm % 4) << 1, Zn, Zn+1, V);
          case 0x2: // size=10
            return new SmeMovaInsert2Reg<uint32_t>(machInst,
                    ZAd_imm / 2, Ws, (ZAd_imm % 2) << 1, Zn, Zn+1, V);
          case 0x3: // size=11
            return new SmeMovaInsert2Reg<uint64_t>(machInst,
                    ZAd_imm / 1, Ws, (ZAd_imm % 1) << 1, Zn, Zn+1, V);
        }
        return new Unknown64(machInst);
    }

    // C4.1.15.3 SME2 move vector to tile, four registers
    StaticInstPtr
    decodeSmeMoveVecToTile4Regs(ExtMachInst machInst)
    {
        uint8_t size = (uint8_t)bits(machInst, 23, 22);
        RegIndex Zn = (RegIndex)(uint32_t)(bits(machInst, 9, 7) << 2);
        RegIndex Ws = (RegIndex)(uint32_t)(bits(machInst, 14, 13) + 12);
        RegIndex ZAd_imm = (RegIndex)(uint32_t)(bits(machInst, 2, 0));
        bool V = (bool)bits(machInst, 15);

        switch (size) {
          case 0x0: // size=00
            return new SmeMovaInsert4Reg<uint8_t>(machInst,
                    0, Ws, (uint8_t)bits(ZAd_imm, 1, 0) << 2,
                    Zn, Zn+1, Zn+2, Zn+3, V);
          case 0x1: // size=01
            return new SmeMovaInsert4Reg<uint16_t>(machInst,
                    (uint8_t)bits(ZAd_imm, 1), Ws,
                    (uint8_t)bits(ZAd_imm, 0) << 2, Zn, Zn+1, Zn+2, Zn+3, V);
          case 0x2: // size=10
            return new SmeMovaInsert4Reg<uint32_t>(machInst,
                    (uint8_t)bits(ZAd_imm, 1, 0), Ws, 0,
                    Zn, Zn+1, Zn+2, Zn+3, V);
          case 0x3: // size=11
            return new SmeMovaInsert4Reg<uint64_t>(machInst,
                    ZAd_imm, Ws, 0, Zn, Zn+1, Zn+2, Zn+3, V);
        }
        return new Unknown64(machInst);
    }

    // C4.1.15 SME Move into Array
    StaticInstPtr
    decodeSmeMoveIntoArray(ExtMachInst machInst)
    {
        uint8_t op1 = (uint8_t)bits(machInst, 18);
        if (op1 == 0x0) {
            return decodeSmeMoveVecToArray(machInst);
        } else {
            uint8_t op0 = (uint8_t)bits(machInst, 23, 22);
            uint8_t op2 = (uint8_t)bits(machInst, 16, 15);
            uint8_t op3 = (uint8_t)bits(machInst, 12, 10);
            uint8_t op4 = (uint8_t)bits(machInst, 6, 5);
            uint8_t op5 = (uint8_t)bits(machInst, 3);

            switch (op3) {
              case 0x0: // op3=000
                if (bits(op2, 1) == 0 && bits(op4, 0) == 0 && op5 == 0) {
                    // op=1 op2=0x op3=000 op4=x0 op5=0
                    return decodeSmeMoveVecToTile2Regs(machInst);
                }
                break;
              case 0x1: // op3=001
                if (bits(op2, 1) == 0 && op4 == 0x0 && op5 == 0) {
                    // op=1 op2=0x op3=001 op4=00 op5=0
                    return decodeSmeMoveVecToTile4Regs(machInst);
                }
                break;
              case 0x2: // op3=010
                if (op0 == 0x0 && op2 == 0x0 && bits(op4, 0) == 0 &&
                        op5 == 0) {
                    // op0=00 op1==1 op2==00 op3=010 op4=x0 op5=0
                    // MOVA (vector to array, two registers)
                    RegIndex Zn = (RegIndex)(bits(machInst, 9, 6) << 1);
                    RegIndex Rv = (RegIndex)(0b1000 +
                        (uint8_t)bits(machInst, 14, 13));
                    uint8_t off3 = (uint8_t)bits(machInst, 2, 0);

                    return new SmeMovaArrayInsert2Reg<uint64_t>(
                        machInst, Rv, off3, Zn, Zn+1);
                }
                break;
              case 0x3: // op3=011
                if (op0 == 0x0 && op2 == 0x0 && op4 == 0x0 && op5 == 0) {
                    // op0=00 op1==1 op2==00 op3=011 op4=00 op5=0
                    // MOVA (vector to array, four registers)
                    RegIndex Zn = (RegIndex)(bits(machInst, 9, 7) << 2);
                    RegIndex Rv = (RegIndex)(0b1000 +
                        (uint8_t)bits(machInst, 14, 13));
                    uint8_t off3 = (uint8_t)bits(machInst, 2, 0);

                    return new SmeMovaArrayInsert4Reg<uint64_t>(
                        machInst, Rv, off3, Zn, Zn+1, Zn+2, Zn+3);
                }
                break;
            }
        }
        return new Unknown64(machInst);
    }

    // C4.1.16.1 SME zeroing move array to vector
    StaticInstPtr
    decodeSmeZeroMoveArrayToVec(ExtMachInst machInst)
    {
        uint8_t size_Q = ((uint8_t)bits(machInst, 23, 22) << 1) |
                            (uint8_t)bits(machInst, 16);
        RegIndex Zd = (RegIndex)(uint32_t)(bits(machInst, 4, 0));
        RegIndex Ws = (RegIndex)(uint32_t)(bits(machInst, 14, 13) + 12);
        RegIndex ZAn_imm = (RegIndex)(uint32_t)(bits(machInst, 8, 5));
        bool V = (bool)bits(machInst, 15);

        switch (size_Q) {
          case 0x0: // size=00 Q=0
            return new SmeMovazExtract<uint8_t>(
                    machInst, ZAn_imm / 16, Ws, ZAn_imm % 16, Zd, V);
          case 0x2: // size=01 Q=0
            return new SmeMovazExtract<uint16_t>(
                    machInst, ZAn_imm / 8, Ws, ZAn_imm % 8, Zd, V);
          case 0x4: // size=10 Q=0
            return new SmeMovazExtract<uint32_t>(
                    machInst, ZAn_imm / 4, Ws, ZAn_imm % 4, Zd, V);
          case 0x6: // size=11 Q=0
            return new SmeMovazExtract<uint64_t>(
                    machInst, ZAn_imm / 2, Ws, ZAn_imm % 2, Zd, V);
          case 0x7: // size=11 Q=1
           return new SmeMovazExtract<__uint128_t>(
                    machInst, ZAn_imm / 1, Ws, ZAn_imm % 1, Zd, V);
        }
        return new Unknown64(machInst);
    }

    // C4.1.16.2 SME move array to vector
    StaticInstPtr
    decodeSmeMoveArrayToVec(ExtMachInst machInst)
    {
        uint8_t size_Q = ((uint8_t)bits(machInst, 23, 22) << 1) |
                            (uint8_t)bits(machInst, 16);
        RegIndex Zd = (RegIndex)(uint32_t)(bits(machInst, 4, 0));
        RegIndex Ws = (RegIndex)(uint32_t)(bits(machInst, 14, 13) + 12);
        RegIndex Pg = (RegIndex)(uint32_t)(bits(machInst, 12, 10));
        RegIndex ZAn_imm = (RegIndex)(uint32_t)(bits(machInst, 8, 5));
        bool V = (bool)bits(machInst, 15);

        switch (size_Q) {
          case 0x0: // size=00 Q=0
            return new SmeMovaExtract<uint8_t>(
                    machInst, Zd, ZAn_imm / 16, ZAn_imm % 16, Pg, Ws, V);
          case 0x2: // size=01 Q=0
            return new SmeMovaExtract<uint16_t>(
                    machInst, Zd, ZAn_imm / 8, ZAn_imm % 8, Pg, Ws, V);
          case 0x4: // size=10 Q=0
            return new SmeMovaExtract<uint32_t>(
                    machInst, Zd, ZAn_imm / 4, ZAn_imm % 4, Pg, Ws, V);
          case 0x6: // size=11 Q=0
            return new SmeMovaExtract<uint64_t>(
                    machInst, Zd, ZAn_imm / 2, ZAn_imm % 2, Pg, Ws, V);
          case 0x7: // size=11 Q=1
           return new SmeMovaExtract<__uint128_t>(
                    machInst, Zd, ZAn_imm / 1, ZAn_imm % 1, Pg, Ws, V);
        }
        return new Unknown64(machInst);
    }

    // C4.1.16.3 SME2 move tile to vector, two registers
    StaticInstPtr
    decodeSmeMoveTileToVec2Regs(ExtMachInst machInst)
    {
        uint8_t size = (uint8_t)bits(machInst, 23, 22);
        RegIndex Zd = (RegIndex)(uint32_t)(bits(machInst, 4, 1) << 1);
        RegIndex Ws = (RegIndex)(uint32_t)(bits(machInst, 14, 13) + 12);
        RegIndex ZAn_imm = (RegIndex)(uint32_t)(bits(machInst, 7, 5));
        bool V = (bool)bits(machInst, 15);

        switch (size) {
          case 0x0: // size=00
            return new SmeMovaExtract2Reg<uint8_t>(machInst,
                    ZAn_imm / 8, Ws, (ZAn_imm % 8) << 1, Zd, Zd+1, V);
          case 0x1: // size=01
            return new SmeMovaExtract2Reg<uint16_t>(machInst,
                    ZAn_imm / 4, Ws, (ZAn_imm % 4) << 1, Zd, Zd+1, V);
          case 0x2: // size=10
            return new SmeMovaExtract2Reg<uint32_t>(machInst,
                    ZAn_imm / 2, Ws, (ZAn_imm % 2) << 1, Zd, Zd+1, V);
          case 0x3: // size=11
            return new SmeMovaExtract2Reg<uint64_t>(machInst,
                    ZAn_imm / 1, Ws, (ZAn_imm % 1) << 1, Zd, Zd+1, V);
        }
        return new Unknown64(machInst);
    }

    // C4.1.16.4 SME2 zeroing move tile to vector, two registers
    StaticInstPtr
    decodeSmeZeroMoveTileToVec2Regs(ExtMachInst machInst)
    {
        uint8_t size = (uint8_t)bits(machInst, 23, 22);
        RegIndex Zd = (RegIndex)(uint32_t)(bits(machInst, 4, 1) << 1);
        RegIndex Ws = (RegIndex)(uint32_t)(bits(machInst, 14, 13) + 12);
        RegIndex ZAn_imm = (RegIndex)(uint32_t)(bits(machInst, 7, 5));
        bool V = (bool)bits(machInst, 15);

        switch (size) {
          case 0x0: // size=00
            return new SmeMovazExtract2Reg<uint8_t>(machInst,
                    ZAn_imm / 8, Ws, (ZAn_imm % 8) << 1, Zd, Zd+1, V);
          case 0x1: // size=01
            return new SmeMovazExtract2Reg<uint16_t>(machInst,
                    ZAn_imm / 4, Ws, (ZAn_imm % 4) << 1, Zd, Zd+1, V);
          case 0x2: // size=10
            return new SmeMovazExtract2Reg<uint32_t>(machInst,
                    ZAn_imm / 2, Ws, (ZAn_imm % 2) << 1, Zd, Zd+1, V);
          case 0x3: // size=11
            return new SmeMovazExtract2Reg<uint64_t>(machInst,
                    ZAn_imm / 1, Ws, (ZAn_imm % 1) << 1, Zd, Zd+1, V);
        }
        return new Unknown64(machInst);
    }

    // C4.1.16.5 SME2 move tile to vector, four registers
    StaticInstPtr
    decodeSmeMoveTileToVec4Regs(ExtMachInst machInst)
    {
        uint8_t size = (uint8_t)bits(machInst, 23, 22);
        RegIndex Zd = (RegIndex)(uint32_t)(bits(machInst, 4, 2) << 2);
        RegIndex Ws = (RegIndex)(uint32_t)(bits(machInst, 14, 13) + 12);
        RegIndex ZAn_imm = (RegIndex)(uint32_t)(bits(machInst, 7, 5));
        bool V = (bool)bits(machInst, 15);

        switch (size) {
          case 0x0: // size=00
            return new SmeMovaExtract4Reg<uint8_t>(machInst,
                    0, Ws, (uint8_t)bits(ZAn_imm, 1, 0) << 2,
                    Zd, Zd+1, Zd+2, Zd+3, V);
          case 0x1: // size=01
            return new SmeMovaExtract4Reg<uint16_t>(machInst,
                    (uint8_t)bits(ZAn_imm, 1), Ws,
                    (uint8_t)bits(ZAn_imm, 0) << 2, Zd, Zd+1, Zd+2, Zd+3, V);
          case 0x2: // size=10
            return new SmeMovaExtract4Reg<uint32_t>(machInst,
                    (uint8_t)bits(ZAn_imm, 1, 0), Ws, 0,
                    Zd, Zd+1, Zd+2, Zd+3, V);
          case 0x3: // size=11
            return new SmeMovaExtract4Reg<uint64_t>(machInst,
                    ZAn_imm, Ws, 0, Zd, Zd+1, Zd+2, Zd+3, V);
        }
        return new Unknown64(machInst);
    }

    // C4.1.16.6 SME2 zeroing move tile to vector, four registers
    StaticInstPtr
    decodeSmeZeroMoveTileToVec4Regs(ExtMachInst machInst)
    {
        uint8_t size = (uint8_t)bits(machInst, 23, 22);
        RegIndex Zd = (RegIndex)(uint32_t)(bits(machInst, 4, 2) << 2);
        RegIndex Ws = (RegIndex)(uint32_t)(bits(machInst, 14, 13) + 12);
        RegIndex ZAn_imm = (RegIndex)(uint32_t)(bits(machInst, 7, 5));
        bool V = (bool)bits(machInst, 15);

        switch (size) {
          case 0x0: // size=00
            return new SmeMovazExtract4Reg<uint8_t>(machInst,
                    0, Ws, (uint8_t)bits(ZAn_imm, 1, 0) << 2,
                    Zd, Zd+1, Zd+2, Zd+3, V);
          case 0x1: // size=01
            return new SmeMovazExtract4Reg<uint16_t>(machInst,
                    (uint8_t)bits(ZAn_imm, 1), Ws,
                    (uint8_t)bits(ZAn_imm, 0) << 2, Zd, Zd+1, Zd+2, Zd+3, V);
          case 0x2: // size=10
            return new SmeMovazExtract4Reg<uint32_t>(machInst,
                    (uint8_t)bits(ZAn_imm, 1, 0), Ws, 0,
                    Zd, Zd+1, Zd+2, Zd+3, V);
          case 0x3: // size=11
            return new SmeMovazExtract4Reg<uint64_t>(machInst,
                    ZAn_imm, Ws, 0, Zd, Zd+1, Zd+2, Zd+3, V);
        }
        return new Unknown64(machInst);
    }

    // C4.1.16 SME Move from Array
    StaticInstPtr
    decodeSmeMoveFromArray(ExtMachInst machInst)
    {
        uint8_t op1 = (uint8_t)bits(machInst, 18);
        uint8_t op4 = (uint8_t)bits(machInst, 9, 8);
        if (op1 == 0x0) {
            uint8_t op3 = (uint8_t)bits(machInst, 12, 10);
            uint8_t op4 = (uint8_t)bits(machInst, 9, 8);
            if (bits(op4, 1) == 0) {  // op1=0 op4=0x
                return decodeSmeMoveArrayToVec(machInst);
            } else if (op3 == 0x0) {  // op1=0 op3=000 op4=1x
                return decodeSmeZeroMoveArrayToVec(machInst);
            }
        } else if (op4 == 0x0) {  // op1=1 op4=00
            uint8_t op0 = (uint8_t)bits(machInst, 23, 22);
            uint8_t op2 = (uint8_t)bits(machInst, 16, 15);
            uint8_t op3 = (uint8_t)bits(machInst, 12, 10);
            uint8_t op5 = (uint8_t)bits(machInst, 1, 0);

            switch (op3) {
              case 0x0: // op3=000
                if (bits(op2, 1) == 0 && bits(op5, 0) == 0) {
                    // op=1 op2=0x op3=000 op4=00 op5=x0
                    return decodeSmeMoveTileToVec2Regs(machInst);
                }
                break;
              case 0x1: // op3=001
                if (bits(op2, 1) == 0 && op5 == 0x0) {
                    // op=1 op2=0x op3=001 op4=00 op5=00
                    return decodeSmeMoveTileToVec4Regs(machInst);
                }
                break;
              case 0x2: // op3=010
                if (op0 == 0x0 && op2 == 0x0 && bits(op5, 0) == 0) {
                    // op0=00 op1=1 op2=00 op3=010 op4=00 op5=x0
                    // MOVA (array to vector, two registers)
                    RegIndex Zd = (RegIndex)(bits(machInst, 4, 1) << 1);
                    RegIndex Rv = (RegIndex)(0b1000 +
                        (uint8_t)bits(machInst, 14, 13));
                    uint8_t off3 = (uint8_t)bits(machInst, 7, 5);

                    return new SmeMovaArrayExtract2Reg<uint64_t>(
                        machInst, Rv, off3, Zd, Zd+1);
                }
                break;
              case 0x3: // op3=011
                if (op0 == 0x0 && op2 == 0x0 && op5 == 0x0) {
                    // op0=00 op1=1 op2=00 op3=011 op4=00 op5=00
                    // MOVA (array to vector, four registers)
                    RegIndex Zd = (RegIndex)(bits(machInst, 4, 2) << 2);
                    RegIndex Rv = (RegIndex)(0b1000 +
                        (uint8_t)bits(machInst, 14, 13));
                    uint8_t off3 = (uint8_t)bits(machInst, 7, 5);

                    return new SmeMovaArrayExtract4Reg<uint64_t>(
                        machInst, Rv, off3, Zd, Zd+1, Zd+2, Zd+3);
                }
                break;
            }
        } else if (op4 == 0x2) {  // op1=1 op4=10
            uint8_t op0 = (uint8_t)bits(machInst, 23, 22);
            uint8_t op2 = (uint8_t)bits(machInst, 16, 15);
            uint8_t op3 = (uint8_t)bits(machInst, 12, 10);
            uint8_t op5 = (uint8_t)bits(machInst, 1, 0);

            switch (op3) {
              case 0x0: // op3=000
                if (bits(op2, 1) == 0 && bits(op5, 0) == 0) {
                    // op=1 op2=0x op3=000 op4=10 op5=x0
                    return decodeSmeZeroMoveTileToVec2Regs(machInst);
                }
                break;
              case 0x1: // op3=001
                if (bits(op2, 1) == 0 && op5 == 0x0) {
                    // op=1 op2=0x op3=001 op4=10 op5=00
                    return decodeSmeZeroMoveTileToVec4Regs(machInst);
                }
                break;
              case 0x2: // op3=010
                if (op0 == 0x0 && op2 == 0x0 && bits(op5, 0) == 0) {
                    // op0=00 op1=1 op2=00 op3=010 op4=10 op5=x0
                    // MOVAZ (array to vector, two registers)
                    RegIndex Zd = (RegIndex)(bits(machInst, 4, 1) << 1);
                    RegIndex Rv = (RegIndex)(0b1000 +
                        (uint8_t)bits(machInst, 14, 13));
                    uint8_t off3 = (uint8_t)bits(machInst, 7, 5);

                    return new SmeMovazArrayExtract2Reg<uint64_t>(
                        machInst, Rv, off3, Zd, Zd+1);
                }
                break;
              case 0x3: // op3=011
                if (op0 == 0x0 && op2 == 0x0 && op5 == 0x0) {
                    // op0=00 op1=1 op2=00 op3=011 op4=10 op5=00
                    // MOVAZ (array to vector, four registers)
                    RegIndex Zd = (RegIndex)(bits(machInst, 4, 2) << 2);
                    RegIndex Rv = (RegIndex)(0b1000 +
                        (uint8_t)bits(machInst, 14, 13));
                    uint8_t off3 = (uint8_t)bits(machInst, 7, 5);

                    return new SmeMovazArrayExtract4Reg<uint64_t>(
                        machInst, Rv, off3, Zd, Zd+1, Zd+2, Zd+3);
                }
                break;
            }
        }
        return new Unknown64(machInst);
    }

    // C4.1.17.1 SME add vector to array
    StaticInstPtr
    decodeSmeAddVecToArraySub(ExtMachInst machInst)
    {
        uint8_t op_v = ((uint8_t)bits(machInst, 22) << 1) |
                        (uint8_t)bits(machInst, 16);
        uint8_t opc2 = (uint8_t)bits(machInst, 2, 0);
        RegIndex Zn = (RegIndex)(uint32_t)(bits(machInst, 9, 5));
        RegIndex Pn = (RegIndex)(uint32_t)(bits(machInst, 12, 10));
        RegIndex Pm = (RegIndex)(uint32_t)(bits(machInst, 15, 13));
        RegIndex ZAda = (RegIndex)(uint32_t)(bits(machInst, 2, 0));

        switch (op_v) {
          case 0x0: // op=0 V=0
            if (bits(opc2, 2) == 0x0) {
                return new SmeAddhaI32<int32_t>(machInst, ZAda, Zn, Pn, Pm);
            }
            break;
          case 0x1: // op=0 V=1
            if (bits(opc2, 2) == 0x0) {
                return new SmeAddvaI32<int32_t>(machInst, ZAda, Zn, Pn, Pm);
            }
            break;
          case 0x2: // op=1 V=0
            return new SmeAddhaI64<int64_t>(machInst, ZAda, Zn, Pn, Pm);
          case 0x3: // op=1 V=1
            return new SmeAddvaI64<int64_t>(machInst, ZAda, Zn, Pn, Pm);
        }
        return new Unknown64(machInst);
    }

    // C4.1.17 SME Add Vector to Array
    StaticInstPtr
    decodeSmeAddVecToArray(ExtMachInst machInst)
    {
        uint32_t op0 = (uint32_t)bits(machInst, 23);
        uint32_t op1 = (uint32_t)bits(machInst, 18, 17);
        uint32_t op2 = (uint32_t)bits(machInst, 4);

        if (op0 == 0x1 && op1 == 0x0 && op2 == 0x0) {   // op0=1 op1=00 op2=0
            return decodeSmeAddVecToArraySub(machInst);
        }
        return new Unknown64(machInst);
    }

    // C4.1.18.1 SME2 single-multi long FMA two sources
    StaticInstPtr
    decodeSme2SingleMultiLongFma2Srcs(ExtMachInst machInst)
    {
        uint8_t op_S_o2 = (uint8_t)bits(machInst, 4, 2);
        RegIndex Zn1 = (RegIndex)(uint32_t)(bits(machInst, 9, 5));
        RegIndex Zn2 = (RegIndex)(uint32_t)((Zn1 + 1) % 32);
        RegIndex Zm = (RegIndex)(uint32_t)(bits(machInst, 19, 16));
        RegIndex Rv = (RegIndex)(0b1000 + (uint32_t)bits(machInst, 14, 13));
        uint8_t off2 = (uint8_t)bits(machInst, 1, 0) << 1;

        switch (op_S_o2) {
          case 0x0: // op=0 S=0 o2=0
            return new SmeFmlalMSgl2Reg<uint16_t, uint16_t, uint32_t>(
                machInst, Rv, off2, Zn1, Zn2, Zm);
          case 0x1: // op=0 S=0 o2=1
            // FMLAL (multiple and single vector, FP8 to FP16)
            return new Unknown64(machInst);
          case 0x2: // op=0 S=1 o2=0
            return new SmeFmlslMSgl2Reg<uint16_t, uint16_t, uint32_t>(
                machInst, Rv, off2, Zn1, Zn2, Zm);
          case 0x4: // op=1 S=0 o2=0
            return new SmeBfmlalMSgl2Reg<uint16_t, uint16_t, uint32_t>(
                machInst, Rv, off2, Zn1, Zn2, Zm);
          case 0x6: // op=1 S=1 o2=0
            return new SmeBfmlslMSgl2Reg<uint16_t, uint16_t, uint32_t>(
                machInst, Rv, off2, Zn1, Zn2, Zm);
        }
        return new Unknown64(machInst);
    }

    // C4.1.18.2 SME2 multiple and single vector long FMA one source
    StaticInstPtr
    decodeSme2SingleMultiLongFma1Src(ExtMachInst machInst)
    {
        uint8_t op_S = (uint8_t)bits(machInst, 4, 3);
        RegIndex Zn = (RegIndex)(uint32_t)(bits(machInst, 9, 5));
        RegIndex Zm = (RegIndex)(uint32_t)(bits(machInst, 19, 16));
        RegIndex Rv = (RegIndex)(0b1000 + (uint32_t)bits(machInst, 14, 13));
        uint8_t off3 = (uint8_t)bits(machInst, 2, 0) << 1;

        switch (op_S) {
          case 0x0: // op=0 S=0
            return new SmeFmlalMSgl1Reg<uint16_t, uint16_t, uint32_t>(
                machInst, Rv, off3, Zn, Zm);
          case 0x1: // op=0 S=1
            return new SmeFmlslMSgl1Reg<uint16_t, uint16_t, uint32_t>(
                machInst, Rv, off3, Zn, Zm);
          case 0x2: // op=1 S=0
            return new SmeBfmlalMSgl1Reg<uint16_t, uint16_t, uint32_t>(
                machInst, Rv, off3, Zn, Zm);
          case 0x3: // op=1 S=1
            return new SmeBfmlslMSgl1Reg<uint16_t, uint16_t, uint32_t>(
                machInst, Rv, off3, Zn, Zm);
        }
        return new Unknown64(machInst);
    }

    // C4.1.18.3 SME2 single-multi FP dot product two registers
    StaticInstPtr
    decodeSme2SingleMultiFpDotProd2Regs(ExtMachInst machInst)
    {
        uint8_t opc = (uint8_t)bits(machInst, 4, 3);
        RegIndex Zn1 = (RegIndex)(uint32_t)(bits(machInst, 9, 5));
        RegIndex Zn2 = (RegIndex)(uint32_t)((Zn1 + 1) % 32);
        RegIndex Zm = (RegIndex)(uint32_t)(bits(machInst, 19, 16));
        RegIndex Rv = (RegIndex)(0b1000 + (uint32_t)bits(machInst, 14, 13));
        uint8_t off3 = (uint8_t)bits(machInst, 2, 0);

        switch (opc) {
          case 0x0: // opc=00
            return new SmeFdotHpSpMSgl2Reg<uint16_t, uint16_t, uint32_t>(
                machInst, Rv, off3, Zn1, Zn2, Zm);
          case 0x1: // opc=01
            // FDOT (2-way, multiple and single vector, FP8 to FP16)
            return new Unknown64(machInst);
          case 0x2: // opc=10
            return new SmeBfdotMSgl2Reg<uint16_t, uint16_t, uint32_t>(
                machInst, Rv, off3, Zn1, Zn2, Zm);
          case 0x3: // opc=11
            // FDOT (4-way, multiple and single vector)
