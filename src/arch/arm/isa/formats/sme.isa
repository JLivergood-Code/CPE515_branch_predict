    // C4.1.24.7 SME2 multi-vec indexed long MLA four sources
    StaticInstPtr
    decodeSme2MultiVecIdxLongMla4Srcs(ExtMachInst machInst)
    {
        uint8_t U_S = (uint8_t)bits(machInst, 4, 3);
        RegIndex Zn = (RegIndex)(uint32_t)(bits(machInst, 9, 7) << 2);
        RegIndex Zm = (RegIndex)(uint32_t)(bits(machInst, 19, 16));
        RegIndex Rv = (RegIndex)(0b1000 + (uint32_t)bits(machInst, 14, 13));
        uint8_t off2 = (uint8_t)bits(machInst, 1, 0) << 1;
        uint8_t i3 = ((uint8_t)bits(machInst, 11, 10) << 1) |
                        (uint8_t)bits(machInst, 2);

        switch (U_S) {
          case 0x0: // U=0 S=0
            return new SmeSmlalMIdx4Reg<int16_t, int16_t, int32_t>(
                machInst, Rv, off2, Zn, Zn+1, Zn+2, Zn+3, Zm, i3);
          case 0x1: // U=0 S=1
            return new SmeSmlslMIdx4Reg<int16_t, int16_t, int32_t>(
                machInst, Rv, off2, Zn, Zn+1, Zn+2, Zn+3, Zm, i3);
          case 0x2: // U=1 S=0
            return new SmeUmlalMIdx4Reg<uint16_t, uint16_t, uint32_t>(
                machInst, Rv, off2, Zn, Zn+1, Zn+2, Zn+3, Zm, i3);
          case 0x3: // U=1 S=1
            return new SmeUmlslMIdx4Reg<uint16_t, uint16_t, uint32_t>(
                machInst, Rv, off2, Zn, Zn+1, Zn+2, Zn+3, Zm, i3);
        }
        return new Unknown64(machInst);
    }

    // C4.1.24 SME2 Multi-vector - Indexed (Four registers)
    StaticInstPtr
    decodeSme2MVMultiVecIndexedFourRegs(ExtMachInst machInst)
    {
        uint8_t op0 = (uint32_t)bits(machInst, 23, 22);
        uint8_t op1 = (uint32_t)bits(machInst, 12, 11);
        uint8_t op2 = (uint32_t)bits(machInst, 6, 4);
        uint8_t op3 = (uint32_t)bits(machInst, 3);

        switch (op0) {
          case 0x0: // op0=00
            if (bits(op2, 2) == 0) {    // op0=00 op2=0xx
                if (bits(op1, 1) == 0) {
                    // op0=00 op1=0x op2=0xx
                    return decodeSme2MultiVecIdxLongLongMla4Srcs32(machInst);
                } else {
                    // op0=00 op1=1x op2=0xx
                    return decodeSme2MultiVecTerIdx4Regs16(machInst);
                }
            } else if (op2 == 100) {    // op0=00 op2=100
                if (bits(op1, 1) == 0 && op3 == 0) {
                    // op0=00 op1=0x op2=100 op3=0
                    // FMLALL (multiple and indexed vector) —
                    // Four ZA quad-vectors
                    return new Unknown64(machInst);
                } if (bits(op1, 1) == 1) {
                    // op0=00 op1=0x op2=100 op3=0
                    // FDOT (2-way, multiple and indexed vector, FP8 to FP16) —
                    // Four ZA single-vectors
                    return new Unknown64(machInst);
                }
            }
            break;
          case 0x1: // op0=01
            if (bits(op2, 2) == 0) {    // op0=00 op2=0xx
                // op0=01 op2=0xx
                // SME2 multi-vec ternary indexed four registers 32-bit
                return decodeSme2MultiVecTerIdx4Regs32(machInst);
            }
            break;
          case 0x2: // op0=10
            if (bits(op2, 2, 1) == 0) {    // op0=10 op2=00x
                if (op1 == 00) {
                    // op0=10 op1=00 op2=00x
                    return decodeSme2MultiVecIdxLongLongMla4Srcs64(machInst);
                } else if (bits(op1, 1) == 1) {
                    // op0=10 op1=1x op2=00x
                    return decodeSme2MultiVecIdxLongFma4Srcs(machInst);
                }
            } else if (op2 == 0x2) {    // op0=10 op2=010
                if (bits(op1, 1) == 1) {
                    // op0=10 op1=1x op2=010
                    // FMLAL (multiple and indexed vector, FP8 to FP16) —
                    // Four ZA double-vectors
                    return new Unknown64(machInst);
                }
            }
            break;
          case 0x3: // op0=11
            if (bits(op2, 2, 1) == 0) {    // op0=11 op2=00x
                if (bits(op1, 1) == 0) {
                    // op0=11 op1=0x op2=00x
                    return decodeSme2MultiVecTerIdx4Regs64(machInst);
                } else {
                    // op0=11 op1=1x op2=00x
                    return decodeSme2MultiVecIdxLongMla4Srcs(machInst);
                }
            }
            break;
        }
        return new Unknown64(machInst);
    }

    // C4.1.25.1 SME2 single-multi int min/max two registers
    StaticInstPtr
    decodeSme2SingleMultiIntMinMax2Regs(ExtMachInst machInst)
    {
        uint8_t op_u = ((uint8_t)bits(machInst, 5) << 1) |
                        (uint8_t)bits(machInst, 0);
        RegIndex Zdn = (RegIndex)(bits(machInst, 4, 1) << 1);
        RegIndex Zm = (RegIndex)(bits(machInst, 19, 16));
        unsigned esize = bits(machInst, 23, 22);

        switch (op_u) {
          case 0x0: // op=0 U=0
            return decodeSme2MSDestrBinOp2RegsSign<SmeSmaxMSgl2Reg>(
                esize, machInst, Zdn, Zdn+1, Zm);
          case 0x1: // op=0 U=1
            return decodeSme2MSDestrBinOp2Regs<SmeUmaxMSgl2Reg>(
                esize, machInst, Zdn, Zdn+1, Zm);
          case 0x2: // op=1 U=0
            return decodeSme2MSDestrBinOp2RegsSign<SmeSminMSgl2Reg>(
                esize, machInst, Zdn, Zdn+1, Zm);
          case 0x3: // op=1 U=1
            return decodeSme2MSDestrBinOp2Regs<SmeUminMSgl2Reg>(
                esize, machInst, Zdn, Zdn+1, Zm);
        }
        return new Unknown64(machInst);
    }

    // C4.1.25.2 SME2 single-multi FP min/max two registers
    StaticInstPtr
    decodeSme2SingleMultiFpMinMax2Regs(ExtMachInst machInst)
    {
        uint8_t op_o2 = ((uint8_t)bits(machInst, 5) << 1) |
                        (uint8_t)bits(machInst, 0);
        RegIndex Zdn = (RegIndex)(bits(machInst, 4, 1) << 1);
        RegIndex Zm = (RegIndex)(bits(machInst, 19, 16));
        unsigned esize = bits(machInst, 23, 22);

        switch (op_o2) {
          case 0x0: // op=0 o2=0
            if (esize == 0) {
                return new SmeBfmaxMSgl2Reg<uint16_t>(
                    machInst, Zdn, Zdn+1, Zm);
            } else {
                return decodeSme2MSDestrFpBinOp2Regs<SmeFmaxMSgl2Reg>(
                    esize, machInst, Zdn, Zdn+1, Zm);
            }
          case 0x1: // op=0 o2=1
            if (esize == 0) {
                return new SmeBfminMSgl2Reg<uint16_t>(
                    machInst, Zdn, Zdn+1, Zm);
            } else {
                return decodeSme2MSDestrFpBinOp2Regs<SmeFminMSgl2Reg>(
                    esize, machInst, Zdn, Zdn+1, Zm);
            }
          case 0x2: // op=1 o2=0
            if (esize == 0) {
                return new SmeBfmaxnmMSgl2Reg<uint16_t>(
                    machInst, Zdn, Zdn+1, Zm);
            } else {
                return decodeSme2MSDestrFpBinOp2Regs<SmeFmaxnmMSgl2Reg>(
                    esize, machInst, Zdn, Zdn+1, Zm);
            }
          case 0x3: // op=1 o2=1
            if (esize == 0) {
                return new SmeBfminnmMSgl2Reg<uint16_t>(
                    machInst, Zdn, Zdn+1, Zm);
            } else {
                return decodeSme2MSDestrFpBinOp2Regs<SmeFminnmMSgl2Reg>(
                    esize, machInst, Zdn, Zdn+1, Zm);
            }
        }
        return new Unknown64(machInst);
    }

    // C4.1.25.3 SME2 multiple and single vector FSCALE two registers
    // C4.1.25.4 SME2 single-multi shift two registers
    StaticInstPtr
    decodeSme2SingleMultiShift2Regs(ExtMachInst machInst)
    {
        uint8_t opc_u = ((uint8_t)bits(machInst, 7, 5) << 1) |
