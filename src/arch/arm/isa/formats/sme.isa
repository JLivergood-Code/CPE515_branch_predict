    // C4.1.19.10 SME2 single-multi ternary FP16 four registers
    StaticInstPtr
    decodeSme2SingleMultiTerFp164Regs(ExtMachInst machInst)
    {
        uint8_t S = (uint8_t)bits(machInst, 3);
        RegIndex Zn1 = (RegIndex)(uint32_t)(bits(machInst, 9, 5));
        RegIndex Zn2 = (RegIndex)(uint32_t)((Zn1 + 1) % 32);
        RegIndex Zn3 = (RegIndex)(uint32_t)((Zn1 + 2) % 32);
        RegIndex Zn4 = (RegIndex)(uint32_t)((Zn1 + 3) % 32);
        RegIndex Zm = (RegIndex)(uint32_t)(bits(machInst, 19, 16));
        RegIndex Rv = (RegIndex)(0b1000 + (uint32_t)bits(machInst, 14, 13));
        uint8_t off3 = (uint8_t)bits(machInst, 2, 0);
        uint8_t sz = (uint8_t)bits(machInst, 22);

        switch (S) {
          case 0x0: // S=0
            if (sz) {
                return new SmeBfmlaMSgl4Reg<uint16_t, uint16_t, uint16_t>(
                    machInst, Rv, off3, Zn1, Zn2, Zn3, Zn4, Zm);
            } else {
                return new SmeFmlaHpMSgl4Reg<uint16_t, uint16_t, uint16_t>(
                    machInst, Rv, off3, Zn1, Zn2, Zn3, Zn4, Zm);
            }
          case 0x1: // S=1
            if (sz) {
                return new SmeBfmlsMSgl4Reg<uint16_t, uint16_t, uint16_t>(
                    machInst, Rv, off3, Zn1, Zn2, Zn3, Zn4, Zm);
            } else {
                return new SmeFmlsHpMSgl4Reg<uint16_t, uint16_t, uint16_t>(
                    machInst, Rv, off3, Zn1, Zn2, Zn3, Zn4, Zm);
            }
        }
        return new Unknown64(machInst);
    }

    // C4.1.19 SME2 Multi-vector - Multiple and Single Array Vectors
    // (Four registers)
    StaticInstPtr
    decodeSme2MVMultiAndSingleArrayVecFourRegs(ExtMachInst machInst)
    {
        uint8_t op0 = (uint8_t)bits(machInst, 22);
        uint8_t op1 = (uint8_t)bits(machInst, 12, 10);
        uint8_t op2 = (uint8_t)bits(machInst, 4, 2);
        uint8_t op3 = (uint8_t)bits(machInst, 1);

        switch (op1) {
          case 0x0:    // op1=000
            if (op0 == 0x0 && op2 == 0x0 && op3 == 0x1) {
                // op0=0 op1=000 op2=000 op3=1
                // FMLALL (multiple and single vector) — Four ZA quad-vectors
                return new Unknown64(machInst);
            } else if (op3 == 0x0) {
                // op1=000 op3=0
                return decodeSme2SingleMultiLongLongMla4Srcs(machInst);
            }
            break;
          case 0x1:    // op1=001
            if (op0 == 0x0 && op2 == 0x0) { // op0=0 op1=001 op2=000
                // FMLALL (multiple and single vector) — One ZA quad-vector
                return new Unknown64(machInst);
            }
            break;
          case 0x2:    // op1=010
            if (op0 == 0) {     // op0=0 op1=010
                return decodeSme2SingleMultiLongFma4Srcs(machInst);
            } else {            // op0=1 op1=010
                return decodeSme2SingleMultiLongMla4Srcs(machInst);
            }
            break;
          case 0x3:    // op1=011
            if (op0 == 0 && bits(op2, 2, 1) == 0x0) { // op0=0 op1=011 op2=00x
                // FMLAL (multiple and single vector, FP8 to FP16)
                // — One ZA double-vector
                return new Unknown64(machInst);
            }
            break;
          case 0x4:    // op1=100
            if (op0 == 0) {     // op0=0 op1=100
                return decodeSme2SingleMultiFpDotProd4Regs(machInst);
            }
            break;
          case 0x5:    // op1=101
            if (bits(op2, 1) == 1) {
                if (op0 == 0) { // op0=0 op1=101 op2=x1x
                    return decodeSme2SingleMultiMixDotProd4Regs(machInst);
                } else{         // op0=1 op1=101 op2=x1x
                    return decodeSme2SingleMultiTwoWayDotProd4Regs(machInst);
                }
            } else {            // op1=101 op2=x0x
                return decodeSme2SingleMultiFourWayDotProd4Regs(machInst);
            }
            break;
          case 0x6:     // op1=110
            if (bits(op2, 2) == 0) {    // op1=110 op2=0xx
                return decodeSme2SingleMultiTerFp4Regs(machInst);
            } else {                    // op1=110 op2=1xx
                return decodeSme2SingleMultiTerInt4Regs(machInst);
            }
            break;
          case 0x7:     // op1=111
            if (bits(op2, 2) == 0) {    // op1=111 op2=0xx
                return decodeSme2SingleMultiTerFp164Regs(machInst);
            }
            break;
        }
        return new Unknown64(machInst);
    }

    // C4.1.20.1 SME2 multiple vectors long FMA two sources
    StaticInstPtr
    decodeSme2MultiVecLongFma2Srcs(ExtMachInst machInst)
    {
        uint8_t op_S = (uint8_t)bits(machInst, 4, 3);
        RegIndex Zn = (RegIndex)(uint32_t)(bits(machInst, 9, 6) << 1);
        RegIndex Zm = (RegIndex)(uint32_t)(bits(machInst, 20, 17) << 1);
        RegIndex Rv = (RegIndex)(0b1000 + (uint32_t)bits(machInst, 14, 13));
        uint8_t off2 = (uint8_t)bits(machInst, 1, 0) << 1;

        switch (op_S) {
          case 0x0: // op=0 S=0
            return new SmeFmlalMVec2Reg<uint16_t, uint16_t, uint32_t>(
                machInst, Rv, off2, Zn, Zn+1, Zm, Zm+1);
          case 0x1: // op=0 S=1
            return new SmeFmlslMVec2Reg<uint16_t, uint16_t, uint32_t>(
                machInst, Rv, off2, Zn, Zn+1, Zm, Zm+1);
          case 0x2: // op=1 S=0
            return new SmeBfmlalMVec2Reg<uint16_t, uint16_t, uint32_t>(
                machInst, Rv, off2, Zn, Zn+1, Zm, Zm+1);
          case 0x3: // op=1 S=1
            return new SmeBfmlslMVec2Reg<uint16_t, uint16_t, uint32_t>(
                machInst, Rv, off2, Zn, Zn+1, Zm, Zm+1);
        }
        return new Unknown64(machInst);
    }

    // C4.1.20.2 SME2 multiple vectors FP dot product two registers
    StaticInstPtr
    decodeSme2MultiVecFpDotProd2Regs(ExtMachInst machInst)
    {
        uint8_t opc = (uint8_t)bits(machInst, 5, 4);
        RegIndex Zn = (RegIndex)(uint32_t)(bits(machInst, 9, 6) << 1);
        RegIndex Zm = (RegIndex)(uint32_t)(bits(machInst, 20, 17) << 1);
        RegIndex Rv = (RegIndex)(0b1000 + (uint32_t)bits(machInst, 14, 13));
        uint8_t off3 = (uint8_t)bits(machInst, 2, 0);

        switch (opc) {
          case 0x0:  // opc=00
            return new SmeFdotHpSpMVec2Reg<uint16_t, uint16_t, uint32_t>(
                machInst, Rv, off3, Zn, Zn+1, Zm, Zm+1);
          case 0x1:  // opc=01
            return new SmeBfdotMVec2Reg<uint16_t, uint16_t, uint32_t>(
                machInst, Rv, off3, Zn, Zn+1, Zm, Zm+1);
          case 0x2:  // opc=10
            // FDOT (2-way, multiple vectors, FP8 to FP16)
            return new Unknown64(machInst);
          case 0x3:  // opc=11
            // FDOT (4-way, multiple vectors)
            return new Unknown64(machInst);
        }
        return new Unknown64(machInst);
    }

