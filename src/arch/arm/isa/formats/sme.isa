                    machInst, Rv, off1, Zn1, Zn2, Zm);
            } else {
                return new SmeSmlallI8I32MSgl2Reg<int8_t, int8_t, int32_t>(
                    machInst, Rv, off1, Zn1, Zn2, Zm);
            }
