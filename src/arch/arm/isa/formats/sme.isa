    // C4.1.20 SME2 Multi-vector - Multiple Array Vectors (Two registers)
    StaticInstPtr
    decodeSme2MVMultiArrayTwoRegs(ExtMachInst machInst)
    {
        uint8_t op0 = (uint8_t)bits(machInst, 22);
        uint8_t op1_op2 = (uint8_t)bits(machInst, 20, 17);
        uint8_t op3_op4 = ((uint8_t)bits(machInst, 12, 10) << 1) |
                            (uint8_t)bits(machInst, 5);
        uint8_t op5 = (uint8_t)bits(machInst, 4, 2);
        uint8_t op6 = (uint8_t)bits(machInst, 1);

        switch (op3_op4) {
          case 0x0: // op3=000 op4=0
            if (op6 == 0) {
                // op3=000 op4=0 op6=0
                return decodeSme2MultiVecLongLongMla2Srcs(machInst);
            }
            break;
          case 0x1: // op3=000 op4=1
            if (op0 == 0 && op5 == 0 && op6 == 0) {
                // op0=0 op3=000 op4=1 op5=000 op6=0
                // FMLALL (multiple vectors) — Two ZA quad-vectors
                return new Unknown64(machInst);
            }
            break;
          case 0x4: // op3=010 op4=0
            if (op0 == 0 && bits(op5, 0) == 0) {
                // op0=0 op3=010 op4=0 op5=xx0
                return decodeSme2MultiVecLongFma2Srcs(machInst);
            } else if (op0 == 1 && bits(op5, 0) == 0) {
                // op0=1 op3=010 op4=0 op5=xx0
                return decodeSme2MultiVecLongMla2Srcs(machInst);
            }
            break;
          case 0x5: // op3=010 op4=1
            if (op0 == 0 && op5 == 0) {
                // op0=0 op3=010 op4=1 op5=000
                // FMLAL (multiple vectors, FP8 to FP16)
                // — Two ZA double-vectors
                return new Unknown64(machInst);
            }
            break;
          case 0x8:   // op3=100 op4=0
            if (op0 == 0 && bits(op5, 1) == 0) {
                // op0=0 op3=100 op4=0 op5=x0x
                return decodeSme2MultiVecFpDotProd2Regs(machInst);
            } else if (bits(op5, 1) == 1) {
                // op3=100 op4=0 op5=x1x
                return decodeSme2MultiVecTerFp162Regs(machInst);
            }
            break;
          case 0x9:   // op3=100 op4=1
            if (op0 == 0 && bits(op5, 1) == 0) {
                // op0=0 op3=100 op4=1 op5=x0x
                return decodeSme2MultiVecFpDotProd2Regs(machInst);
            }
            break;
          case 0xa: // op3=101 op4=0
            if (op0 == 0 && bits(op5, 2, 1) == 0x1) {
                // op0=0 op3=101 op4=0 op5=01x
                // USDOT (multiple vectors) — Two ZA single-vectors
                RegIndex Zn =
                    (RegIndex)(uint32_t)(bits(machInst, 9, 6) << 1);
                RegIndex Zm =
                    (RegIndex)(uint32_t)(bits(machInst, 20, 17) << 1);
                RegIndex Rv =
                    (RegIndex)(0b1000 + (uint32_t)bits(machInst, 14, 13));
                uint8_t off3 = (uint8_t)bits(machInst, 2, 0);

                return new SmeUsdotMVec2Reg<uint8_t, int8_t, int32_t>(
                    machInst, Rv, off3, Zn, Zn+1, Zm, Zm+1);
            } else if (op0 == 1 && bits(op5, 1) == 1) {
                // op0=1 op3=101 op4=0 op5=x1x
                return decodeSme2MultiVecTwoWayDotProd2Regs(machInst);
            } else if (bits(op5, 1) == 0) {
                // op3=101 op4=0 op5=x0x
                return decodeSme2MultiVecFourWayDotProd2Regs(machInst);
            }
            break;
          case 0xc: // op3=110 op4=0
            if (bits(op5, 2) == 0) {
                // op3=100 op4=0 op5=0xx
                return decodeSme2MultiVecTerFp2Regs(machInst);
            } else {
                // op3=100 op4=0 op5=1xx
                return decodeSme2MultiVecTerInt2Regs(machInst);
            }
            break;
          case 0xe: // op3=111 op4=0
            if (op1_op2 == 0x0 && bits(op5, 2) == 0) {
                // op1=00 op2=00 op3=111 op4=0 op5=0xx
                return decodeSme2MultiVecBinFp2Regs(machInst);
            } else if (op1_op2 == 0x0 && bits(op5, 2) == 1) {
                // op1=00 op2=00 op3=111 op4=0 op5=1xx
                return decodeSme2MultiVecBinInt2Regs(machInst);
            } else if (op1_op2 == 0x2 && bits(op5, 2) == 0) {
                // op1=00 op2=10 op3=111 op4=0 op5=0xx
                return decodeSme2MultiVecBinFp162Regs(machInst);
            }
            break;
        }
        return new Unknown64(machInst);
    }

    // C4.1.21.1 SME2 multiple vectors long FMA four sources
    StaticInstPtr
    decodeSme2MultiVecLongFma4Srcs(ExtMachInst machInst)
    {
        uint8_t op_S = (uint8_t)bits(machInst, 4, 3);
        RegIndex Zn = (RegIndex)(uint32_t)(bits(machInst, 9, 7) << 2);
        RegIndex Zm = (RegIndex)(uint32_t)(bits(machInst, 20, 18) << 2);
        RegIndex Rv = (RegIndex)(0b1000 + (uint32_t)bits(machInst, 14, 13));
        uint8_t off2 = (uint8_t)bits(machInst, 2, 0) << 1;

        switch (op_S) {
          case 0x0: // U=0 S=0
            return new SmeFmlalMVec4Reg<uint16_t, uint16_t, uint32_t>(
                machInst, Rv, off2, Zn, Zn+1, Zn+2, Zn+3,
                Zm, Zm+1, Zm+2, Zm+3);
          case 0x1: // U=0 S=1
            return new SmeFmlslMVec4Reg<uint16_t, uint16_t, uint32_t>(
                machInst, Rv, off2, Zn, Zn+1, Zn+2, Zn+3,
                Zm, Zm+1, Zm+2, Zm+3);
          case 0x2: // U=1 S=0
            return new SmeBfmlalMVec4Reg<uint16_t, uint16_t, uint32_t>(
                machInst, Rv, off2, Zn, Zn+1, Zn+2, Zn+3,
                Zm, Zm+1, Zm+2, Zm+3);
          case 0x3: // U=1 S=1
            return new SmeBfmlslMVec4Reg<uint16_t, uint16_t, uint32_t>(
                machInst, Rv, off2, Zn, Zn+1, Zn+2, Zn+3,
                Zm, Zm+1, Zm+2, Zm+3);
        }
        return new Unknown64(machInst);
    }

    // C4.1.21.2 SME2 multiple vectors FP dot product four registers
    StaticInstPtr
    decodeSme2MultiVecFpDotProd4Regs(ExtMachInst machInst)
    {
        uint8_t opc = (uint8_t)bits(machInst, 5, 4);
        RegIndex Zn = (RegIndex)(uint32_t)(bits(machInst, 9, 7) << 2);
        RegIndex Zm = (RegIndex)(uint32_t)(bits(machInst, 20, 18) << 2);
        RegIndex Rv = (RegIndex)(0b1000 + (uint32_t)bits(machInst, 14, 13));
        uint8_t off3 = (uint8_t)bits(machInst, 2, 0);

        switch (opc) {
          case 0x0:  // opc=00
            return new SmeFdotHpSpMVec4Reg<uint16_t, uint16_t, uint32_t>(
                machInst, Rv, off3, Zn, Zn+1, Zn+2, Zn+3,
                Zm, Zm+1, Zm+2, Zm+3);
          case 0x1:  // opc=01
            return new SmeBfdotMVec4Reg<uint16_t, uint16_t, uint32_t>(
                machInst, Rv, off3, Zn, Zn+1, Zn+2, Zn+3,
                Zm, Zm+1, Zm+2, Zm+3);
          case 0x2:  // opc=10
            // FDOT (2-way, multiple vectors, FP8 to FP16)
            return new Unknown64(machInst);
          case 0x3:  // opc=11
            // FDOT (4-way, multiple vectors)
            return new Unknown64(machInst);
        }
        return new Unknown64(machInst);
    }

