    // C4.1.21.4 SME2 multiple vectors two-way dot product four registers
    StaticInstPtr
    decodeSme2MultiVecTwoWayDotProd4Regs(ExtMachInst machInst)
    {
        uint8_t U = (uint8_t)bits(machInst, 4);
        RegIndex Zn = (RegIndex)(uint32_t)(bits(machInst, 9, 7) << 2);
        RegIndex Zm = (RegIndex)(uint32_t)(bits(machInst, 20, 18) << 2);
        RegIndex Rv = (RegIndex)(0b1000 + (uint32_t)bits(machInst, 14, 13));
        uint8_t off3 = (uint8_t)bits(machInst, 2, 0);

