    # URSHL (multiple and single vector)
    urshlBaseOp = '''
            auto shiftAmt =
                static_cast<std::make_signed_t<TPElem> >(srcElem2);
            if (shiftAmt < 0) {
                shiftAmt = -shiftAmt;
                TPElem rBit = 0;
                if (shiftAmt <= sizeof(TPElem) * 8)
                    rBit = bits(srcElem1, shiftAmt - 1);
                if (shiftAmt > sizeof(TPElem) * 8 && ltz(srcElem1))
                    rBit = 1;
                if (shiftAmt >= sizeof(TPElem) * 8) {
                    shiftAmt = sizeof(TPElem) * 8 - 1;
                    destElem = 0;
                } else {
                    destElem = (srcElem1 >> shiftAmt);
                }
                // Make sure the right shift sign extended when it should.
                if (ltz(srcElem1) && !ltz(destElem)) {
                    destElem |= -((TPElem)1 << (sizeof(TPElem) * 8 -
                                                 1 - shiftAmt));
                }
                destElem += rBit;
            } else if (shiftAmt > 0) {
                if (shiftAmt >= sizeof(TPElem) * 8) {
                    destElem = 0;
                } else {
                    destElem = srcElem1 << shiftAmt;
                }
            } else {
                destElem = srcElem1;
            }
    '''

    sme2DestrNx1Inst("urshl", "UrshlMSgl2Reg", "SimdShiftOp",
                     ['uint8_t', 'uint16_t', 'uint32_t', 'uint64_t'],
                     destrBinCode % {'op': urshlBaseOp}, 2)
