    # SMLAL (multiple and indexed vector)
    multiIdxIntMlalCode = '''
        for (int i = 0; i < %%(align)s; ++i) {
            auto row = getHSlice<TPDElem>(ZA, row_idx + i);
            for (int e = 0; e < eCount; ++e) {
                int segmentbase = e - (e %%%% eltspersegment);
                int s = %%(align)s * segmentbase + idx;

                TPS1Elem element1 = AA64FpOp%%(op1)s_xs1[%%(align)s * e + i];
                TPS2Elem element2 = AA64FpOp%%(op2)s_xs2[s];
                row[e] %(sign)s= (TPDElem)element1 * (TPDElem)element2;
            }
        }
        row_idx += vstride;
    '''

    sme2MultiIdxNRegInst("smlal", "SmlalMIdx1Reg", "SimdMatMultAccOp",
                         ['int16_t'], ['int16_t'], ['int32_t'],
                         multiIdxIntMlalCode % {"sign": "+"}, 1, align=2)
    sme2MultiIdxNRegInst("smlal", "SmlalMIdx2Reg", "SimdMatMultAccOp",
                         ['int16_t'], ['int16_t'], ['int32_t'],
                         multiIdxIntMlalCode % {"sign": "+"}, 2, align=2)
    sme2MultiIdxNRegInst("smlal", "SmlalMIdx4Reg", "SimdMatMultAccOp",
                         ['int16_t'], ['int16_t'], ['int32_t'],
                         multiIdxIntMlalCode % {"sign": "+"}, 4, align=2)

    # SMLAL (multiple and single vector)
    multiVecIntMlalCode = '''
        for (int i = 0; i < %%(align)s; ++i) {
            auto row = getHSlice<TPDElem>(ZA, row_idx + i);
            for (int e = 0; e < eCount; ++e) {
                TPS1Elem element1 = AA64FpOp%%(op1)s_xs1[%%(align)s * e + i];
                TPS2Elem element2 = AA64FpOp%%(op2)s_xs2[%%(align)s * e + i];
                row[e] %(sign)s= (TPDElem)element1 * (TPDElem)element2;
            }
        }
        row_idx += vstride;
    '''

    sme2MultiSglNRegInst("smlal", "SmlalMSgl1Reg", "SimdMatMultAccOp",
                         ['int16_t'], ['int16_t'], ['int32_t'],
                         multiVecIntMlalCode % {"sign": "+"}, 1, align=2)
    sme2MultiSglNRegInst("smlal", "SmlalMSgl2Reg", "SimdMatMultAccOp",
                         ['int16_t'], ['int16_t'], ['int32_t'],
                         multiVecIntMlalCode % {"sign": "+"}, 2, align=2)
    sme2MultiSglNRegInst("smlal", "SmlalMSgl4Reg", "SimdMatMultAccOp",
                         ['int16_t'], ['int16_t'], ['int32_t'],
                         multiVecIntMlalCode % {"sign": "+"}, 4, align=2)

    # SMLAL (multiple vectors)
    sme2MultiVecNRegInst("smlal", "SmlalMVec2Reg", "SimdMatMultAccOp",
                         ['int16_t'], ['int16_t'], ['int32_t'],
                         multiVecIntMlalCode % {"sign": "+"}, 2, align=2)
    sme2MultiVecNRegInst("smlal", "SmlalMVec4Reg", "SimdMatMultAccOp",
