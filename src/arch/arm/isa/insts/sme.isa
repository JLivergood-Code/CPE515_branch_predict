    # URSHL (multiple vectors)
    sme2DestrNxNInst("urshl", "UrshlMVec2Reg", "SimdShiftOp",
                     ['uint8_t', 'uint16_t', 'uint32_t', 'uint64_t'],
                     destrBinCode % {'op': urshlBaseOp}, 2)
    sme2DestrNxNInst("urshl", "UrshlMVec4Reg", "SimdShiftOp",
                     ['uint8_t', 'uint16_t', 'uint32_t', 'uint64_t'],
                     destrBinCode % {'op': urshlBaseOp}, 4)

    # USDOT (multiple and indexed vector)
    sme2MultiIdxNRegInst("usdot", "UsdotMIdx2Reg", "SimdMultAccOp",
                         ['uint8_t'], ['int8_t'], ['int32_t'],
                         multiIdxIntDotCode % {'way': 4}, 2)
    sme2MultiIdxNRegInst("usdot", "UsdotMIdx4Reg", "SimdMultAccOp",
                         ['uint8_t'], ['int8_t'], ['int32_t'],
                         multiIdxIntDotCode % {'way': 4}, 4)

    # USDOT (multiple and single vector)
    sme2MultiSglNRegInst("usdot", "UsdotMSgl2Reg", "SimdMultAccOp",
                         ['uint8_t'], ['int8_t'], ['int32_t'],
                         multiVecIntDotCode % {'way': 4}, 2)
    sme2MultiSglNRegInst("usdot", "UsdotMSgl4Reg", "SimdMultAccOp",
                         ['uint8_t'], ['int8_t'], ['int32_t'],
                         multiVecIntDotCode % {'way': 4}, 4)

    # USDOT (multiple vectors)
    sme2MultiVecNRegInst("usdot", "UsdotMVec2Reg", "SimdMultAccOp",
                         ['uint8_t'], ['int8_t'], ['int32_t'],
                         multiVecIntDotCode % {'way': 4}, 2)
    sme2MultiVecNRegInst("usdot", "UsdotMVec4Reg", "SimdMultAccOp",
                         ['uint8_t'], ['int8_t'], ['int32_t'],
                         multiVecIntDotCode % {'way': 4}, 4)

    # USMLALL (multiple and indexed vector)
    sme2MultiIdxNRegInst("usmlall", "UsmlallMIdx1Reg", "SimdMultAccOp",
                         ['uint8_t'], ['int8_t'], ['int32_t'],
                         multiIdxIntMlalCode % {"sign": "+"}, 1, align=4)
    sme2MultiIdxNRegInst("usmlall", "UsmlallMIdx2Reg", "SimdMultAccOp",
                         ['uint8_t'], ['int8_t'], ['int32_t'],
                         multiIdxIntMlalCode % {"sign": "+"}, 2, align=4)
    sme2MultiIdxNRegInst("usmlall", "UsmlallMIdx4Reg", "SimdMultAccOp",
                         ['uint8_t'], ['int8_t'], ['int32_t'],
                         multiIdxIntMlalCode % {"sign": "+"}, 4, align=4)

    # USMLALL (multiple and single vector)
    sme2MultiSglNRegInst("usmlall", "UsmlallMSgl1Reg", "SimdMultAccOp",
                         ['uint8_t'], ['int8_t'], ['int32_t'],
                         multiVecIntMlalCode % {"sign": "+"}, 1, align=4)
    sme2MultiSglNRegInst("usmlall", "UsmlallMSgl2Reg", "SimdMultAccOp",
                         ['uint8_t'], ['int8_t'], ['int32_t'],
                         multiVecIntMlalCode % {"sign": "+"}, 2, align=4)
    sme2MultiSglNRegInst("usmlall", "UsmlallMSgl4Reg", "SimdMultAccOp",
                         ['uint8_t'], ['int8_t'], ['int32_t'],
                         multiVecIntMlalCode % {"sign": "+"}, 4, align=4)

    # USMLALL (multiple vectors)
    sme2MultiVecNRegInst("usmlall", "UsmlallMVec2Reg", "SimdMultAccOp",
                         ['uint8_t'], ['int8_t'], ['int32_t'],
                         multiVecIntMlalCode % {"sign": "+"}, 2, align=4)
    sme2MultiVecNRegInst("usmlall", "UsmlallMVec4Reg", "SimdMultAccOp",
                         ['uint8_t'], ['int8_t'], ['int32_t'],
                         multiVecIntMlalCode % {"sign": "+"}, 4, align=4)

    # USMOPA
    smeIntOPInst('usmopa', 'UsmopaI8I32', 'MatrixOPOp',
                 ['uint8_t'], ['int8_t'], ['int32_t'], intMopaCode)
    smeIntOPInst('usmopa', 'UsmopaI16I64', 'MatrixOPOp',
                 ['uint16_t'], ['int16_t'], ['int64_t'], intMopaCode)

    # USMOPS
    smeIntOPInst('usmops', 'UsmopsI8I32', 'MatrixOPOp',
                 ['uint8_t'], ['int8_t'], ['int32_t'], intMopsCode)
    smeIntOPInst('usmops', 'UsmopsI16I64', 'MatrixOPOp',
                 ['uint16_t'], ['int16_t'], ['int64_t'], intMopsCode)

    # USVDOT
    sme2MultiIdxNRegInst("usvdot", "UsvdotMIdx4Reg", "SimdMultAccOp",
                         ['uint8_t'], ['int8_t'], ['int32_t'],
                         multiIdxIntVdot4WayCode, 4)

    # UUNPK
    sme2UnpkInst("uunpk", "Uunpk2Reg", "SimdAluOp",
                 ['uint8_t', 'uint16_t', 'uint32_t'],
                 ['uint16_t', 'uint32_t', 'uint64_t'],
                 unpkCode, 2)
    sme2UnpkInst("uunpk", "Uunpk4Reg", "SimdAluOp",
                 ['uint8_t', 'uint16_t', 'uint32_t'],
                 ['uint16_t', 'uint32_t', 'uint64_t'],
                 unpkCode, 4)

    # UVDOT (2-way)
    sme2MultiIdxNRegInst("uvdot", "UvdotI16I32MIdx2Reg", "SimdMultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiIdxIntVdot2WayCode, 2)

    # UVDOT (4-way)
    sme2MultiIdxNRegInst("uvdot", "UvdotI8I32MIdx4Reg", "SimdMultAccOp",
                         ['uint8_t'], ['uint8_t'], ['uint32_t'],
                         multiIdxIntVdot4WayCode, 4)
    sme2MultiIdxNRegInst("uvdot", "UvdotI16I64MIdx4Reg", "SimdMultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint64_t'],
                         multiIdxIntVdot4WayCode, 4)

    # UZP (four registers)
    uzp4PreCode = '''
        // Determine the number of quads of vector elements we have
        unsigned quads = eCount / 4;
        unsigned base = 0;
    '''

    uzp4Code = '''
        for (int q = 0; q < quads; ++q) {
            AA64FpDest1_x[base+q] = AA64FpOp%(op1)s_x[4*q+0];
            AA64FpDest2_x[base+q] = AA64FpOp%(op1)s_x[4*q+1];
            AA64FpDest3_x[base+q] = AA64FpOp%(op1)s_x[4*q+2];
            AA64FpDest4_x[base+q] = AA64FpOp%(op1)s_x[4*q+3];
        }

        // Update base for the next iteration
        base += quads;
    '''

    sme2DestrNxNInst("uzp", "Uzp4Reg", "SimdAluOp",
                     ['uint8_t', 'uint16_t', 'uint32_t', 'uint64_t',
                      '__uint128_t'],
                     uzp4Code, 4, preCode=uzp4PreCode)

    # UZP (two registers)
    uzp2PreCode = '''
        // Determine the number of pairs of vector elements we have
        unsigned pairs = eCount / 2;
        unsigned base = 0;
    '''

    uzp2Code = '''
        for (int p = 0; p < pairs; ++p) {
            AA64FpDest1_x[base+p] = AA64FpOp%(op1)s_x[2*p+0];
            AA64FpDest2_x[base+p] = AA64FpOp%(op1)s_x[2*p+1];
        }

        // Update base for the next iteration
        base += pairs;
    '''

    sme2DestrNxNInst("uzp", "Uzp2Reg", "SimdAluOp",
                     ['uint8_t', 'uint16_t', 'uint32_t', 'uint64_t',
                      '__uint128_t'],
                     uzp2Code, 2, preCode=uzp2PreCode)

    # ZERO (double-vector)
    smeZeroArrayInst('zero', 'Zero2Reg1Grp', 'MatrixOp', ["uint64_t"], 2, 1)
    smeZeroArrayInst('zero', 'Zero2Reg2Grp', 'MatrixOp', ["uint64_t"], 2, 2)
    smeZeroArrayInst('zero', 'Zero2Reg4Grp', 'MatrixOp', ["uint64_t"], 2, 4)

    # ZERO (quad-vector)
    smeZeroArrayInst('zero', 'Zero4Reg1Grp', 'MatrixOp', ["uint64_t"], 4, 1)
    smeZeroArrayInst('zero', 'Zero4Reg2Grp', 'MatrixOp', ["uint64_t"], 4, 2)
    smeZeroArrayInst('zero', 'Zero4Reg4Grp', 'MatrixOp', ["uint64_t"], 4, 4)

    # ZERO (single-vector)
    smeZeroArrayInst('zero', 'Zero1Reg2Grp', 'MatrixOp', ["uint64_t"], 1, 2)
    smeZeroArrayInst('zero', 'Zero1Reg4Grp', 'MatrixOp', ["uint64_t"], 1, 4)

    # ZERO (table)
    sme2ZeroLutInst("zero", "ZeroLut", "SimdAluOp")

    # ZERO (tiles)
    smeZeroInst("zero", "Zero", "MatrixOp", ["uint64_t"])

    # ZIP (four registers)
    zip4PreCode = '''
        // Determine the number of quads of vector elements we have
        unsigned quads = eCount / 4;
        unsigned base = 0;
    '''

    zip4Code = '''
        for (int q = 0; q < quads; ++q) {
            AA64FpDest%(op1)s_x[4*q+0] = AA64FpOp1_x[base+q];
            AA64FpDest%(op1)s_x[4*q+1] = AA64FpOp2_x[base+q];
            AA64FpDest%(op1)s_x[4*q+2] = AA64FpOp3_x[base+q];
            AA64FpDest%(op1)s_x[4*q+3] = AA64FpOp4_x[base+q];
        }

        // Update base for the next iteration
        base += quads;
    '''

    sme2DestrNxNInst("zip", "Zip4Reg", "SimdAluOp",
                     ['uint8_t', 'uint16_t', 'uint32_t', 'uint64_t',
                      '__uint128_t'],
                     zip4Code, 4, preCode=zip4PreCode)

    # ZIP (two registers)
    zip2PreCode = '''
        // Determine the number of pairs of vector elements we have
        unsigned pairs = eCount / 2;
        unsigned base = 0;
    '''

    zip2Code = '''
        for (int p = 0; p < pairs; ++p) {
            AA64FpDest%(op1)s_x[2*p+0] = AA64FpOp1_x[base+p];
            AA64FpDest%(op1)s_x[2*p+1] = AA64FpOp2_x[base+p];
        }

        // Update base for the next iteration
        base += pairs;
    '''

    sme2DestrNxNInst("zip", "Zip2Reg", "SimdAluOp",
                     ['uint8_t', 'uint16_t', 'uint32_t', 'uint64_t',
                      '__uint128_t'],
                     zip2Code, 2, preCode=zip2PreCode)

}};
