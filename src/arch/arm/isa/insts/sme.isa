    # UQRSHR (four registers)
    uqrshrBaseOp = '''
            if (imm > sizeof(srcElem1) * 8) {
                destElem = 0;
            } else if (imm) {
                TPSElem mid = (srcElem1 >> (imm - 1));
                uint64_t rBit = mid & 0x1;
                mid >>= 1;
                mid += rBit;
                if (mid != (TPDElem)mid) {
                    destElem = mask(sizeof(TPDElem) * 8);
                } else {
                    destElem = mid;
                }
            } else {
                if (srcElem1 != (TPDElem)srcElem1) {
                    destElem = mask(sizeof(TPDElem) * 8 - 1);
                } else {
                    destElem = srcElem1;
                }
            }
    '''
    sme2RightShiftInst("uqrshr", "Uqrshr4Reg", "SimdShiftOp",
                       ['uint32_t', 'uint64_t'], ['uint8_t', 'uint16_t'],
                       nonDestrBinCode % {'op': uqrshrBaseOp}, 4)

