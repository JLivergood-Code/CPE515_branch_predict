    def smeZeroArrayInst(name, Name, opClass, types, numRegs, numGrp):
        assert numRegs in [1, 2, 4]
        assert numGrp in [1, 2, 4]
        global header_output, decoder_output, exec_output
        code = smEnCheckCodeNoSM + smeZaWrite + '''
            // When zeroing tiles, we use  64-bit elements. This means
            // that we have up to eight subtiles to clear in the ZA tile.

            unsigned eCount = ArmStaticInst::getCurSmeVecLen<TPElem>(
                xc->tcBase());

            int vectors = eCount * sizeof(TPElem);
            int vstride = vectors / %(numGrp)s;
            int vec = (WIndex + imm) %% vstride;
            unsigned row_idx = vec;
            ''' % {'numGrp': numGrp}
        if numRegs > 1:
            code += '''
            vec = vec - (vec %% %(numRegs)s);
            row_idx = vec;
            ''' % {'numRegs': numRegs}
        for i in range(1, numGrp + 1):
            code += '''
            for (int i = 0; i < %(numRegs)s; ++i) {
                auto row = getHSlice<TPElem>(ZA, row_idx + i);
                row.zero();
            }
            row_idx += vstride;
            ''' % {'numRegs': numRegs}

        iop = InstObjParams(name, "Sme" + Name, "SmeZeroArrayOp",
                            {'code': code, 'op_class': opClass},
