    sme2DestrNxNInst("bfminnm", "BfminnmMVec4Reg", "SimdBf16CmpOp",
                     ['uint16_t'], destrBfBinCode % {'op': bfminnmBaseOp}, 4)

    # BFMLA (multiple and indexed vector)
    multiIdxFpMlaCode = '''
        auto row%%(op1)s = getHSlice<TPDElem>(ZA, row_idx);
        for (int e = 0; e < eCount; ++e) {
            FPSCR fpscr = FpscrExc & ~FpscrAhpMask;
            fpscr.dn = 1;
            FPCR fpcr = (FPCR)Fpcr;

            int segmentbase = e - (e %%%% eltspersegment);
            int s = segmentbase + idx;

            TPS1Elem element1 = AA64FpOp%%(op1)s_xs1[e];
            TPS2Elem element2 = AA64FpOp%%(op2)s_xs2[s];
            TPDElem destElem = row%%(op1)s[e];
            %(op)s
            row%%(op1)s[e] = destElem;
        }
        row_idx += vstride;
    '''

    bfmlaBaseOp = '''
            destElem = fplibBfMulAdd(destElem, element1,
                                    element2, fpscr, fpcr, true);'''

    sme2MultiIdxNRegInst("bfmla", "BfmlaMIdx2Reg", "SimdBf16MultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint16_t'],
                         multiIdxFpMlaCode % {"op": bfmlaBaseOp}, 2)
    sme2MultiIdxNRegInst("bfmla", "BfmlaMIdx4Reg", "SimdBf16MultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint16_t'],
                         multiIdxFpMlaCode % {"op": bfmlaBaseOp}, 4)

    # BFMLA (multiple and single vector)
    multiVecFpMlaCode = '''
        auto row%%(op1)s = getHSlice<TPDElem>(ZA, row_idx);
        for (int e = 0; e < eCount; ++e) {
            FPSCR fpscr = FpscrExc & ~FpscrAhpMask;
            fpscr.dn = 1;
            FPCR fpcr = (FPCR)Fpcr;

            TPS1Elem element1 = AA64FpOp%%(op1)s_xs1[e];
            TPS2Elem element2 = AA64FpOp%%(op2)s_xs2[e];
            TPDElem destElem = row%%(op1)s[e];
            %(op)s
            row%%(op1)s[e] = destElem;
        }
        row_idx += vstride;
    '''

    sme2MultiSglNRegInst("bfmla", "BfmlaMSgl2Reg", "SimdBf16MultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint16_t'],
