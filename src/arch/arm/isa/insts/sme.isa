                    FPCRRounding(fpscr), fpscr, fpcr);'''

    sme2NonDestrNxNInst("scvtf", "Scvtf2Reg", "SimdCvtOp", ['uint32_t'],
                        destrFpUnaryCode % {"op": scvtfBaseOp}, 2)
    sme2NonDestrNxNInst("scvtf", "Scvtf4Reg", "SimdCvtOp", ['uint32_t'],
                        destrFpUnaryCode % {"op": scvtfBaseOp}, 4)

    # SDOT (2-way, multiple and indexed vector)
    multiIdxIntDotCode = '''
        auto row%%(op1)s  = getHSlice<TPDElem>(ZA, row_idx);
        for (int e = 0; e < eCount; ++e) {
            TPDElem destElem = row%%(op1)s[e];
            int segmentbase = e - (e %%%% eltspersegment);
            int s = segmentbase + idx;
            for (int k = 0; k < %(way)s; ++k) {
                TPS1Elem srcElem1 = AA64FpOp%%(op1)s_xs1[e * %(way)s + k];
                TPS2Elem srcElem2 = AA64FpOp%%(op2)s_xs2[s * %(way)s + k];
                destElem += (TPDElem)srcElem1 * (TPDElem)srcElem2;
            }
            row%%(op1)s[e] = destElem;
        }
        row_idx += vstride;
    '''

    sme2MultiIdxNRegInst("sdot", "SdotI16I32MIdx2Reg", "SimdMultAccOp",
                         ['int16_t'], ['int16_t'], ['int32_t'],
                         multiIdxIntDotCode % {'way': 2}, 2)
    sme2MultiIdxNRegInst("sdot", "SdotI16I32MIdx4Reg", "SimdMultAccOp",
                         ['int16_t'], ['int16_t'], ['int32_t'],
                         multiIdxIntDotCode % {'way': 2}, 4)

