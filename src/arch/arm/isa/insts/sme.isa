        code = smEnCheckCode + '''
            // AA64FpOp1 is the first grouped source register
            // WIndex is the 32-bit vector select register
            // imm is the optional index offset

            unsigned eCount = ArmStaticInst::getCurSmeVecLen<TPElem>(
                xc->tcBase());

            int vectors = eCount * sizeof(TPElem);
            int vstride = vectors / %(numRegs)s;
            int vec = (WIndex + imm) %% vstride;
            unsigned row_idx = vec;
            ''' % {'numRegs': numRegs}
        for i in range(1, numRegs + 1):
            code += '''
            auto row%(op1)s = getHSlice<TPElem>(ZA, row_idx);
            for (int e = 0; e < eCount; ++e) {
                AA64FpDest%(op1)s_x[e] = row%(op1)s[e];
