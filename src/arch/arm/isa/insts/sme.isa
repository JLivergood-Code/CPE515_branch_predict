output decoder {{

    StaticInstPtr
    decodeSmeNonContigLoadSIInsts(uint8_t msz, ExtMachInst machInst,
            RegIndex zt, RegIndex pg, RegIndex rn,
            int64_t imm, int numregs, bool nonTemporal)
    {
        static const char* nm[2][4] = {
            { "ld1b", "ld1h", "ld1w", "ld1d" },
            { "ldnt1b", "ldnt1h", "ldnt1w", "ldnt1d" } };

        if (!nonTemporal) {
            switch (msz) {
                case 0:
                    return new SmeLdNonContigSI<uint8_t,
                            SmeLoadRegImmPngMicroop>(
                                nm[nonTemporal][msz], machInst, MemReadOp,
                                zt, pg, rn, imm, numregs);
                case 1:
                    return new SmeLdNonContigSI<uint16_t,
                            SmeLoadRegImmPngMicroop>(
                                nm[nonTemporal][msz], machInst, MemReadOp,
                                zt, pg, rn, imm, numregs);
                case 2:
                    return new SmeLdNonContigSI<uint32_t,
                            SmeLoadRegImmPngMicroop>(
                                nm[nonTemporal][msz], machInst, MemReadOp,
                                zt, pg, rn, imm, numregs);
                case 3:
                    return new SmeLdNonContigSI<uint64_t,
                            SmeLoadRegImmPngMicroop>(
                                nm[nonTemporal][msz], machInst, MemReadOp,
                                zt, pg, rn, imm, numregs);
            }
        } else {
            switch (msz) {
                case 0:
                    return new SmeLdNonContigSI<uint8_t,
                            SmeLoadRegImmPngNTMicroop>(
                                nm[nonTemporal][msz], machInst, MemReadOp,
                                zt, pg, rn, imm, numregs);
                case 1:
                    return new SmeLdNonContigSI<uint16_t,
                            SmeLoadRegImmPngNTMicroop>(
                                nm[nonTemporal][msz], machInst, MemReadOp,
                                zt, pg, rn, imm, numregs);
                case 2:
                    return new SmeLdNonContigSI<uint32_t,
                            SmeLoadRegImmPngNTMicroop>(
                                nm[nonTemporal][msz], machInst, MemReadOp,
                                zt, pg, rn, imm, numregs);
                case 3:
                    return new SmeLdNonContigSI<uint64_t,
                            SmeLoadRegImmPngNTMicroop>(
                                nm[nonTemporal][msz], machInst, MemReadOp,
                                zt, pg, rn, imm, numregs);
            }
        }
        return new Unknown64(machInst);
    }

    StaticInstPtr
    decodeSmeNonContigtoreSIInsts(uint8_t msz, ExtMachInst machInst,
            RegIndex zt, RegIndex pg, RegIndex xn,
            int64_t imm, int numregs, bool nonTemporal)
    {
        static const char* nm[2][4] = {
            { "st1b", "st1h", "st1w", "st1d" },
            { "stnt1b", "stnt1h", "stnt1w", "stnt1d" } };

        if (!nonTemporal) {
            switch (msz) {
                case 0:
                    return new SmeStNonContigSI<uint8_t,
                            SmeStoreRegImmPngMicroop>(
                                nm[nonTemporal][msz], machInst, MemWriteOp,
                                zt, pg, xn, imm, numregs);
                case 1:
                    return new SmeStNonContigSI<uint16_t,
                            SmeStoreRegImmPngMicroop>(
                                nm[nonTemporal][msz], machInst, MemWriteOp,
                                zt, pg, xn, imm, numregs);
                case 2:
                    return new SmeStNonContigSI<uint32_t,
                            SmeStoreRegImmPngMicroop>(
                                nm[nonTemporal][msz], machInst, MemWriteOp,
                                zt, pg, xn, imm, numregs);
                case 3:
                    return new SmeStNonContigSI<uint64_t,
                            SmeStoreRegImmPngMicroop>(
                                nm[nonTemporal][msz], machInst, MemWriteOp,
                                zt, pg, xn, imm, numregs);
            }
        } else {
            switch (msz) {
                case 0:
                    return new SmeStNonContigSI<uint8_t,
                            SmeStoreRegImmPngNTMicroop>(
                                nm[nonTemporal][msz], machInst, MemWriteOp,
                                zt, pg, xn, imm, numregs);
                case 1:
                    return new SmeStNonContigSI<uint16_t,
                            SmeStoreRegImmPngNTMicroop>(
                                nm[nonTemporal][msz], machInst, MemWriteOp,
                                zt, pg, xn, imm, numregs);
                case 2:
                    return new SmeStNonContigSI<uint32_t,
                            SmeStoreRegImmPngNTMicroop>(
                                nm[nonTemporal][msz], machInst, MemWriteOp,
                                zt, pg, xn, imm, numregs);
                case 3:
                    return new SmeStNonContigSI<uint64_t,
                            SmeStoreRegImmPngNTMicroop>(
                                nm[nonTemporal][msz], machInst, MemWriteOp,
                                zt, pg, xn, imm, numregs);
            }
        }
        return new Unknown64(machInst);
    }

    StaticInstPtr
    decodeSmeNonContigLoadSSInsts(uint8_t msz, ExtMachInst machInst,
            RegIndex zt, RegIndex pg, RegIndex rn,
            RegIndex rm, int numregs, bool nonTemporal)
    {
        static const char* nm[2][4] = {
            { "ld1b", "ld1h", "ld1w", "ld1d" },
            { "ldnt1b", "ldnt1h", "ldnt1w", "ldnt1d" } };

        if (!nonTemporal) {
            switch (msz) {
                case 0:
                    return new SmeLdNonContigSS<uint8_t,
                            SmeLoadRegRegPngMicroop>(
                                nm[nonTemporal][msz], machInst, MemReadOp,
                                zt, pg, rn, rm, numregs);
                case 1:
                    return new SmeLdNonContigSS<uint16_t,
                            SmeLoadRegRegPngMicroop>(
                                nm[nonTemporal][msz], machInst, MemReadOp,
                                zt, pg, rn, rm, numregs);
                case 2:
                    return new SmeLdNonContigSS<uint32_t,
                            SmeLoadRegRegPngMicroop>(
                                nm[nonTemporal][msz], machInst, MemReadOp,
                                zt, pg, rn, rm, numregs);
                case 3:
                    return new SmeLdNonContigSS<uint64_t,
                            SmeLoadRegRegPngMicroop>(
                                nm[nonTemporal][msz], machInst, MemReadOp,
                                zt, pg, rn, rm, numregs);
            }
        } else {
            switch (msz) {
                case 0:
                    return new SmeLdNonContigSS<uint8_t,
                            SmeLoadRegRegPngNTMicroop>(
                                nm[nonTemporal][msz], machInst, MemReadOp,
                                zt, pg, rn, rm, numregs);
                case 1:
                    return new SmeLdNonContigSS<uint16_t,
                            SmeLoadRegRegPngNTMicroop>(
                                nm[nonTemporal][msz], machInst, MemReadOp,
                                zt, pg, rn, rm, numregs);
                case 2:
                    return new SmeLdNonContigSS<uint32_t,
                            SmeLoadRegRegPngNTMicroop>(
                                nm[nonTemporal][msz], machInst, MemReadOp,
                                zt, pg, rn, rm, numregs);
                case 3:
                    return new SmeLdNonContigSS<uint64_t,
                            SmeLoadRegRegPngNTMicroop>(
                                nm[nonTemporal][msz], machInst, MemReadOp,
                                zt, pg, rn, rm, numregs);
            }
        }
        return new Unknown64(machInst);
    }

    StaticInstPtr
    decodeSmeNonContigtoreSSInsts(uint8_t msz, ExtMachInst machInst,
            RegIndex zt, RegIndex pg, RegIndex rn,
            RegIndex rm, int numregs, bool nonTemporal)
