    sme2MultiVecNRegInst("bfmla", "BfmlaMVec4Reg", "SimdBf16MultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint16_t'],
                         multiVecFpMlaCode % {"op": bfmlaBaseOp}, 4)

    # BFMLAL (multiple and indexed vector)
    multiIdxFpMlalCode = '''
        for (int i = 0; i < %%(align)s; ++i) {
            auto row = getHSlice<TPDElem>(ZA, row_idx + i);
            for (int e = 0; e < eCount; ++e) {
                FPSCR fpscr = FpscrExc & ~FpscrAhpMask;
                fpscr.dn = 1;
                FPCR fpcr = (FPCR)Fpcr;

                int segmentbase = e - (e %%%% eltspersegment);
                int s = %%(align)s * segmentbase + idx;

                TPS1Elem element1 = AA64FpOp%%(op1)s_xs1[%%(align)s * e + i];
                TPS2Elem element2 = AA64FpOp%%(op2)s_xs2[s];
                TPDElem destElem = row[e];
                %(op)s
                row[e] = destElem;
            }
        }
        row_idx += vstride;
    '''

    bfmlalBaseOp = '''
                destElem = fplibBfMulAddH(destElem, element1,
                                          element2, fpscr, fpcr, true);'''

    sme2MultiIdxNRegInst("bfmlal", "BfmlalMIdx1Reg", "SimdBf16MultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiIdxFpMlalCode % {"op": bfmlalBaseOp}, 1, align=2)
    sme2MultiIdxNRegInst("bfmlal", "BfmlalMIdx2Reg", "SimdBf16MultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiIdxFpMlalCode % {"op": bfmlalBaseOp}, 2, align=2)
    sme2MultiIdxNRegInst("bfmlal", "BfmlalMIdx4Reg", "SimdBf16MultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiIdxFpMlalCode % {"op": bfmlalBaseOp}, 4, align=2)

    # BFMLAL (multiple and single vector)
    multiVecFpMlalCode = '''
        for (int i = 0; i < %%(align)s; ++i) {
            auto row = getHSlice<TPDElem>(ZA, row_idx + i);
            for (int e = 0; e < eCount; ++e) {
                FPSCR fpscr = FpscrExc & ~FpscrAhpMask;
                fpscr.dn = 1;
                FPCR fpcr = (FPCR)Fpcr;

                TPS1Elem element1 = AA64FpOp%%(op1)s_xs1[%%(align)s * e + i];
                TPS2Elem element2 = AA64FpOp%%(op2)s_xs2[%%(align)s * e + i];
                TPDElem destElem = row[e];
                %(op)s
                row[e] = destElem;
            }
        }
        row_idx += vstride;
    '''

    sme2MultiSglNRegInst("bfmlal", "BfmlalMSgl1Reg", "SimdBf16MultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiVecFpMlalCode % {"op": bfmlalBaseOp}, 1, align=2)
    sme2MultiSglNRegInst("bfmlal", "BfmlalMSgl2Reg", "SimdBf16MultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiVecFpMlalCode % {"op": bfmlalBaseOp}, 2, align=2)
    sme2MultiSglNRegInst("bfmlal", "BfmlalMSgl4Reg", "SimdBf16MultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiVecFpMlalCode % {"op": bfmlalBaseOp}, 4, align=2)

    # BFMLAL (multiple vectors)
    sme2MultiVecNRegInst("bfmlal", "BfmlalMVec2Reg", "SimdBf16MultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiVecFpMlalCode % {"op": bfmlalBaseOp}, 2, align=2)
    sme2MultiVecNRegInst("bfmlal", "BfmlalMVec4Reg", "SimdBf16MultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiVecFpMlalCode % {"op": bfmlalBaseOp}, 4, align=2)

    # BFMLS (multiple and indexed vector)
    bfmlsBaseOp = '''
            destElem = fplibBfMulAdd(destElem, fplibBfNeg(element1, fpcr),
                                    element2, fpscr, fpcr, true);'''

    sme2MultiIdxNRegInst("bfmls", "BfmlsMIdx2Reg", "SimdBf16MultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint16_t'],
                         multiIdxFpMlaCode % {"op": bfmlsBaseOp}, 2)
    sme2MultiIdxNRegInst("bfmls", "BfmlsMIdx4Reg", "SimdBf16MultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint16_t'],
                         multiIdxFpMlaCode % {"op": bfmlsBaseOp}, 4)

    # BFMLS (multiple and single vector)
    sme2MultiSglNRegInst("bfmls", "BfmlsMSgl2Reg", "SimdBf16MultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint16_t'],
                         multiVecFpMlaCode % {"op": bfmlsBaseOp}, 2)
    sme2MultiSglNRegInst("bfmls", "BfmlsMSgl4Reg", "SimdBf16MultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint16_t'],
                         multiVecFpMlaCode % {"op": bfmlsBaseOp}, 4)

    # BFMLS (multiple vectors)
    sme2MultiVecNRegInst("bfmls", "BfmlsMVec2Reg", "SimdBf16MultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint16_t'],
                         multiVecFpMlaCode % {"op": bfmlsBaseOp}, 2)
    sme2MultiVecNRegInst("bfmls", "BfmlsMVec4Reg", "SimdBf16MultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint16_t'],
                         multiVecFpMlaCode % {"op": bfmlsBaseOp}, 4)

    # BFMLSL (multiple and indexed vector)
    bfmlslBaseOp = '''
                destElem = fplibBfMulAddH(destElem, fplibBfNeg(element1, fpcr),
                                         element2, fpscr, fpcr, true);'''

    sme2MultiIdxNRegInst("bfmlsl", "BfmlslMIdx1Reg", "SimdBf16MultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiIdxFpMlalCode % {"op": bfmlslBaseOp}, 1, align=2)
    sme2MultiIdxNRegInst("bfmlsl", "BfmlslMIdx2Reg", "SimdBf16MultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiIdxFpMlalCode % {"op": bfmlslBaseOp}, 2, align=2)
    sme2MultiIdxNRegInst("bfmlsl", "BfmlslMIdx4Reg", "SimdBf16MultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiIdxFpMlalCode % {"op": bfmlslBaseOp}, 4, align=2)

    # BFMLSL (multiple and single vector)
    sme2MultiSglNRegInst("bfmlsl", "BfmlslMSgl1Reg", "SimdBf16MultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiVecFpMlalCode % {"op": bfmlslBaseOp}, 1, align=2)
    sme2MultiSglNRegInst("bfmlsl", "BfmlslMSgl2Reg", "SimdBf16MultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiVecFpMlalCode % {"op": bfmlslBaseOp}, 2, align=2)
    sme2MultiSglNRegInst("bfmlsl", "BfmlslMSgl4Reg", "SimdBf16MultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiVecFpMlalCode % {"op": bfmlslBaseOp}, 4, align=2)

    # BFMLSL (multiple vectors)
    sme2MultiVecNRegInst("bfmlsl", "BfmlslMVec2Reg", "SimdBf16MultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiVecFpMlalCode % {"op": bfmlslBaseOp}, 2, align=2)
    sme2MultiVecNRegInst("bfmlsl", "BfmlslMVec4Reg", "SimdBf16MultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiVecFpMlalCode % {"op": bfmlslBaseOp}, 4, align=2)

    # BFMOPA (non-widening)
    fmopxCode = '''
        auto tile = getTile<TPDElem>(ZA, imm);
        FPSCR fpscr = FpscrExc & ~FpscrAhpMask;
        fpscr.dn = 1;
        FPCR fpcr = (FPCR)Fpcr;

        for (int j = 0; j < eCount; ++j) {
            for (int i = 0; i < eCount; ++i) {
                if (!GpOp1_xs[j] || !GpOp2_xs[i]) {
                    continue;
                }

                TPSElem elem1 = AA64FpOp1_xs[j];
                TPSElem elem2 = AA64FpOp2_xs[i];
                %s
            }
        }
        '''

    bfmopaCode = fmopxCode % '''
                tile[j][i] = fplibBfMulAdd(tile[j][i], elem1, elem2,
                                fpscr, fpcr);'''

    smeFPOPInst('bfmopa', 'Bfmopa', 'MatrixOPOp', ['uint16_t'], ['uint16_t'],
                bfmopaCode)

    # BFMOPA (widening)
    wideningFmopxCode = '''
        auto tile = getTile<TPDElem>(ZA, imm);
        FPSCR fpscr = FpscrExc & ~FpscrAhpMask;
        fpscr.dn = 1;
        FPCR fpcr = (FPCR)Fpcr;

        const int K = 2;
        for (int j = 0; j < eCount; ++j) {
            for (int i = 0; i < eCount; ++i) {
                if ((!GpOp1_xs[K * j + 0] || !GpOp2_xs[K * i + 0]) &&
                    (!GpOp1_xs[K * j + 1] || !GpOp2_xs[K * i + 1])) {
                    continue;
                }

                TPSElem erow[2] = {0, 0};
                TPSElem ecol[2] = {0, 0};
                for (int k = 0; k < K; ++k) {
                    if (GpOp1_xs[K * j + k]) {
                        erow[k] = AA64FpOp1_xs[K * j + k];
                    }
                    if (GpOp2_xs[K * i + k]) {
                        ecol[k] = AA64FpOp2_xs[K * i + k];
                    }
                }
                %s
            }
        }
        '''

    bfmopaCode = wideningFmopxCode % '''
                tile[j][i] = fplibBfdotAdd(tile[j][i],
                        erow[0], erow[1], ecol[0], ecol[1], fpscr, fpcr);'''

    smeFPOPInst('bfmopa', 'BfmopaWiden', 'MatrixOPOp',
                ['uint16_t'], ['uint32_t'], bfmopaCode)

    # BFMOPS (non-widening)
    bfmopsCode = fmopxCode % '''
                tile[j][i] = fplibBfMulAdd(tile[j][i],
                        elem1, fplibBfNeg(elem2, 0), fpscr, fpcr);'''

    smeFPOPInst('bfmops', 'Bfmops', 'MatrixOPOp', ['uint16_t'], ['uint16_t'],
                bfmopsCode)

    # BFMOPS (widening)
    bfmopsCode = wideningFmopxCode % '''
                if (GpOp1_xs[K * j + 0]) erow[0] = fplibBfNeg(erow[0], 0);
                if (GpOp1_xs[K * j + 1]) erow[1] = fplibBfNeg(erow[1], 0);
                tile[j][i] = fplibBfdotAdd(tile[j][i],
                        erow[0], erow[1], ecol[0], ecol[1], fpscr, fpcr);'''

    smeFPOPInst('bfmops', 'BfmopsWiden', 'MatrixOPOp',
                ['uint16_t'], ['uint32_t'], bfmopsCode)

    # BFSUB
    bfsubBaseOp = 'destElem = fplibBfSub(srcElem1, srcElem2, fpscr, fpcr);'

    sme2ZaZNRegInst("bfsub", "Bfsub2Reg", "SimdBf16AddOp", ['uint16_t'],
                    zazFpBinCode % {'op': bfsubBaseOp}, 2)
    sme2ZaZNRegInst("bfsub", "Bfsub4Reg", "SimdBf16AddOp", ['uint16_t'],
                    zazFpBinCode % {'op': bfsubBaseOp}, 4)

    # BFVDOT
    multiIdxBfvdotCode = '''
        auto row%(op1)s = getHSlice<TPDElem>(ZA, row_idx);
        for (int e = 0; e < eCount; ++e) {
            FPSCR fpscr = FpscrExc & ~FpscrAhpMask;
            fpscr.dn = 1;
            FPCR fpcr = (FPCR)Fpcr;

            TPS1Elem elt1_a = AA64FpOp1_xs1[2 * e + %(op1)s - 1];
            TPS1Elem elt1_b = AA64FpOp2_xs1[2 * e + %(op1)s - 1];

            int segmentbase = e - (e %% eltspersegment);
            int s = segmentbase + idx;
            TPS2Elem elt2_a = AA64FpOp%(op2)s_xs2[2 * s + 0];
            TPS2Elem elt2_b = AA64FpOp%(op2)s_xs2[2 * s + 1];

            TPDElem destElem = fplibBfdotAdd(row%(op1)s[e],
                elt1_a, elt1_b, elt2_a, elt2_b, fpscr, fpcr);
            row%(op1)s[e] = destElem;
        }
        row_idx += vstride;
    '''

    sme2MultiIdxNRegInst("bfvdot", "Bfvdot", "SimdBf16DotProdOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiIdxBfvdotCode, 2)

    # BMOPA
    bmopxCode = '''
        auto tile = getTile<TPDElem>(ZA, imm);

        auto K = sizeof(TPDElem) / sizeof(TPS1Elem);
        for (int j = 0; j < eCount; ++j) {
            for (int i = 0; i < eCount; ++i) {
                for (int k = 0; k < K; ++k) {
                    if (!GpOp1_xs1[K * j + k] || !GpOp2_xs2[K * i + k]) {
                        continue;
                    }

                    TPS1Elem element1 = AA64FpOp1_xs1[K * j + k];
                    TPS2Elem element2 = AA64FpOp2_xs1[K * i + k];

                    // Perform the XNOR
                    TPDElem temp = ~(element1 ^ element2);

                    // Loop over all bits, count the number of set bits
                    TPDElem res = 0;
                    for (int k = 0; k < sizeof(TPDElem) * 8; ++k) {
                        res += temp & 0b1;
                        temp >>= 1;
                    }

                    tile[j][i] %(sign)s= res;
                }
            }
        }
    '''

    smeIntOPInst('bmopa', 'Bmopa', 'MatrixOPOp',
                 ['uint32_t'], ['uint32_t'], ['uint32_t'],
                 bmopxCode % {"sign": "+"})
    # BMOPS
    smeIntOPInst('bmops', 'Bmops', 'MatrixOPOp',
                 ['uint32_t'], ['uint32_t'], ['uint32_t'],
                 bmopxCode % {"sign": "-"})

    # FADD
    faddBaseOp = '''
            destElem = fplibAdd<TPElem>(srcElem1, srcElem2, fpscr, fpcr);'''

    sme2ZaZNRegInst("fadd", "FaddHp2Reg", "SimdFloatAddOp", ['uint16_t'],
                    zazFpBinCode % {'op': faddBaseOp}, 2)
    sme2ZaZNRegInst("fadd", "FaddSp2Reg", "SimdFloatAddOp", ['uint32_t'],
                    zazFpBinCode % {'op': faddBaseOp}, 2)
    sme2ZaZNRegInst("fadd", "FaddDp2Reg", "SimdFloatAddOp", ['uint64_t'],
                    zazFpBinCode % {'op': faddBaseOp}, 2)
    sme2ZaZNRegInst("fadd", "FaddHp4Reg", "SimdFloatAddOp", ['uint16_t'],
                    zazFpBinCode % {'op': faddBaseOp}, 4)
    sme2ZaZNRegInst("fadd", "FaddSp4Reg", "SimdFloatAddOp", ['uint32_t'],
                    zazFpBinCode % {'op': faddBaseOp}, 4)
    sme2ZaZNRegInst("fadd", "FaddDp4Reg", "SimdFloatAddOp", ['uint64_t'],
                    zazFpBinCode % {'op': faddBaseOp}, 4)

    # FCLAMP
    fclampCode = '''
        for (int e = 0; e < eCount; ++e) {
            FPSCR fpscr = FpscrExc & ~FpscrAhpMask;
            FPCR fpcr = (FPCR)Fpcr;

            TPElem element1 = AA64FpOp1_x[e];
            TPElem element2 = AA64FpOp2_x[e];
            TPElem element3 = AA64FpDest%(op)sMerge_x[e];
            TPElem res = fplibMaxNum(element1, element3, fpscr, fpcr);
            res = fplibMinNum(res, element2, fpscr, fpcr);
            AA64FpDest%(op)s_x[e] = res;
            FpscrExc = fpscr;
        }
    '''

    sme2ClampInst("fclamp", "Fclamp2Reg", "SimdFloatCmpOp",
                  ['uint16_t', 'uint32_t', 'uint64_t'], fclampCode, 2)
    sme2ClampInst("fclamp", "Fclamp4Reg", "SimdFloatCmpOp",
                  ['uint16_t', 'uint32_t', 'uint64_t'], fclampCode, 4)

    # FCVT (narrowing, FP32 to FP16)
    fcvtBaseOp = '''
            destElem = fplibConvert<TPSElem, TPDElem>(
                    srcElem1, FPCRRounding(fpscr), fpscr, fpcr);'''

    sme2NonDestr1xNInst("fcvt", "Fcvt2Reg", "SimdCvtOp",
                        ['uint32_t'], ['uint16_t'],
                        nonDestrFpCvtNCode % {'op': fcvtBaseOp}, 2)

    # FCVT (widening)
    nonDestrFpCvtWCode = '''
        for (int e = 0; e < eCount; ++e) {
            FPSCR fpscr = FpscrExc & ~FpscrAhpMask;
            FPCR fpcr = (FPCR)Fpcr;

            TPSElem srcElem1 = AA64FpOp1_xs[offset + e];
            TPDElem destElem;
            %(op)s
            AA64FpDest%%(op1)s_xd[e] = destElem;
            FpscrExc = fpscr;
        }
        offset += eCount;
    '''

    nonDestrFpCvtWInterCode = '''
        for (int e = 0; e < eCount; ++e) {
            FPSCR fpscr = FpscrExc & ~FpscrAhpMask;
            FPCR fpcr = (FPCR)Fpcr;

            TPSElem srcElem1 = AA64FpOp1_xs[%%(numRegs)s * e + offset];
            TPDElem destElem;
            %(op)s
            AA64FpDest%%(op1)s_xd[e] = destElem;
            FpscrExc = fpscr;
        }
        offset += 1;
    '''

    sme2NonDestrNx1Inst("fcvt", "FcvtWiden2Reg", "SimdCvtOp",
                        ['uint16_t'], ['uint32_t'],
                        nonDestrFpCvtWCode % {'op': fcvtBaseOp}, 2)

    # FCVTL
    sme2NonDestrNx1Inst("fcvtl", "Fcvtl2Reg", "SimdCvtOp",
                        ['uint16_t'], ['uint32_t'],
                        nonDestrFpCvtWInterCode % {'op': fcvtBaseOp}, 2)

    # FCVTN (FP32 to FP16)
    sme2NonDestr1xNInst("fcvtn", "Fcvtn2Reg", "SimdCvtOp",
                        ['uint32_t'], ['uint16_t'],
                        nonDestrFpCvtNInterCode % {'op': fcvtBaseOp}, 2)

    # FCVTZS
    destrFpUnaryCode = '''
        for (int e = 0; e < eCount; ++e) {
            FPSCR fpscr = FpscrExc & ~FpscrAhpMask;
            FPCR fpcr = (FPCR)Fpcr;

            TPElem srcElem1 = AA64FpOp%%(op2)s_x[e];
            TPElem destElem;
            %(op)s
            AA64FpDest%%(op1)s_x[e] = destElem;
            FpscrExc = fpscr;
        }
    '''

    fcvtzsBaseOp = '''
            destElem = fplibFPToFixed<TPElem, TPElem>(
                srcElem1, 0, false, FPRounding_ZERO, fpscr, fpcr);'''

    sme2NonDestrNxNInst("fcvtzs", "Fcvtzs2Reg", "SimdCvtOp", ['uint32_t'],
                        destrFpUnaryCode % {"op": fcvtzsBaseOp}, 2)
    sme2NonDestrNxNInst("fcvtzs", "Fcvtzs4Reg", "SimdCvtOp", ['uint32_t'],
                        destrFpUnaryCode % {"op": fcvtzsBaseOp}, 4)

    # FCVTZU
    fcvtzuBaseOp = '''
            destElem = fplibFPToFixed<TPElem, TPElem>(
                srcElem1, 0, true, FPRounding_ZERO, fpscr, fpcr);'''

    sme2NonDestrNxNInst("fcvtzu", "Fcvtzu2Reg", "SimdCvtOp", ['uint32_t'],
                        destrFpUnaryCode % {"op": fcvtzuBaseOp}, 2)
    sme2NonDestrNxNInst("fcvtzu", "Fcvtzu4Reg", "SimdCvtOp", ['uint32_t'],
                        destrFpUnaryCode % {"op": fcvtzuBaseOp}, 4)

    # FDOT (2-way, multiple and indexed vector, FP16 to FP32)
    multiIdxFdotHpSpCode = '''
        auto row%(op1)s = getHSlice<TPDElem>(ZA, row_idx);
        for (int e = 0; e < eCount; ++e) {
            FPSCR fpscr = FpscrExc & ~FpscrAhpMask;
            fpscr.dn = 1;
            FPCR fpcr = (FPCR)Fpcr;

            TPS1Elem elt1_a = AA64FpOp%(op1)s_xs1[2 * e + 0];
            TPS1Elem elt1_b = AA64FpOp%(op1)s_xs1[2 * e + 1];

            int segmentbase = e - (e %% eltspersegment);
            int s = segmentbase + idx;
            TPS2Elem elt2_a = AA64FpOp%(op2)s_xs2[2 * s + 0];
            TPS2Elem elt2_b = AA64FpOp%(op2)s_xs2[2 * s + 1];

            TPDElem prod = fplibDot<TPS1Elem, TPDElem>(
                elt1_a, elt1_b, elt2_a, elt2_b, fpscr, fpcr);
            TPDElem destElem = fplibAdd(row%(op1)s[e], prod, fpscr, fpcr);
            row%(op1)s[e] = destElem;
        }
        row_idx += vstride;
    '''

    sme2MultiIdxNRegInst("fdot", "FdotHpSpMIdx2Reg", "SimdFloatMultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiIdxFdotHpSpCode, 2)
    sme2MultiIdxNRegInst("fdot", "FdotHpSpMIdx4Reg", "SimdFloatMultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiIdxFdotHpSpCode, 4)

    # FDOT (2-way, multiple and single vector, FP16 to FP32)
    multiVecFpDotHpSpCode = '''
        auto row%(op1)s = getHSlice<TPDElem>(ZA, row_idx);
        for (int e = 0; e < eCount; ++e) {
            FPSCR fpscr = FpscrExc & ~FpscrAhpMask;
            fpscr.dn = 1;
            FPCR fpcr = (FPCR)Fpcr;

            TPS1Elem elt1_a = AA64FpOp%(op1)s_xs1[2 * e + 0];
            TPS1Elem elt1_b = AA64FpOp%(op1)s_xs1[2 * e + 1];

            TPS2Elem elt2_a = AA64FpOp%(op2)s_xs2[2 * e + 0];
            TPS2Elem elt2_b = AA64FpOp%(op2)s_xs2[2 * e + 1];

            TPDElem prod = fplibDot<TPS1Elem, TPDElem>(
                elt1_a, elt1_b, elt2_a, elt2_b, fpscr, fpcr);
            TPDElem destElem = fplibAdd(row%(op1)s[e], prod, fpscr, fpcr);
            row%(op1)s[e] = destElem;
        }
        row_idx += vstride;
    '''

    sme2MultiSglNRegInst("fdot", "FdotHpSpMSgl2Reg", "SimdFloatMultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiVecFpDotHpSpCode, 2)
    sme2MultiSglNRegInst("fdot", "FdotHpSpMSgl4Reg", "SimdFloatMultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiVecFpDotHpSpCode, 4)

    # FDOT (2-way, multiple vectors, FP16 to FP32)
    sme2MultiVecNRegInst("fdot", "FdotHpSpMVec2Reg", "SimdFloatMultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiVecFpDotHpSpCode, 2)
    sme2MultiVecNRegInst("fdot", "FdotHpSpMVec4Reg", "SimdFloatMultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiVecFpDotHpSpCode, 4)

    # FMAX (multiple and single vector)
    destrFpBinCode = '''
        for (int e = 0; e < eCount; ++e) {
            FPSCR fpscr = FpscrExc & ~FpscrAhpMask;
            FPCR fpcr = (FPCR)Fpcr;

            TPElem srcElem1 = AA64FpDest%%(op1)sMerge_x[e];
            TPElem srcElem2 = AA64FpOp%%(op2)s_x[e];
            TPElem destElem;
            %(op)s
            AA64FpDest%%(op1)s_x[e] = destElem;
            FpscrExc = fpscr;
        }
    '''

    fmaxBaseOp = 'destElem = fplibMax(srcElem1, srcElem2, fpscr, fpcr);'

    sme2DestrNx1Inst("fmax", "FmaxMSgl2Reg", "SimdFloatCmpOp",
                     ['uint16_t', 'uint32_t', 'uint64_t'],
                     destrFpBinCode % {'op': fmaxBaseOp}, 2)
    sme2DestrNx1Inst("fmax", "FmaxMSgl4Reg", "SimdFloatCmpOp",
                     ['uint16_t', 'uint32_t', 'uint64_t'],
                     destrFpBinCode % {'op': fmaxBaseOp}, 4)

    # FMAX (multiple vectors)
    sme2DestrNxNInst("fmax", "FmaxMVec2Reg", "SimdFloatCmpOp",
                     ['uint16_t', 'uint32_t', 'uint64_t'],
                     destrFpBinCode % {'op': fmaxBaseOp}, 2)
    sme2DestrNxNInst("fmax", "FmaxMVec4Reg", "SimdFloatCmpOp",
                     ['uint16_t', 'uint32_t', 'uint64_t'],
                     destrFpBinCode % {'op': fmaxBaseOp}, 4)

    # FMAXNM (multiple and single vector)
    fmaxnmBaseOp = 'destElem = fplibMaxNum(srcElem1, srcElem2, fpscr, fpcr);'

    sme2DestrNx1Inst("fmaxnm", "FmaxnmMSgl2Reg", "SimdFloatCmpOp",
                     ['uint16_t', 'uint32_t', 'uint64_t'],
                     destrFpBinCode % {'op': fmaxnmBaseOp}, 2)
    sme2DestrNx1Inst("fmaxnm", "FmaxnmMSgl4Reg", "SimdFloatCmpOp",
                     ['uint16_t', 'uint32_t', 'uint64_t'],
                     destrFpBinCode % {'op': fmaxnmBaseOp}, 4)

    # FMAXNM (multiple vectors)
    sme2DestrNxNInst("fmaxnm", "FmaxnmMVec2Reg", "SimdFloatCmpOp",
                     ['uint16_t', 'uint32_t', 'uint64_t'],
                     destrFpBinCode % {'op': fmaxnmBaseOp}, 2)
    sme2DestrNxNInst("fmaxnm", "FmaxnmMVec4Reg", "SimdFloatCmpOp",
                     ['uint16_t', 'uint32_t', 'uint64_t'],
                     destrFpBinCode % {'op': fmaxnmBaseOp}, 4)

    # FMIN (multiple and single vector)
    fminBaseOp = 'destElem = fplibMin(srcElem1, srcElem2, fpscr, fpcr);'

    sme2DestrNx1Inst("fmin", "FminMSgl2Reg", "SimdFloatCmpOp",
                     ['uint16_t', 'uint32_t', 'uint64_t'],
                     destrFpBinCode % {'op': fminBaseOp}, 2)
    sme2DestrNx1Inst("fmin", "FminMSgl4Reg", "SimdFloatCmpOp",
                     ['uint16_t', 'uint32_t', 'uint64_t'],
                     destrFpBinCode % {'op': fminBaseOp}, 4)

    # FMIN (multiple vectors)
    sme2DestrNxNInst("fmin", "FminMVec2Reg", "SimdFloatCmpOp",
                     ['uint16_t', 'uint32_t', 'uint64_t'],
                     destrFpBinCode % {'op': fminBaseOp}, 2)
    sme2DestrNxNInst("fmin", "FminMVec4Reg", "SimdFloatCmpOp",
                     ['uint16_t', 'uint32_t', 'uint64_t'],
                     destrFpBinCode % {'op': fminBaseOp}, 4)

    # FMINNM (multiple and single vector)
    fminnmBaseOp = 'destElem = fplibMinNum(srcElem1, srcElem2, fpscr, fpcr);'

    sme2DestrNx1Inst("fminnm", "FminnmMSgl2Reg", "SimdFloatCmpOp",
                     ['uint16_t', 'uint32_t', 'uint64_t'],
                     destrFpBinCode % {'op': fminnmBaseOp}, 2)
    sme2DestrNx1Inst("fminnm", "FminnmMSgl4Reg", "SimdFloatCmpOp",
                     ['uint16_t', 'uint32_t', 'uint64_t'],
                     destrFpBinCode % {'op': fminnmBaseOp}, 4)

    # FMINNM (multiple vectors)
    sme2DestrNxNInst("fminnm", "FminnmMVec2Reg", "SimdFloatCmpOp",
                     ['uint16_t', 'uint32_t', 'uint64_t'],
                     destrFpBinCode % {'op': fminnmBaseOp}, 2)
    sme2DestrNxNInst("fminnm", "FminnmMVec4Reg", "SimdFloatCmpOp",
                     ['uint16_t', 'uint32_t', 'uint64_t'],
                     destrFpBinCode % {'op': fminnmBaseOp}, 4)

    # FMLA (multiple and indexed vector)
    fmlaBaseOp = '''
            destElem = fplibMulAdd<TPDElem>(
                destElem, element1, element2, fpscr, fpcr);'''

    sme2MultiIdxNRegInst("fmla", "FmlaHpMIdx2Reg", "SimdFloatMultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint16_t'],
                         multiIdxFpMlaCode % {"op": fmlaBaseOp}, 2)
    sme2MultiIdxNRegInst("fmla", "FmlaSpMIdx2Reg", "SimdFloatMultAccOp",
                         ['uint32_t'], ['uint32_t'], ['uint32_t'],
                         multiIdxFpMlaCode % {"op": fmlaBaseOp}, 2)
    sme2MultiIdxNRegInst("fmla", "FmlaDpMIdx2Reg", "SimdFloatMultAccOp",
                         ['uint64_t'], ['uint64_t'], ['uint64_t'],
                         multiIdxFpMlaCode % {"op": fmlaBaseOp}, 2)
    sme2MultiIdxNRegInst("fmla", "FmlaHpMIdx4Reg", "SimdFloatMultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint16_t'],
                         multiIdxFpMlaCode % {"op": fmlaBaseOp}, 4)
    sme2MultiIdxNRegInst("fmla", "FmlaSpMIdx4Reg", "SimdFloatMultAccOp",
                         ['uint32_t'], ['uint32_t'], ['uint32_t'],
                         multiIdxFpMlaCode % {"op": fmlaBaseOp}, 4)
    sme2MultiIdxNRegInst("fmla", "FmlaDpMIdx4Reg", "SimdFloatMultAccOp",
                         ['uint64_t'], ['uint64_t'], ['uint64_t'],
                         multiIdxFpMlaCode % {"op": fmlaBaseOp}, 4)

    # FMLA (multiple and single vector)
    sme2MultiSglNRegInst("fmla", "FmlaHpMSgl2Reg", "SimdFloatMultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint16_t'],
                         multiVecFpMlaCode % {"op": fmlaBaseOp}, 2)
    sme2MultiSglNRegInst("fmla", "FmlaSpMSgl2Reg", "SimdFloatMultAccOp",
                         ['uint32_t'], ['uint32_t'], ['uint32_t'],
                         multiVecFpMlaCode % {"op": fmlaBaseOp}, 2)
    sme2MultiSglNRegInst("fmla", "FmlaDpMSgl2Reg", "SimdFloatMultAccOp",
                         ['uint64_t'], ['uint64_t'], ['uint64_t'],
                         multiVecFpMlaCode % {"op": fmlaBaseOp}, 2)
    sme2MultiSglNRegInst("fmla", "FmlaHpMSgl4Reg", "SimdFloatMultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint16_t'],
                         multiVecFpMlaCode % {"op": fmlaBaseOp}, 4)
    sme2MultiSglNRegInst("fmla", "FmlaSpMSgl4Reg", "SimdFloatMultAccOp",
                         ['uint32_t'], ['uint32_t'], ['uint32_t'],
                         multiVecFpMlaCode % {"op": fmlaBaseOp}, 4)
    sme2MultiSglNRegInst("fmla", "FmlaDpMSgl4Reg", "SimdFloatMultAccOp",
                         ['uint64_t'], ['uint64_t'], ['uint64_t'],
                         multiVecFpMlaCode % {"op": fmlaBaseOp}, 4)

    # FMLA (multiple vectors)
    sme2MultiVecNRegInst("fmla", "FmlaHpMVec2Reg", "SimdFloatMultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint16_t'],
                         multiVecFpMlaCode % {"op": fmlaBaseOp}, 2)
    sme2MultiVecNRegInst("fmla", "FmlaSpMVec2Reg", "SimdFloatMultAccOp",
                         ['uint32_t'], ['uint32_t'], ['uint32_t'],
                         multiVecFpMlaCode % {"op": fmlaBaseOp}, 2)
    sme2MultiVecNRegInst("fmla", "FmlaDpMVec2Reg", "SimdFloatMultAccOp",
                         ['uint64_t'], ['uint64_t'], ['uint64_t'],
                         multiVecFpMlaCode % {"op": fmlaBaseOp}, 2)
    sme2MultiVecNRegInst("fmla", "FmlaHpMVec4Reg", "SimdFloatMultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint16_t'],
                         multiVecFpMlaCode % {"op": fmlaBaseOp}, 4)
    sme2MultiVecNRegInst("fmla", "FmlaSpMVec4Reg", "SimdFloatMultAccOp",
                         ['uint32_t'], ['uint32_t'], ['uint32_t'],
                         multiVecFpMlaCode % {"op": fmlaBaseOp}, 4)
    sme2MultiVecNRegInst("fmla", "FmlaDpMVec4Reg", "SimdFloatMultAccOp",
                         ['uint64_t'], ['uint64_t'], ['uint64_t'],
                         multiVecFpMlaCode % {"op": fmlaBaseOp}, 4)

    # FMLAL (multiple and indexed vector)
    fmlalBaseOp = '''
            destElem = fplibMulAddH<TPS1Elem, TPDElem>(
                destElem, element1, element2, fpscr, fpcr);'''

    sme2MultiIdxNRegInst("fmlal", "FmlalMIdx1Reg", "SimdFloatMultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiIdxFpMlalCode % {"op": fmlalBaseOp}, 1, align=2)
    sme2MultiIdxNRegInst("fmlal", "FmlalMIdx2Reg", "SimdFloatMultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiIdxFpMlalCode % {"op": fmlalBaseOp}, 2, align=2)
    sme2MultiIdxNRegInst("fmlal", "FmlalMIdx4Reg", "SimdFloatMultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiIdxFpMlalCode % {"op": fmlalBaseOp}, 4, align=2)

    # FMLAL (multiple and single vector)
    sme2MultiSglNRegInst("fmlal", "FmlalMSgl1Reg", "SimdFloatMultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiVecFpMlalCode % {"op": fmlalBaseOp}, 1, align=2)
    sme2MultiSglNRegInst("fmlal", "FmlalMSgl2Reg", "SimdFloatMultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiVecFpMlalCode % {"op": fmlalBaseOp}, 2, align=2)
    sme2MultiSglNRegInst("fmlal", "FmlalMSgl4Reg", "SimdFloatMultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiVecFpMlalCode % {"op": fmlalBaseOp}, 4, align=2)

    # FMLAL (multiple vectors)
    sme2MultiVecNRegInst("fmlal", "FmlalMVec2Reg", "SimdFloatMultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiVecFpMlalCode % {"op": fmlalBaseOp}, 2, align=2)
    sme2MultiVecNRegInst("fmlal", "FmlalMVec4Reg", "SimdFloatMultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiVecFpMlalCode % {"op": fmlalBaseOp}, 4, align=2)

    # FMLS (multiple and indexed vector)
    fmlsBaseOp = '''
            destElem = fplibMulAdd<TPDElem>(
                    destElem, fplibNeg<TPDElem>(element1, fpcr),
                    element2, fpscr, fpcr);'''

    sme2MultiIdxNRegInst("fmls", "FmlsHpMIdx2Reg", "SimdFloatMultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint16_t'],
                         multiIdxFpMlaCode % {"op": fmlsBaseOp}, 2)
    sme2MultiIdxNRegInst("fmls", "FmlsSpMIdx2Reg", "SimdFloatMultAccOp",
                         ['uint32_t'], ['uint32_t'], ['uint32_t'],
                         multiIdxFpMlaCode % {"op": fmlsBaseOp}, 2)
    sme2MultiIdxNRegInst("fmls", "FmlsDpMIdx2Reg", "SimdFloatMultAccOp",
                         ['uint64_t'], ['uint64_t'], ['uint64_t'],
                         multiIdxFpMlaCode % {"op": fmlsBaseOp}, 2)
    sme2MultiIdxNRegInst("fmls", "FmlsHpMIdx4Reg", "SimdFloatMultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint16_t'],
                         multiIdxFpMlaCode % {"op": fmlsBaseOp}, 4)
    sme2MultiIdxNRegInst("fmls", "FmlsSpMIdx4Reg", "SimdFloatMultAccOp",
                         ['uint32_t'], ['uint32_t'], ['uint32_t'],
                         multiIdxFpMlaCode % {"op": fmlsBaseOp}, 4)
    sme2MultiIdxNRegInst("fmls", "FmlsDpMIdx4Reg", "SimdFloatMultAccOp",
                         ['uint64_t'], ['uint64_t'], ['uint64_t'],
                         multiIdxFpMlaCode % {"op": fmlsBaseOp}, 4)

    # FMLS (multiple and single vector)
    sme2MultiSglNRegInst("fmls", "FmlsHpMSgl2Reg", "SimdFloatMultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint16_t'],
                         multiVecFpMlaCode % {"op": fmlsBaseOp}, 2)
    sme2MultiSglNRegInst("fmls", "FmlsSpMSgl2Reg", "SimdFloatMultAccOp",
                         ['uint32_t'], ['uint32_t'], ['uint32_t'],
                         multiVecFpMlaCode % {"op": fmlsBaseOp}, 2)
    sme2MultiSglNRegInst("fmls", "FmlsDpMSgl2Reg", "SimdFloatMultAccOp",
                         ['uint64_t'], ['uint64_t'], ['uint64_t'],
                         multiVecFpMlaCode % {"op": fmlsBaseOp}, 2)
    sme2MultiSglNRegInst("fmls", "FmlsHpMSgl4Reg", "SimdFloatMultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint16_t'],
                         multiVecFpMlaCode % {"op": fmlsBaseOp}, 4)
    sme2MultiSglNRegInst("fmls", "FmlsSpMSgl4Reg", "SimdFloatMultAccOp",
                         ['uint32_t'], ['uint32_t'], ['uint32_t'],
                         multiVecFpMlaCode % {"op": fmlsBaseOp}, 4)
    sme2MultiSglNRegInst("fmls", "FmlsDpMSgl4Reg", "SimdFloatMultAccOp",
                         ['uint64_t'], ['uint64_t'], ['uint64_t'],
                         multiVecFpMlaCode % {"op": fmlsBaseOp}, 4)

    # FMLS (multiple vectors)
    sme2MultiVecNRegInst("fmls", "FmlsHpMVec2Reg", "SimdFloatMultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint16_t'],
                         multiVecFpMlaCode % {"op": fmlsBaseOp}, 2)
    sme2MultiVecNRegInst("fmls", "FmlsSpMVec2Reg", "SimdFloatMultAccOp",
                         ['uint32_t'], ['uint32_t'], ['uint32_t'],
                         multiVecFpMlaCode % {"op": fmlsBaseOp}, 2)
    sme2MultiVecNRegInst("fmls", "FmlsDpMVec2Reg", "SimdFloatMultAccOp",
                         ['uint64_t'], ['uint64_t'], ['uint64_t'],
                         multiVecFpMlaCode % {"op": fmlsBaseOp}, 2)
    sme2MultiVecNRegInst("fmls", "FmlsHpMVec4Reg", "SimdFloatMultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint16_t'],
                         multiVecFpMlaCode % {"op": fmlsBaseOp}, 4)
    sme2MultiVecNRegInst("fmls", "FmlsSpMVec4Reg", "SimdFloatMultAccOp",
                         ['uint32_t'], ['uint32_t'], ['uint32_t'],
                         multiVecFpMlaCode % {"op": fmlsBaseOp}, 4)
    sme2MultiVecNRegInst("fmls", "FmlsDpMVec4Reg", "SimdFloatMultAccOp",
                         ['uint64_t'], ['uint64_t'], ['uint64_t'],
                         multiVecFpMlaCode % {"op": fmlsBaseOp}, 4)

    # FMLSL (multiple and indexed vector)
    fmlslBaseOp = '''
            destElem = fplibMulAddH<TPS1Elem, TPDElem>(
                destElem, fplibNeg<TPS1Elem>(element1, fpcr),
                element2, fpscr, fpcr);'''

    sme2MultiIdxNRegInst("fmlsl", "FmlslMIdx1Reg", "SimdFloatMultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiIdxFpMlalCode % {"op": fmlslBaseOp}, 1, align=2)
    sme2MultiIdxNRegInst("fmlsl", "FmlslMIdx2Reg", "SimdFloatMultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiIdxFpMlalCode % {"op": fmlslBaseOp}, 2, align=2)
    sme2MultiIdxNRegInst("fmlsl", "FmlslMIdx4Reg", "SimdFloatMultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiIdxFpMlalCode % {"op": fmlslBaseOp}, 4, align=2)

    # FMLSL (multiple and single vector)
    sme2MultiSglNRegInst("fmlsl", "FmlslMSgl1Reg", "SimdFloatMultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiVecFpMlalCode % {"op": fmlslBaseOp}, 1, align=2)
    sme2MultiSglNRegInst("fmlsl", "FmlslMSgl2Reg", "SimdFloatMultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiVecFpMlalCode % {"op": fmlslBaseOp}, 2, align=2)
    sme2MultiSglNRegInst("fmlsl", "FmlslMSgl4Reg", "SimdFloatMultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiVecFpMlalCode % {"op": fmlslBaseOp}, 4, align=2)

    # FMLSL (multiple vectors)
    sme2MultiVecNRegInst("fmlsl", "FmlslMVec2Reg", "SimdFloatMultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiVecFpMlalCode % {"op": fmlslBaseOp}, 2, align=2)
    sme2MultiVecNRegInst("fmlsl", "FmlslMVec4Reg", "SimdFloatMultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiVecFpMlalCode % {"op": fmlslBaseOp}, 4, align=2)

    # FMOPA (non-widening)
    fmopaCode = fmopxCode % '''
                tile[j][i] = fplibMulAdd(tile[j][i], elem1, elem2,
                        fpscr, fpcr);'''

    smeFPOPInst('fmopa', 'FmopaHp', 'MatrixOPOp', ['uint16_t'], ['uint16_t'],
                fmopaCode)
    smeFPOPInst('fmopa', 'FmopaSp', 'MatrixOPOp', ['uint32_t'], ['uint32_t'],
                fmopaCode)
    smeFPOPInst('fmopa', 'FmopaDp', 'MatrixOPOp', ['uint64_t'], ['uint64_t'],
                fmopaCode)

    # FMOPA (widening, 2-way, FP16 to FP32)
    fmopaCode = wideningFmopxCode % '''
                TPDElem prod = fplibDot<TPSElem, TPDElem>(
                    erow[0], erow[1], ecol[0], ecol[1], fpscr, fpcr);
                tile[j][i] = fplibAdd(tile[j][i], prod, fpscr, fpcr);'''

    smeFPOPInst('fmopa', 'FmopaHpSp', 'MatrixOPOp',
                ['uint16_t'], ['uint32_t'], fmopaCode)

    # FMOPS (non-widening)
    fmopsCode = fmopxCode % '''
                tile[j][i] = fplibMulAdd(tile[j][i], elem1,
                        fplibNeg(elem2, fpcr), fpscr, fpcr);'''

    smeFPOPInst('fmops', 'FmopsHp', 'MatrixOPOp', ['uint16_t'], ['uint16_t'],
                fmopsCode)
    smeFPOPInst('fmops', 'FmopsSp', 'MatrixOPOp', ['uint32_t'], ['uint32_t'],
                fmopsCode)
    smeFPOPInst('fmops', 'FmopsDp', 'MatrixOPOp', ['uint64_t'], ['uint64_t'],
                fmopsCode)

    # FMOPS (widening)
    fmopsCode = wideningFmopxCode % '''
                if (GpOp1_xs[K * j + 0]) erow[0] = fplibNeg(erow[0], fpcr);
                if (GpOp1_xs[K * j + 1]) erow[1] = fplibNeg(erow[1], fpcr);
                TPDElem prod = fplibDot<TPSElem, TPDElem>(
                    erow[0], erow[1], ecol[0], ecol[1], fpscr, fpcr);
                tile[j][i] = fplibAdd(tile[j][i], prod, fpscr, fpcr);'''

    smeFPOPInst('fmops', 'FmopsHpSp', 'MatrixOPOp',
                ['uint16_t'], ['uint32_t'], fmopsCode)

    # FRINTA
    frintBaseOp = '''
            destElem = fplibRoundInt<TPElem>(
                srcElem1, %(rounding)s, false, fpscr, fpcr);
    '''

    frintaBaseOp = frintBaseOp % {"rounding": "FPRounding_TIEAWAY"}

    sme2NonDestrNxNInst("fprinta", "Frinta2Reg", "SimdCvtOp", ['uint32_t'],
                        destrFpUnaryCode % {"op": frintaBaseOp}, 2)
    sme2NonDestrNxNInst("fprinta", "Frinta4Reg", "SimdCvtOp", ['uint32_t'],
                        destrFpUnaryCode % {"op": frintaBaseOp}, 4)

    # FRINTM
    frintmBaseOp = frintBaseOp % {"rounding": "FPRounding_NEGINF"}

    sme2NonDestrNxNInst("fprintm", "Frintm2Reg", "SimdCvtOp", ['uint32_t'],
                        destrFpUnaryCode % {"op": frintmBaseOp}, 2)
    sme2NonDestrNxNInst("fprintm", "Frintm4Reg", "SimdCvtOp", ['uint32_t'],
                        destrFpUnaryCode % {"op": frintmBaseOp}, 4)

    # FRINTN
    frintnBaseOp = frintBaseOp % {"rounding": "FPRounding_TIEEVEN"}

    sme2NonDestrNxNInst("fprintn", "Frintn2Reg", "SimdCvtOp", ['uint32_t'],
                        destrFpUnaryCode % {"op": frintnBaseOp}, 2)
    sme2NonDestrNxNInst("fprintn", "Frintn4Reg", "SimdCvtOp", ['uint32_t'],
                        destrFpUnaryCode % {"op": frintnBaseOp}, 4)

    # FRINTP
    frintpBaseOp = frintBaseOp % {"rounding": "FPRounding_POSINF"}

    sme2NonDestrNxNInst("fprintp", "Frintp2Reg", "SimdCvtOp", ['uint32_t'],
                        destrFpUnaryCode % {"op": frintpBaseOp}, 2)
    sme2NonDestrNxNInst("fprintp", "Frintp4Reg", "SimdCvtOp", ['uint32_t'],
                        destrFpUnaryCode % {"op": frintpBaseOp}, 4)

    # FSUB
    fsubBaseOp = '''
            destElem = fplibSub<TPElem>(srcElem1, srcElem2, fpscr, fpcr);'''

    sme2ZaZNRegInst("fsub", "FsubHp2Reg", "SimdFloatAddOp", ['uint16_t'],
                    zazFpBinCode % {'op': fsubBaseOp}, 2)
    sme2ZaZNRegInst("fsub", "FsubSp2Reg", "SimdFloatAddOp", ['uint32_t'],
                    zazFpBinCode % {'op': fsubBaseOp}, 2)
    sme2ZaZNRegInst("fsub", "FsubDp2Reg", "SimdFloatAddOp", ['uint64_t'],
                    zazFpBinCode % {'op': fsubBaseOp}, 2)
    sme2ZaZNRegInst("fsub", "FsubHp4Reg", "SimdFloatAddOp", ['uint16_t'],
                    zazFpBinCode % {'op': fsubBaseOp}, 4)
    sme2ZaZNRegInst("fsub", "FsubSp4Reg", "SimdFloatAddOp", ['uint32_t'],
                    zazFpBinCode % {'op': fsubBaseOp}, 4)
    sme2ZaZNRegInst("fsub", "FsubDp4Reg", "SimdFloatAddOp", ['uint64_t'],
                    zazFpBinCode % {'op': fsubBaseOp}, 4)

    # FVDOT (FP16 to FP32)
    multiIdxFvdotCode = '''
        auto row%(op1)s = getHSlice<TPDElem>(ZA, row_idx);
        for (int e = 0; e < eCount; ++e) {
            FPSCR fpscr = FpscrExc & ~FpscrAhpMask;
            fpscr.dn = 1;
            FPCR fpcr = (FPCR)Fpcr;

            TPS1Elem elt1_a = AA64FpOp1_xs1[2 * e + %(op1)s - 1];
            TPS1Elem elt1_b = AA64FpOp2_xs1[2 * e + %(op1)s - 1];

            int segmentbase = e - (e %% eltspersegment);
            int s = segmentbase + idx;
            TPS2Elem elt2_a = AA64FpOp%(op2)s_xs2[2 * s + 0];
            TPS2Elem elt2_b = AA64FpOp%(op2)s_xs2[2 * s + 1];

            TPDElem prod = fplibDot<TPS1Elem, TPDElem>(
                elt1_a, elt1_b, elt2_a, elt2_b, fpscr, fpcr);
            TPDElem destElem = fplibAdd(row%(op1)s[e], prod, fpscr, fpcr);
            row%(op1)s[e] = destElem;
        }
        row_idx += vstride;
    '''

    sme2MultiIdxNRegInst("fvdot", "Fvdot", "SimdFloatMultAccOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiIdxFvdotCode, 2)

    # LD1B
    smeLd1xInst('ld1b', 'Ld1b', 'MemReadOp', ['uint8_t'])

    # LD1D
    smeLd1xInst('ld1d', 'Ld1d', 'MemReadOp', ['uint64_t'])

    # LD1H
    smeLd1xInst('ld1h', 'Ld1h', 'MemReadOp', ['uint16_t'])

    # LD1Q
    smeLd1xInst('ld1q', 'Ld1q', 'MemReadOp', ['__uint128_t'])

    # LD1W
    smeLd1xInst('ld1w', 'Ld1w', 'MemReadOp', ['uint32_t'])

    # LD1B (scalar plus immediate, multiple, consecutive)
    # LD1B (scalar plus immediate, multiple, strided)
    # LD1B (scalar plus scalar, multiple, consecutive)
    # LD1B (scalar plus scalar, multiple, strided)
    # LD1D (scalar plus immediate, multiple, consecutive)
    # LD1D (scalar plus immediate, multiple, strided)
    # LD1D (scalar plus scalar, multiple, consecutive)
    # LD1D (scalar plus scalar, multiple, strided)
    # LD1H (scalar plus immediate, multiple, consecutive)
    # LD1H (scalar plus immediate, multiple, strided)
    # LD1H (scalar plus scalar, multiple, consecutive)
    # LD1H (scalar plus scalar, multiple, strided)
    # LD1W (scalar plus immediate, multiple, consecutive)
    # LD1W (scalar plus immediate, multiple, strided)
    # LD1W (scalar plus scalar, multiple, consecutive)
    # LD1W (scalar plus scalar, multiple, strided)
    # LDNT1B (scalar plus immediate, multiple, consecutive)
    # LDNT1B (scalar plus immediate, multiple, strided)
    # LDNT1B (scalar plus scalar, multiple, consecutive)
    # LDNT1B (scalar plus scalar, multiple, strided)
    # LDNT1D (scalar plus immediate, multiple, consecutive)
    # LDNT1D (scalar plus immediate, multiple, strided)
    # LDNT1D (scalar plus scalar, multiple, consecutive)
    # LDNT1D (scalar plus scalar, multiple, strided)
    # LDNT1H (scalar plus immediate, multiple, consecutive)
    # LDNT1H (scalar plus immediate, multiple, strided)
    # LDNT1H (scalar plus scalar, multiple, consecutive)
    # LDNT1H (scalar plus scalar, multiple, strided)
    # LDNT1W (scalar plus immediate, multiple, consecutive)
    # LDNT1W (scalar plus immediate, multiple, strided)
    # LDNT1W (scalar plus scalar, multiple, consecutive)
    # LDNT1W (scalar plus scalar, multiple, strided)
    emitSmeConseMemInsts(offsetIsImm = True)
    emitSmeConseMemInsts(offsetIsImm = False)

    # LDR (array vector)
    smeLdrInst("ldr", "Ldr", 'MemReadOp')

    # LDR (table)
    smeLdrTableInst("ldr", "LdrTable", 'MemReadOp')

    # LUTI2 (four registers)
    luti2Code = '''
        for (int e = 0; e < eCount; ++e) {
            int byte_index = (base + e) / 4;
            int byte_offset = 2 * ((base + e) %% 4);
            uint8_t srcElem1 = AA64FpOp%(op2)s_ub[byte_index];
            srcElem1 = (srcElem1 >> byte_offset) & 0x3;
            AA64FpDest%(op1)s_x[e] = static_cast<TPElem>(ZT0_uw[srcElem1]);
        }
        base += eCount;
    '''
    luti4Code = '''
        for (int e = 0; e < eCount; ++e) {
            int byte_index = (base + e) / 2;
            int byte_offset = 4 * ((base + e) %% 2);
            uint8_t srcElem1 = AA64FpOp%(op2)s_ub[byte_index];
            srcElem1 = (srcElem1 >> byte_offset) & 0xF;
            AA64FpDest%(op1)s_x[e] = static_cast<TPElem>(ZT0_uw[srcElem1]);
        }
        base += eCount;
    '''

    sme2LutiInst("luti2", "Luti24Reg", 'SimdAluOp',
                 ['uint8_t', 'uint16_t', 'uint32_t'], luti2Code, 2, 4)
    sme2LutiInst("luti2", "Luti2Stride4Reg", 'SimdAluOp',
                 ['uint8_t', 'uint16_t', 'uint32_t'], luti2Code, 2, 4)

    # LUTI2 (single)
    sme2LutiInst("luti2", "Luti21Reg", 'SimdAluOp',
                 ['uint8_t', 'uint16_t', 'uint32_t'], luti2Code, 2, 1)

    # LUTI2 (two registers)
    sme2LutiInst("luti2", "Luti22Reg", 'SimdAluOp',
                 ['uint8_t', 'uint16_t', 'uint32_t'], luti2Code, 2, 2)
    sme2LutiInst("luti2", "Luti2Stride2Reg", 'SimdAluOp',
                 ['uint8_t', 'uint16_t', 'uint32_t'], luti2Code, 2, 2)

    # LUTI4 (four registers)
    sme2LutiInst("luti4", "Luti44Reg", 'SimdAluOp',
                 ['uint16_t', 'uint32_t'], luti4Code, 4, 4)
    sme2LutiInst("luti4", "Luti4Stride4Reg", 'SimdAluOp',
                 ['uint16_t', 'uint32_t'], luti4Code, 4, 4)
    sme2Luti4to8b4RegInst("luti4", "Luti4to8b4Reg", 'SimdAluOp', luti4Code)
    sme2Luti4to8b4RegInst("luti4", "Luti4to8bStride4Reg", 'SimdAluOp',
                          luti4Code)

    # LUTI4 (single)
    sme2LutiInst("luti4", "Luti41Reg", 'SimdAluOp',
                 ['uint8_t', 'uint16_t', 'uint32_t'], luti4Code, 4, 1)

    # LUTI4 (two registers)
    sme2LutiInst("luti4", "Luti42Reg", 'SimdAluOp',
                 ['uint8_t', 'uint16_t', 'uint32_t'], luti4Code, 4, 2)
    sme2LutiInst("luti4", "Luti4Stride2Reg", 'SimdAluOp',
                 ['uint8_t', 'uint16_t', 'uint32_t'], luti4Code, 4, 2)

    # MOVA (array to vector, four registers)
    sme2MovaArrayExtractInst("mova", "MovaArrayExtract4Reg", 'MatrixMovOp',
                             ["uint64_t"], 4)

    # MOVA (array to vector, two registers)
    sme2MovaArrayExtractInst("mova", "MovaArrayExtract2Reg", 'MatrixMovOp',
                             ["uint64_t"], 2)

    # MOVA (tile to vector, four registers)
    sme2MovaExtractInst("mova", "MovaExtract4Reg", 'MatrixMovOp',
                        ["uint8_t", "uint16_t", "uint32_t", "uint64_t"], 4)

    # MOVA (tile to vector, single)
    smeMovaExtractInst("mova", "MovaExtract", 'MatrixMovOp',
                       ["uint8_t", "uint16_t", "uint32_t", "uint64_t",
                       "__uint128_t"])

    # MOVA (tile to vector, two registers)
    sme2MovaExtractInst("mova", "MovaExtract2Reg", 'MatrixMovOp',
                        ["uint8_t", "uint16_t", "uint32_t", "uint64_t"], 2)

    # MOVA (vector to array, four registers)
    sme2MovaArrayInsertInst("mova", "MovaArrayInsert4Reg", 'MatrixMovOp',
                            ["uint64_t"], 4)

    # MOVA (vector to array, two registers)
    sme2MovaArrayInsertInst("mova", "MovaArrayInsert2Reg", 'MatrixMovOp',
                            ["uint64_t"], 2)

    # MOVA (vector to tile, four registers)
    sme2MovaInsertInst("mova", "MovaInsert4Reg", 'MatrixMovOp',
                       ["uint8_t", "uint16_t", "uint32_t", "uint64_t"], 4)

    # MOVA (vector to tile, single)
    smeMovaInsertInst("mova", "MovaInsert", 'MatrixMovOp',
                      ["uint8_t", "uint16_t", "uint32_t", "uint64_t",
                      "__uint128_t"])

    # MOVA (vector to tile, two registers)
    sme2MovaInsertInst("mova", "MovaInsert2Reg", 'MatrixMovOp',
                       ["uint8_t", "uint16_t", "uint32_t", "uint64_t"], 2)

    # MOVAZ (array to vector, four registers)
    sme2MovazArrayExtractInst("movaz", "MovazArrayExtract4Reg", 'MatrixMovOp',
                              ["uint64_t"], 4)

    # MOVAZ (array to vector, two registers)
    sme2MovazArrayExtractInst("movaz", "MovazArrayExtract2Reg", 'MatrixMovOp',
                              ["uint64_t"], 2)

    # MOVAZ (tile to vector, four registers)
    sme2MovazExtractInst("movaz", "MovazExtract4Reg", 'MatrixMovOp',
                         ["uint8_t", "uint16_t", "uint32_t", "uint64_t"], 4)

    # MOVAZ (tile to vector, single)
    sme2MovazExtractInst("movaz", "MovazExtract", 'MatrixMovOp',
                         ["uint8_t", "uint16_t", "uint32_t", "uint64_t",
                         "__uint128_t"], 1)

    # MOVAZ (tile to vector, two registers)
    sme2MovazExtractInst("movaz", "MovazExtract2Reg", 'MatrixMovOp',
                         ["uint8_t", "uint16_t", "uint32_t", "uint64_t"], 2)

    # MOVT (scalar to table)
    # MOVT (table to scalar)
    # MOVT (vector to table)

    # RDSVL
    smeRdsvlInst('rdsvl', 'Rdsvl', 'SimdAddOp')

    # SCLAMP
    intClampCode = '''
        for (int e = 0; e < eCount; ++e) {
            TPElem element1 = AA64FpOp1_x[e];
            TPElem element2 = AA64FpOp2_x[e];
            TPElem element3 = AA64FpDest%(op)sMerge_x[e];

            TPElem res;

            // First handle the minimum - get the larger of the two elements
            if (element1 < element3) {
                res = element3;
            } else {
                res = element1;
            }

            // Now handle the maximum - get the smaller of the two elements
            if (element2 < res) {
                res = element2;
            }

            AA64FpDest%(op)s_x[e] = res;
        }
    '''

    sme2ClampInst("sclamp", "Sclamp2Reg", "SimdCmpOp",
