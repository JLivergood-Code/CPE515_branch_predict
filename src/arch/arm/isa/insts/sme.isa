    sme2MultiVecNRegInst("smlsll", "SmlsllI16I64MVec4Reg", "SimdMatMultAccOp",
                         ['int16_t'], ['int16_t'], ['int64_t'],
                         multiVecIntMlalCode % {"sign": "-"}, 4, align=4)

    # SMOPA (2-way)
    intMopxCode = '''
        auto tile = getTile<TPDElem>(ZA, imm);

        auto K = sizeof(TPDElem) / sizeof(TPS1Elem);
        for (int j = 0; j < eCount; ++j) {
            for (int i = 0; i < eCount; ++i) {
                for (int k = 0; k < K; ++k) {
                    if (!GpOp1_xs1[K * j + k] || !GpOp2_xs2[K * i + k]) {
                        continue;
                    }

                    TPS1Elem temp1 = AA64FpOp1_xs1[K * j + k];
                    TPS2Elem temp2 = AA64FpOp2_xs2[K * i + k];
                    %s
                }
            }
        }
        '''

    intMopaCode = intMopxCode % '''
                    tile[j][i] += (TPDElem)temp1 * (TPDElem)temp2;'''

    smeIntOPInst('smopa', 'SmopaI16I32', 'MatrixOPOp',
                 ['int16_t'], ['int16_t'], ['int32_t'], intMopaCode)

    # SMOPA (4-way)
    smeIntOPInst('smopa', 'SmopaI8I32', 'MatrixOPOp',
                 ['int8_t'], ['int8_t'], ['int32_t'], intMopaCode)
    smeIntOPInst('smopa', 'SmopaI16I64', 'MatrixOPOp',
                 ['int16_t'], ['int16_t'], ['int64_t'], intMopaCode)

    # SMOPS (2-way)
    intMopsCode = intMopxCode % '''
                    tile[j][i] -= (TPDElem)temp1 * (TPDElem)temp2;'''

    smeIntOPInst('smops', 'SmopsI16I32', 'MatrixOPOp',
                 ['int16_t'], ['int16_t'], ['int32_t'], intMopsCode)

    # SMOPS (4-way)
    smeIntOPInst('smops', 'SmopsI8I32', 'MatrixOPOp',
                 ['int8_t'], ['int8_t'], ['int32_t'], intMopsCode)
    smeIntOPInst('smops', 'SmopsI16I64', 'MatrixOPOp',
                 ['int16_t'], ['int16_t'], ['int64_t'], intMopsCode)

    # SMSTART
    smstartSmstopCode = '''
        // Bit 0 of imm determines if we are setting or clearing
        // (smstart vs smstop)
        // Bit 1 means that we are applying this to SM
        // Bit 2 means that we are applying this to ZA
        bool new_state    = imm & 0x1;
        bool sm_affected  = imm & 0x2;
        bool za_affected  = imm & 0x4;
        bool old_sm_state = Svcr & 0x1;
        bool old_za_state = Svcr & 0x2;

        bool sm_changed = sm_affected && old_sm_state != new_state;
        bool za_changed = za_affected && old_za_state != new_state;

        if (sm_changed) {
            // We need to zero the SVE Z, P, FFR registers on SM change. Also,
            // set FPSR to a default value. Note that we use the max SVE len
            // instead of the actual vector length.
            //
            // For the Z, P registers we are directly setting these to zero
            // without going through the ISA parser (which generates the
            // dependencies) as otherwise the O3 CPU can deadlock when there
            // are too few free physical registers. We therefore rely on this
            // instruction being a barrier (IsSerialiseAfter).

            // Z Registers, including special and interleave registers
            ArmISA::VecRegContainer zeroed_z_reg;
            zeroed_z_reg.zero();

            for (int reg_idx = 0; reg_idx < NumVecRegs; ++reg_idx) {
                auto reg_id = ArmISA::vecRegClass[reg_idx];
                xc->tcBase()->setReg(reg_id, &zeroed_z_reg);
            }

            // P Registers, including the FFR
            ArmISA::VecPredRegContainer zeroed_p_reg;
            zeroed_p_reg.reset();

            for (int reg_idx = 0; reg_idx < NumVecPredRegs; ++reg_idx) {
                auto reg_id = ArmISA::vecPredRegClass[reg_idx];
                xc->tcBase()->setReg(reg_id, &zeroed_p_reg);
            }

            // FPSR
            Fpsr = 0x0800009f;
        }

        if (za_changed) {
            // ZA write
            ZA = ZA;
            ZA.zero();
        }

        // Now that we've handled the zeroing of the appropriate registers,
        // we update the pstate accordingly.

        if (sm_changed) {
            if (new_state == 1) {
                Svcr = Svcr | 0x1; // Set SM
            } else {
                Svcr = Svcr & ~(uint64_t)0x1; // Clear SM
            }
        }

        if (za_changed) {
            if (new_state == 1) {
                Svcr = Svcr | 0x2; // Set ZA
            } else {
                Svcr = Svcr & ~(uint64_t)0x2; // Clear ZA
            }
        }
    '''

    smeMsrInst('smstart', 'Smstart', 'IntAluOp',
               smstartSmstopCode)

    # SMSTOP
    smeMsrInst('smstop', 'Smstop', 'IntAluOp',
               smstartSmstopCode)

    # SQCVT (four registers)
    sqcvtBaseOp = '''
            if (srcElem1 > std::numeric_limits<TPDElem>::max()) {
                destElem = std::numeric_limits<TPDElem>::max();
            } else if (srcElem1 < std::numeric_limits<TPDElem>::min()) {
                destElem = std::numeric_limits<TPDElem>::min();
            } else {
                destElem = srcElem1;
            }
    '''

    nonDestrBinCode = '''
        for (int e = 0; e < eCount; ++e) {
            TPSElem srcElem1 = AA64FpOp%%(op1)s_xs[e];
            TPDElem destElem = srcElem1;
            %(op)s
            AA64FpDest_xd[offset + e] = destElem;
        }
        offset += eCount;
    '''

    nonDestrBinInterCode = '''
        for (int e = 0; e < eCount; ++e) {
            TPSElem srcElem1 = AA64FpOp%%(op1)s_xs[e];
            TPDElem destElem = srcElem1;
            %(op)s
            AA64FpDest_xd[%%(numRegs)s * e + offset] = destElem;
        }
        offset += 1;
    '''
    sme2NonDestr1xNInst("sqcvt", "Sqcvt4Reg", "SimdCvtOp",
                        ['int32_t', 'int64_t'], ['int8_t', 'int16_t'],
                        nonDestrBinCode % {'op': sqcvtBaseOp}, 4)

    # SQCVT (two registers)
    sme2NonDestr1xNInst("sqcvt", "Sqcvt2Reg", "SimdCvtOp",
                        ['int32_t'], ['int16_t'],
                        nonDestrBinCode % {'op': sqcvtBaseOp}, 2)

    # SQCVTN
    sme2NonDestr1xNInst("sqcvtn", "Sqcvtn4Reg", "SimdCvtOp",
                        ['int32_t', 'int64_t'], ['int8_t', 'int16_t'],
                        nonDestrBinInterCode % {'op': sqcvtBaseOp}, 4)

    # SQCVTU (four registers)
    sqcvtuBaseOp = '''
            if (srcElem1 < 0) {
                destElem = 0;
            } else if ((srcElem1 >> (8 * sizeof(TPDElem))) > 0) {
                destElem = -1;
            } else {
                destElem = srcElem1;
            }
    '''

    sme2NonDestr1xNInst("sqcvtu", "Sqcvtu4Reg", "SimdCvtOp",
                        ['int32_t', 'int64_t'], ['int8_t', 'int16_t'],
                        nonDestrBinCode % {'op': sqcvtuBaseOp}, 4)

    # SQCVTU (two registers)
    sme2NonDestr1xNInst("sqcvtu", "Sqcvtu2Reg", "SimdCvtOp",
                        ['int32_t'], ['int16_t'],
                        nonDestrBinCode % {'op': sqcvtuBaseOp}, 2)

    # SQCVTUN
    sme2NonDestr1xNInst("sqcvtun", "Sqcvtun4Reg", "SimdCvtOp",
                        ['int32_t', 'int64_t'], ['int8_t', 'int16_t'],
                        nonDestrBinInterCode % {'op': sqcvtuBaseOp}, 4)

    # SQDMULH (multiple and single vector)
    sqdmulhBaseOp = '''
            destElem = (2 * (__int128_t)srcElem1 * (__int128_t)srcElem2) >>
                        (sizeof(TPElem) * 8);
            if (srcElem1 == srcElem2 &&
                    srcElem1 == (TPElem)((TPElem)1 <<
                        (sizeof(TPElem) * 8 - 1))) {
                destElem = ~srcElem1;
            }
    '''

    sme2DestrNx1Inst("sqdmulh", "SqdmulhMSgl2Reg", "SimdMultOp",
                     ['int8_t', 'int16_t', 'int32_t', 'int64_t'],
                     destrBinCode % {'op': sqdmulhBaseOp}, 2)
    sme2DestrNx1Inst("sqdmulh", "SqdmulhMSgl4Reg", "SimdMultOp",
                     ['int8_t', 'int16_t', 'int32_t', 'int64_t'],
                     destrBinCode % {'op': sqdmulhBaseOp}, 4)

    # SQDMULH (multiple vectors)
    sme2DestrNxNInst("sqdmulh", "SqdmulhMVec2Reg", "SimdMultOp",
                     ['int8_t', 'int16_t', 'int32_t', 'int64_t'],
                     destrBinCode % {'op': sqdmulhBaseOp}, 2)
    sme2DestrNxNInst("sqdmulh", "SqdmulhMVec4Reg", "SimdMultOp",
                     ['int8_t', 'int16_t', 'int32_t', 'int64_t'],
                     destrBinCode % {'op': sqdmulhBaseOp}, 4)

    # SQRSHR (four registers)
    sqrshrBaseOp = '''
            if (imm > sizeof(srcElem1) * 8) {
                destElem = 0;
            } else if (imm) {
                TPSElem mid = (srcElem1 >> (imm - 1));
                uint64_t rBit = mid & 0x1;
                mid >>= 1;
                mid |= -(mid & ((TPSElem)1 <<
                            (sizeof(TPSElem) * 8 - 1 - imm)));
                mid += rBit;
                if (mid != (TPDElem)mid) {
                    destElem = mask(sizeof(TPDElem) * 8 - 1);
                    if (srcElem1 < 0)
                        destElem = ~destElem;
                } else {
                    destElem = mid;
                }
            } else {
                if (srcElem1 != (TPDElem)srcElem1) {
                    destElem = mask(sizeof(TPDElem) * 8 - 1);
                    if (srcElem1 < 0)
                        destElem = ~destElem;
                } else {
                    destElem = srcElem1;
                }
            }
    '''

    sme2RightShiftInst("sqrshr", "Sqrshr4Reg", "SimdShiftOp",
                       ['int32_t', 'int64_t'], ['int8_t', 'int16_t'],
                       nonDestrBinCode % {'op': sqrshrBaseOp}, 4)

    # SQRSHR (two registers)
    sme2RightShiftInst("sqrshr", "Sqrshr2Reg", "SimdShiftOp",
                       ['int32_t'], ['int16_t'],
                       nonDestrBinCode % {'op': sqrshrBaseOp}, 2)

    # SQRSHRN
    sme2RightShiftInst("sqrshrn", "Sqrshrn4Reg", "SimdShiftOp",
                       ['int32_t', 'int64_t'], ['int8_t', 'int16_t'],
                       nonDestrBinInterCode % {'op': sqrshrBaseOp}, 4)

    # SQRSHRU (four registers)
    sqrshruBaseOp = '''
            if (imm > sizeof(srcElem1) * 8) {
                destElem = 0;
            } else if (imm) {
                TPSElem mid = (srcElem1 >> (imm - 1));
                uint64_t rBit = mid & 0x1;
                mid >>= 1;
                mid |= -(mid & ((TPSElem)1 <<
                                (sizeof(TPSElem) * 8 - 1 - imm)));
                mid += rBit;
                if (bits(mid, sizeof(TPSElem) * 8 - 1,
                                sizeof(TPDElem) * 8) != 0) {
                    if (srcElem1 < 0) {
                        destElem = 0;
                    } else {
                        destElem = mask(sizeof(TPDElem) * 8);
                    }
                } else {
                    destElem = mid;
                }
            } else {
                if (srcElem1 < 0) {
                    destElem = 0;
                } else {
                    destElem = srcElem1;
                }
            }
    '''
    sme2RightShiftInst("sqrshru", "Sqrshru4Reg", "SimdShiftOp",
                       ['int32_t', 'int64_t'], ['int8_t', 'int16_t'],
                       nonDestrBinCode % {'op': sqrshruBaseOp}, 4)

    # SQRSHRU (two registers)
    sme2RightShiftInst("sqrshru", "Sqrshru2Reg", "SimdShiftOp",
                       ['int32_t'], ['int16_t'],
                       nonDestrBinCode % {'op': sqrshruBaseOp}, 2)

    # SQRSHRUN
    sme2RightShiftInst("sqrshrun", "Sqrshrun4Reg", "SimdShiftOp",
                       ['int32_t', 'int64_t'], ['int8_t', 'int16_t'],
                       nonDestrBinInterCode % {'op': sqrshruBaseOp}, 4)

    # SRSHL (multiple and single vector)
    srshlBaseOp = '''
            TPElem shiftAmt = srcElem2;
            if (shiftAmt < 0) {
                shiftAmt = -shiftAmt;
                TPElem rBit = 0;
                if (shiftAmt <= sizeof(TPElem) * 8)
                    rBit = bits(srcElem1, shiftAmt - 1);
                if (shiftAmt > sizeof(TPElem) * 8 && ltz(srcElem1))
                    rBit = 1;
                if (shiftAmt >= sizeof(TPElem) * 8) {
                    shiftAmt = sizeof(TPElem) * 8 - 1;
                    destElem = 0;
                } else {
                    destElem = (srcElem1 >> shiftAmt);
                }
                // Make sure the right shift sign extended when it should.
                if (ltz(srcElem1) && !ltz(destElem)) {
                    destElem |= -((TPElem)1 << (sizeof(TPElem) * 8 -
                                                    1 - shiftAmt));
                }
                destElem += rBit;
            } else if (shiftAmt > 0) {
                if (shiftAmt >= sizeof(TPElem) * 8) {
                    destElem = 0;
                } else {
                    destElem = srcElem1 << shiftAmt;
                }
            } else {
                destElem = srcElem1;
            }
    '''

    sme2DestrNx1Inst("srshl", "SrshlMSgl2Reg", "SimdShiftOp",
                     ['int8_t', 'int16_t', 'int32_t', 'int64_t'],
                     destrBinCode % {'op': srshlBaseOp}, 2)
    sme2DestrNx1Inst("srshl", "SrshlMSgl4Reg", "SimdShiftOp",
                     ['int8_t', 'int16_t', 'int32_t', 'int64_t'],
                     destrBinCode % {'op': srshlBaseOp}, 4)

    # SRSHL (multiple vectors)
    sme2DestrNxNInst("srshl", "SrshlMVec2Reg", "SimdShiftOp",
                     ['int8_t', 'int16_t', 'int32_t', 'int64_t'],
                     destrBinCode % {'op': srshlBaseOp}, 2)
    sme2DestrNxNInst("srshl", "SrshlMVec4Reg", "SimdShiftOp",
                     ['int8_t', 'int16_t', 'int32_t', 'int64_t'],
                     destrBinCode % {'op': srshlBaseOp}, 4)

    # ST1B
    smeSt1xInst('st1b', 'St1b', 'MemWriteOp', ['uint8_t'])

    # ST1D
    smeSt1xInst('st1d', 'St1d', 'MemWriteOp', ['uint64_t'])

    # ST1H
    smeSt1xInst('st1h', 'St1h', 'MemWriteOp', ['uint16_t'])

    # ST1Q
    smeSt1xInst('st1q', 'St1q', 'MemWriteOp', ['__uint128_t'])

    # ST1W
    smeSt1xInst('st1w', 'St1w', 'MemWriteOp', ['uint32_t'])

    # ST1B (scalar plus immediate, multiple, consecutive)
    # ST1B (scalar plus immediate, multiple, strided)
    # ST1B (scalar plus scalar, multiple, consecutive)
    # ST1B (scalar plus scalar, multiple, strided)
    # ST1D (scalar plus immediate, multiple, consecutive)
    # ST1D (scalar plus immediate, multiple, strided)
    # ST1D (scalar plus scalar, multiple, consecutive)
    # ST1D (scalar plus scalar, multiple, strided)
    # ST1H (scalar plus immediate, multiple, consecutive)
    # ST1H (scalar plus immediate, multiple, strided)
    # ST1H (scalar plus scalar, multiple, consecutive)
    # ST1H (scalar plus scalar, multiple, strided)
    # ST1W (scalar plus immediate, multiple, consecutive)
    # ST1W (scalar plus immediate, multiple, strided)
    # ST1W (scalar plus scalar, multiple, consecutive)
    # ST1W (scalar plus scalar, multiple, strided)
    # STNT1B (scalar plus immediate, multiple, consecutive)
    # STNT1B (scalar plus immediate, multiple, strided)
    # STNT1B (scalar plus scalar, multiple, consecutive)
    # STNT1B (scalar plus scalar, multiple, strided)
    # STNT1D (scalar plus immediate, multiple, consecutive)
    # STNT1D (scalar plus immediate, multiple, strided)
    # STNT1D (scalar plus scalar, multiple, consecutive)
    # STNT1D (scalar plus scalar, multiple, strided)
    # STNT1H (scalar plus immediate, multiple, consecutive)
    # STNT1H (scalar plus immediate, multiple, strided)
    # STNT1H (scalar plus scalar, multiple, consecutive)
    # STNT1H (scalar plus scalar, multiple, strided)
    # STNT1W (scalar plus immediate, multiple, consecutive)
    # STNT1W (scalar plus immediate, multiple, strided)
    # STNT1W (scalar plus scalar, multiple, consecutive)
    # STNT1W (scalar plus scalar, multiple, strided)

    # STR (array vector)
    smeStrInst("str", "Str", "MemWriteOp")

    # STR (Table)
    smeStrTableInst("str", "StrTable", "MemWriteOp")

    # SUB (array accumulators)
    subBaseOp = 'destElem = srcElem1 - srcElem2;'

    sme2ZaZNRegInst("sub", "SubaI322Reg", "SimdAddOp", ['uint32_t'],
                    zazBinCode % {'op': subBaseOp}, 2)
    sme2ZaZNRegInst("sub", "SubaI642Reg", "SimdAddOp", ['uint64_t'],
                    zazBinCode % {'op': subBaseOp}, 2)
    sme2ZaZNRegInst("sub", "SubaI324Reg", "SimdAddOp", ['uint32_t'],
                    zazBinCode % {'op': subBaseOp}, 4)
    sme2ZaZNRegInst("sub", "SubaI644Reg", "SimdAddOp", ['uint64_t'],
                    zazBinCode % {'op': subBaseOp}, 4)

    # SUB (array results, multiple and single vector)
    sme2MultiSglNRegInst("sub", "SubI32MSgl2Reg", "SimdAddOp",
                         ['uint32_t'], ['uint32_t'], ['uint32_t'],
                         multiVecBinCode % {'op': subBaseOp}, 2)
    sme2MultiSglNRegInst("sub", "SubI64MSgl2Reg", "SimdAddOp",
                         ['uint64_t'], ['uint64_t'], ['uint64_t'],
                         multiVecBinCode % {'op': subBaseOp}, 2)
    sme2MultiSglNRegInst("sub", "SubI32MSgl4Reg", "SimdAddOp",
                         ['uint32_t'], ['uint32_t'], ['uint32_t'],
                         multiVecBinCode % {'op': subBaseOp}, 4)
    sme2MultiSglNRegInst("sub", "SubI64MSgl4Reg", "SimdAddOp",
                         ['uint64_t'], ['uint64_t'], ['uint64_t'],
                         multiVecBinCode % {'op': subBaseOp}, 4)

    # SUB (array results, multiple vectors)
    sme2MultiVecNRegInst("sub", "SubI32MVec2Reg", "SimdAddOp",
                         ['uint32_t'], ['uint32_t'], ['uint32_t'],
                         multiVecBinCode % {'op': subBaseOp}, 2)
    sme2MultiVecNRegInst("sub", "SubI64MVec2Reg", "SimdAddOp",
                         ['uint64_t'], ['uint64_t'], ['uint64_t'],
                         multiVecBinCode % {'op': subBaseOp}, 2)
    sme2MultiVecNRegInst("sub", "SubI32MVec4Reg", "SimdAddOp",
                         ['uint32_t'], ['uint32_t'], ['uint32_t'],
                         multiVecBinCode % {'op': subBaseOp}, 4)
    sme2MultiVecNRegInst("sub", "SubI64MVec4Reg", "SimdAddOp",
                         ['uint64_t'], ['uint64_t'], ['uint64_t'],
                         multiVecBinCode % {'op': subBaseOp}, 4)

    # SUDOT (multiple and indexed vector)
    sme2MultiIdxNRegInst("sudot", "SudotMIdx2Reg", "SimdMultAccOp",
                         ['int8_t'], ['uint8_t'], ['int32_t'],
                         multiIdxIntDotCode % {'way': 4}, 2)
    sme2MultiIdxNRegInst("sudot", "SudotMIdx4Reg", "SimdMultAccOp",
                         ['int8_t'], ['uint8_t'], ['int32_t'],
                         multiIdxIntDotCode % {'way': 4}, 4)

    # SUDOT (multiple and single vector)
    sme2MultiSglNRegInst("sudot", "SudotMSgl2Reg", "SimdMultAccOp",
                         ['int8_t'], ['uint8_t'], ['int32_t'],
                         multiVecIntDotCode % {'way': 4}, 2)
    sme2MultiSglNRegInst("sudot", "SudotMSgl4Reg", "SimdMultAccOp",
                         ['int8_t'], ['uint8_t'], ['int32_t'],
                         multiVecIntDotCode % {'way': 4}, 4)

    # SUMLALL (multiple and indexed vector)
    sme2MultiIdxNRegInst("sumlall", "SumlallMIdx1Reg", "SimdMultAccOp",
                         ['int8_t'], ['uint8_t'], ['int32_t'],
                         multiIdxIntMlalCode % {"sign": "+"}, 1, align=4)
    sme2MultiIdxNRegInst("sumlall", "SumlallMIdx2Reg", "SimdMultAccOp",
                         ['int8_t'], ['uint8_t'], ['int32_t'],
                         multiIdxIntMlalCode % {"sign": "+"}, 2, align=4)
    sme2MultiIdxNRegInst("sumlall", "SumlallMIdx4Reg", "SimdMultAccOp",
                         ['int8_t'], ['uint8_t'], ['int32_t'],
                         multiIdxIntMlalCode % {"sign": "+"}, 4, align=4)

    # SUMLALL (multiple and single vector)
    sme2MultiSglNRegInst("sumlall", "SumlallMSgl1Reg", "SimdMultAccOp",
                         ['int8_t'], ['uint8_t'], ['int32_t'],
                         multiVecIntMlalCode % {"sign": "+"}, 1, align=4)
    sme2MultiSglNRegInst("sumlall", "SumlallMSgl2Reg", "SimdMultAccOp",
                         ['int8_t'], ['uint8_t'], ['int32_t'],
                         multiVecIntMlalCode % {"sign": "+"}, 2, align=4)
    sme2MultiSglNRegInst("sumlall", "SumlallMSgl4Reg", "SimdMultAccOp",
                         ['int8_t'], ['uint8_t'], ['int32_t'],
                         multiVecIntMlalCode % {"sign": "+"}, 4, align=4)

    # SUMOPA
    smeIntOPInst('sumopa', 'SumopaI8I32', 'MatrixOPOp',
                 ['int8_t'], ['uint8_t'], ['int32_t'], intMopaCode)
    smeIntOPInst('sumopa', 'SumopaI16I64', 'MatrixOPOp',
                 ['int16_t'], ['uint16_t'], ['int64_t'], intMopaCode)

    # SUMOPS
    smeIntOPInst('sumops', 'SumopsI8I32', 'MatrixOPOp',
                 ['int8_t'], ['uint8_t'], ['int32_t'], intMopsCode)
    smeIntOPInst('sumops', 'SumopsI16I64', 'MatrixOPOp',
                 ['int16_t'], ['uint16_t'], ['int64_t'], intMopsCode)

    # SUNPK
    unpkCode = '''
        for (int e = 0; e < eCount; ++e) {
            TPSElem srcElem1 = AA64FpOp%(op1)s_xs[e];
            AA64FpDest%(op2)s_xd[e] = static_cast<TPDElem>(srcElem1);
            TPSElem srcElem2 = AA64FpOp%(op1)s_xs[eCount + e];
            AA64FpDest%(op3)s_xd[e] = static_cast<TPDElem>(srcElem2);
        }
    '''
    sme2UnpkInst("sunpk", "Sunpk2Reg", "SimdAluOp",
                 ['int8_t', 'int16_t', 'int32_t'],
                 ['int16_t', 'int32_t', 'int64_t'],
                 unpkCode, 2)
    sme2UnpkInst("sunpk", "Sunpk4Reg", "SimdAluOp",
                 ['int8_t', 'int16_t', 'int32_t'],
                 ['int16_t', 'int32_t', 'int64_t'],
                 unpkCode, 4)

    # SUVDOT
    multiIdxIntVdot2WayCode = '''
        auto row%(op1)s  = getHSlice<TPDElem>(ZA, row_idx);
        for (int e = 0; e < eCount; ++e) {
            TPDElem destElem = row%(op1)s[e];
            int segmentbase = e - (e %% eltspersegment);
            int s = segmentbase + idx;

            TPS1Elem srcElem1 = AA64FpOp1_xs1[e * 2 + %(op1)s - 1];
            TPS2Elem srcElem2 = AA64FpOp%(op2)s_xs2[s * 2 + 0];
            destElem += (TPDElem)srcElem1 * (TPDElem)srcElem2;

            srcElem1 = AA64FpOp2_xs1[e * 2 + %(op1)s - 1];
            srcElem2 = AA64FpOp%(op2)s_xs2[s * 2 + 1];
            destElem += (TPDElem)srcElem1 * (TPDElem)srcElem2;

            row%(op1)s[e] = destElem;
        }
        row_idx += vstride;
    '''

    multiIdxIntVdot4WayCode = '''
        auto row%(op1)s  = getHSlice<TPDElem>(ZA, row_idx);
        for (int e = 0; e < eCount; ++e) {
            TPDElem destElem = row%(op1)s[e];
            int segmentbase = e - (e %% eltspersegment);
            int s = segmentbase + idx;

            TPS1Elem srcElem1 = AA64FpOp1_xs1[e * 4 + %(op1)s - 1];
            TPS2Elem srcElem2 = AA64FpOp%(op2)s_xs2[s * 4 + 0];
            destElem += (TPDElem)srcElem1 * (TPDElem)srcElem2;

            srcElem1 = AA64FpOp2_xs1[e * 4 + %(op1)s - 1];
            srcElem2 = AA64FpOp%(op2)s_xs2[s * 4 + 1];
            destElem += (TPDElem)srcElem1 * (TPDElem)srcElem2;

            srcElem1 = AA64FpOp3_xs1[e * 4 + %(op1)s - 1];
            srcElem2 = AA64FpOp%(op2)s_xs2[s * 4 + 2];
            destElem += (TPDElem)srcElem1 * (TPDElem)srcElem2;

            srcElem1 = AA64FpOp4_xs1[e * 4 + %(op1)s - 1];
            srcElem2 = AA64FpOp%(op2)s_xs2[s * 4 + 3];
            destElem += (TPDElem)srcElem1 * (TPDElem)srcElem2;

            row%(op1)s[e] = destElem;
        }
        row_idx += vstride;
    '''

    sme2MultiIdxNRegInst("suvdot", "SuvdotMIdx4Reg", "SimdMultAccOp",
                         ['int8_t'], ['uint8_t'], ['int32_t'],
                         multiIdxIntVdot4WayCode, 4)

    # SVDOT (2-way)
    sme2MultiIdxNRegInst("svdot", "SvdotI16I32MIdx2Reg", "SimdMultAccOp",
                         ['int16_t'], ['int16_t'], ['int32_t'],
                         multiIdxIntVdot2WayCode, 2)

