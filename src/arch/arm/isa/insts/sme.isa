                    return new SmeStNonContigSS<uint32_t,
                            SmeStoreRegRegPngMicroop>(
                                nm[nonTemporal][msz], machInst, MemWriteOp,
                                zt, pg, rn, rm, numregs);
                case 3:
                    return new SmeStNonContigSS<uint64_t,
                            SmeStoreRegRegPngMicroop>(
                                nm[nonTemporal][msz], machInst, MemWriteOp,
                                zt, pg, rn, rm, numregs);
            }
        } else {
            switch (msz) {
                case 0:
                    return new SmeStNonContigSS<uint8_t,
                            SmeStoreRegRegPngNTMicroop>(
                                nm[nonTemporal][msz], machInst, MemWriteOp,
                                zt, pg, rn, rm, numregs);
                case 1:
                    return new SmeStNonContigSS<uint16_t,
                            SmeStoreRegRegPngNTMicroop>(
                                nm[nonTemporal][msz], machInst, MemWriteOp,
                                zt, pg, rn, rm, numregs);
                case 2:
                    return new SmeStNonContigSS<uint32_t,
                            SmeStoreRegRegPngNTMicroop>(
                                nm[nonTemporal][msz], machInst, MemWriteOp,
                                zt, pg, rn, rm, numregs);
                case 3:
                    return new SmeStNonContigSS<uint64_t,
                            SmeStoreRegRegPngNTMicroop>(
                                nm[nonTemporal][msz], machInst, MemWriteOp,
                                zt, pg, rn, rm, numregs);
            }
        }
        return new Unknown64(machInst);
    }

