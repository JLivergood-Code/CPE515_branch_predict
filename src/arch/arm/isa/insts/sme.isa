output header {{

    template <template <typename T> class Base>
    StaticInstPtr
    decodeSme2MVPredBinOp4Regs(unsigned size, ExtMachInst machInst,
            RegIndex dest1, RegIndex dest2, RegIndex dest3, RegIndex dest4,
            RegIndex gp,
            RegIndex op1, RegIndex op2, RegIndex op3, RegIndex op4,
            RegIndex op5, RegIndex op6, RegIndex op7, RegIndex op8)
    {
        switch (size) {
          case 0:
            return new Base<uint8_t>(machInst, dest1, dest2, dest3, dest4, gp,
                                    op1, op2, op3, op4, op5, op6, op7, op8);
          case 1:
            return new Base<uint16_t>(machInst, dest1, dest2, dest3, dest4, gp,
                                    op1, op2, op3, op4, op5, op6, op7, op8);
          case 2:
            return new Base<uint32_t>(machInst, dest1, dest2, dest3, dest4, gp,
                                    op1, op2, op3, op4, op5, op6, op7, op8);
          case 3:
            return new Base<uint64_t>(machInst, dest1, dest2, dest3, dest4, gp,
                                    op1, op2, op3, op4, op5, op6, op7, op8);
          default:
            return new Unknown64(machInst);
        }
    }

    template <template <typename T> class Base>
    StaticInstPtr
    decodeSme2MVPredBinOp2Regs(unsigned size, ExtMachInst machInst,
            RegIndex dest1, RegIndex dest2, RegIndex gp,
            RegIndex op1, RegIndex op2, RegIndex op5, RegIndex op6)
    {
        switch (size) {
          case 0:
            return new Base<uint8_t>(machInst, dest1, dest2, gp,
                                        op1, op2, op5, op6);
          case 1:
            return new Base<uint16_t>(machInst, dest1, dest2, gp,
                                        op1, op2, op5, op6);
          case 2:
            return new Base<uint32_t>(machInst, dest1, dest2, gp,
                                        op1, op2, op5, op6);
          case 3:
            return new Base<uint64_t>(machInst, dest1, dest2, gp,
                                        op1, op2, op5, op6);
          default:
            return new Unknown64(machInst);
        }
    }

