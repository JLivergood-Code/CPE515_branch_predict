    def sme2MovaExtractInst(name, Name, opClass, types, numRegs):
        assert numRegs in [2, 4]
        global header_output, decoder_output, exec_output
        code = smEnCheckCode + '''
            // imm stores the tile index
            // op1 is the source SVE vector register
            // gp is the governing predecate register
            // op2 is the slice index register
            // v is the row/col select immediate - true for column accesses

            unsigned eCount = ArmStaticInst::getCurSmeVecLen<TPElem>(
                xc->tcBase());

            uint8_t offset = imm;
            uint8_t tile_idx = zan;

            uint32_t index_base = WIndex - (WIndex %% %(numRegs)s);
            uint32_t vec_idx = (index_base + offset) %% eCount;
            ''' % {'numRegs': numRegs}
        for i in range(1, numRegs + 1):
            code += '''
            if (!v) { // Horizontal (row) access
                auto row = getTileHSlice<TPElem>(
                    ZA, tile_idx, vec_idx + %(op)s - 1);
                for (int i = 0; i < eCount; ++i) {
                    AA64FpDest%(op)s_x[i] = row[i];
                }
            } else { // Vertical (column) access
                auto col = getTileVSlice<TPElem>(
                    ZA, tile_idx, vec_idx + %(op)s - 1);
                for (int i = 0; i < eCount; ++i) {
                    AA64FpDest%(op)s_x[i] = col[i];
                }
            }
            ''' % {'op': i}

