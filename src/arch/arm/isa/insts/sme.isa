            '''

        zaWriteCode = '''
            for (int i = 0; i < eCount; ++i) {
                ZT0_ub[i] = data[i];
            }
        '''

        load_fa_code = '''
                fault->annotate(ArmISA::ArmFault::WnR, 0);'''

        iop = InstObjParams(name, "Sme" + Name, "SmeLdrStrTableOp",
