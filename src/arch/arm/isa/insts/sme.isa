            code += op % {'op1': i, 'op2': 5, 'align': align}

        if numRegs == 1:
            iop = InstObjParams(name, "Sme" + Name, "Sme2MultiIdx1RegOp",
                                {'code': code, 'op_class': opClass}, [])
            header_output += SME2MultiIdx1RegDeclare.subst(iop)
        elif numRegs == 2:
            iop = InstObjParams(name, "Sme" + Name, "Sme2MultiIdx2RegOp",
                                {'code': code, 'op_class': opClass}, [])
            header_output += SME2MultiIdx2RegDeclare.subst(iop)
        elif numRegs == 4:
            iop = InstObjParams(name, "Sme" + Name, "Sme2MultiIdx4RegOp",
                                {'code': code, 'op_class': opClass}, [])
            header_output += SME2MultiIdx4RegDeclare.subst(iop)
        exec_output += Sme2Templated2Src1DstExecute.subst(iop)

        for types in zip(src1Types, src2Types, dstTypes):
            substDict = {'targs': "%s, %s, %s" % types,
                         'class_name': 'Sme' + Name}
            exec_output += Sme2OpExecDeclare.subst(substDict)

    def sme2ZeroLutInst(name, Name, opClass):
        global header_output, decoder_output, exec_output
        code = smEnCheckCode + smeZaWrite + '''
            // ZT0 is the SME2 LUT register (hard coded)

            // The LUT is 512-bit. Let's view it is doubles and zero it.
            constexpr unsigned eCount = 512 / 64;

            for (int i = 0; i < eCount; ++i) {
                ZT0_ud[i] = 0;
            }
            '''

        iop = InstObjParams(name, "Sme" + Name, "Sme2ZlutOp",
                            {'code': code, 'op_class': opClass}, [])
        header_output += Sme2ZlutDeclare.subst(iop)
        exec_output += Sme2Execute.subst(iop)

    def sme2ZaZNRegInst(name, Name, opClass, types, op, numRegs):
        assert numRegs in [2, 4]
        global header_output, decoder_output, exec_output
        code = smEnCheckCode + smeZaWrite + '''
            // AA64FpOp1 is the first source register
            // AA64FpOp2 is the second source register
            // AA64FpOp3 is the third source register
            // AA64FpOp4 is the fourth source register
            // WIndex is the 32-bit vector select register
            // imm is the optional index offset
            '''
        code += '''
            unsigned eCount = ArmStaticInst::getCurSmeVecLen<TPElem>(
                xc->tcBase());

            int vectors = eCount * sizeof(TPElem);
            int vstride = vectors / %(numRegs)s;
            int vec = (WIndex + imm) %% vstride;
            unsigned row_idx = vec;
            ''' % {'numRegs': numRegs}
        for i in range(1, numRegs + 1):
            code += op % {'op1': i}

        if numRegs == 2:
            iop = InstObjParams(name, "Sme" + Name, "Sme2ZaZ2RegOp",
                                {'code': code, 'op_class': opClass}, [])
            header_output += SME2ZaZ2RegDeclare.subst(iop)
        elif numRegs == 4:
            iop = InstObjParams(name, "Sme" + Name, "Sme2ZaZ4RegOp",
                                {'code': code, 'op_class': opClass}, [])
            header_output += SME2ZaZ4RegDeclare.subst(iop)
        exec_output += Sme2TemplatedExecute.subst(iop)

        for t in types:
            substDict = {'targs': t,
                         'class_name': 'Sme' + Name}
            exec_output += Sme2OpExecDeclare.subst(substDict)

    def sme2ClampInst(name, Name, opClass, types, op, numRegs):
        assert numRegs in [2, 4]
        global header_output, decoder_output, exec_output
        code = smEnCheckCodeNoZA + '''
            // AA64FpDest1 is the first src/dst reg in a multi-vector group
            // AA64FpDest2 is the second src/dst reg in a multi-vector group
            //
            // 4 Reg Variant:
            // AA64FpDest3 is the third src/dst reg in a multi-vector group
            // AA64FpDest4 is the fourth src/dst reg in a multi-vector group
            //
            // AA64FpOp1 is the first source register
            // AA64FpOp2 is the second source register

            unsigned eCount = ArmStaticInst::getCurSmeVecLen<TPElem>(
                xc->tcBase());
            '''
        for i in range(1, numRegs + 1):
            code += op % {'op': i}

        if numRegs == 2:
            iop = InstObjParams(name, "Sme" + Name, "Sme2Clamp2RegOp",
                                {'code': code, 'op_class': opClass}, [])
            header_output += SME2Clamp2RegDeclare.subst(iop)
        elif numRegs == 4:
            iop = InstObjParams(name, "Sme" + Name, "Sme2Clamp4RegOp",
                                {'code': code, 'op_class': opClass}, [])
            header_output += SME2Clamp4RegDeclare.subst(iop)
        exec_output += Sme2TemplatedExecute.subst(iop)

        for t in types:
            substDict = {'targs': t,
                         'class_name': 'Sme' + Name}
            exec_output += Sme2OpExecDeclare.subst(substDict)

    def sme2RightShiftInst(name, Name, opClass, srcTypes, dstTypes,
                           op, numRegs):
        assert numRegs in [2, 4]
        global header_output, decoder_output, exec_output
        code = smEnCheckCodeNoZA + '''
            // AA64FpDest destination register
            // AA64FpOp1 is the first src reg in a multi-vector group
            // AA64FpOp2 is the second src reg in a multi-vector group
            //
            // 4 Reg Variant:
            // AA64FpOp3 is the third src reg in a multi-vector group
            // AA64FpOp4 is the fourth src reg in a multi-vector group
            //
            // imm is the immediate shift amount

            unsigned eCount = ArmStaticInst::getCurSmeVecLen<TPSElem>(
                xc->tcBase());
            '''
        code += '''
            size_t offset = 0;'''
        for i in range(1, numRegs + 1):
            code += op % {'op1': i, 'numRegs': numRegs}

        if numRegs == 2:
            iop = InstObjParams(name, "Sme" + Name, "Sme2Rshr2RegOp",
                                {'code': code, 'op_class': opClass}, [])
            header_output += Sme2Rshr2RegInstDeclare.subst(iop)
        elif numRegs == 4:
            iop = InstObjParams(name, "Sme" + Name, "Sme2Rshr4RegOp",
                                {'code': code, 'op_class': opClass}, [])
            header_output += Sme2Rshr4RegInstDeclare.subst(iop)
        exec_output += Sme2Templated1Src1DstExecute.subst(iop)

        for types in zip(srcTypes, dstTypes):
            substDict = {'targs': "%s, %s" % types,
                         'class_name': 'Sme' + Name}
            exec_output += Sme2OpExecDeclare.subst(substDict)

    def sme2SelInst(name, Name, opClass, types, op, numRegs):
        assert numRegs in [2, 4]
        global header_output, decoder_output, exec_output
        code = smEnCheckCodeNoZA + '''
            // 2 Reg Variant:
            // GpOp is the governing predicate register with
            //     predicate-as-counter encoding
            // AA64FpDest1 is the first des reg
            // AA64FpDest2 is the second des reg
            // AA64FpOp1 is the first src reg in the first multi-vector group
            // AA64FpOp2 is the second src reg in the first multi-vector group
            // AA64FpOp5 is the first src reg in the second multi-vector group
            // AA64FpOp6 is the second src reg in the second multi-vector group
            //
            // 4 Reg Variant:
            // AA64FpDest1 is the first des reg
            // AA64FpDest2 is the second des reg
            // AA64FpOp1 is the first src reg in the first multi-vector group
            // AA64FpOp2 is the second src reg in the first multi-vector group
            // AA64FpOp5 is the first src reg in the second multi-vector group
            // AA64FpOp6 is the second src reg in the second multi-vector group

            unsigned eCount = ArmStaticInst::getCurSmeVecLen<TPElem>(
                xc->tcBase());
            unsigned pred_width = sizeof(TPElem) * eCount;

            uint16_t png = 0;
            for (unsigned b = 0; b < 16; b ++) {
                png = png | ((uint16_t)GpOp_ub[b] << b);
            }
            '''
        for i in range(1, numRegs + 1):
            code += op % {'op1': i, 'op2': i + 4, 'oppg': i - 1, 'vl': numRegs}

        if numRegs == 2:
            iop = InstObjParams(name, "Sme" + Name, "Sme2SSel2RegOp",
                                {'code': code, 'op_class': opClass}, [])
            header_output += Sme2Sel2RegDeclare.subst(iop)
        elif numRegs == 4:
            iop = InstObjParams(name, "Sme" + Name, "Sme2SSel4RegOp",
                                {'code': code, 'op_class': opClass}, [])
            header_output += Sme2Sel4RegDeclare.subst(iop)
        exec_output += Sme2TemplatedExecute.subst(iop)

        for type in types:
            substDict = {'targs': "%s" % type,
                         'class_name': 'Sme' + Name}
            exec_output += Sme2OpExecDeclare.subst(substDict)

    def sme2UnpkInst(name, Name, opClass, srcTypes, dstTypes, op, numRegs):
        assert numRegs in [2, 4]
        global header_output, decoder_output, exec_output
        code = smEnCheckCodeNoZA + '''
            unsigned eCount = ArmStaticInst::getCurSmeVecLen<TPDElem>(
                xc->tcBase());
            '''
        for i in range(0, numRegs // 2):
            code += op % {'op1': i + 1, 'op2': 2 * i + 1, 'op3': 2 * i + 2}

        if numRegs == 2:
            iop = InstObjParams(name, "Sme" + Name, "Sme2Vector2x1Op",
                                {'code': code, 'op_class': opClass}, [])
            header_output += Sme2NonDestr2x1InstDeclare.subst(iop)
        elif numRegs == 4:
            iop = InstObjParams(name, "Sme" + Name, "Sme2Vector4x2Op",
                                {'code': code, 'op_class': opClass}, [])
            header_output += Sme2NonDestr4x2InstDeclare.subst(iop)
        exec_output += Sme2Templated1Src1DstExecute.subst(iop)

        for src, dst in zip(srcTypes, dstTypes):
            substDict = {'targs' : "{}, {}".format(src, dst),
                         'class_name': 'Sme' + Name}
            exec_output += Sme2OpExecDeclare.subst(substDict)

    def sme2LutiInst(name, Name, opClass, types, op, isize, numRegs):
        assert isize in [1, 2, 4]
        assert numRegs in [1, 2, 4]
        global header_output, decoder_output, exec_output
        code = smEnCheckCodeNoZA + '''
            unsigned eCount = ArmStaticInst::getCurSmeVecLen<TPElem>(
                xc->tcBase());
            int segments = sizeof(TPElem) * 8 / ( %(isize)s * %(numRegs)s );
            int segment = imm %% segments;
            size_t base = segment * %(numRegs)s * eCount;
            ''' % {'isize': isize, 'numRegs': numRegs}
        for i in range(1, numRegs + 1):
            code += op % {'op1': i, 'op2': 1}

        if numRegs == 1:
            iop = InstObjParams(name, "Sme" + Name, "Sme2Luti1RegOp",
                                {'code': code, 'op_class': opClass}, [])
            header_output += Sme2Luti1RegDeclare.subst(iop)
        if numRegs == 2:
            iop = InstObjParams(name, "Sme" + Name, "Sme2Luti2RegOp",
                                {'code': code, 'op_class': opClass}, [])
            header_output += Sme2Luti2RegDeclare.subst(iop)
        elif numRegs == 4:
            iop = InstObjParams(name, "Sme" + Name, "Sme2Luti4RegOp",
                                {'code': code, 'op_class': opClass}, [])
            header_output += Sme2Luti4RegDeclare.subst(iop)
        exec_output += Sme2TemplatedExecute.subst(iop)

        for type in types:
            substDict = {'targs': type,
                         'class_name': 'Sme' + Name}
            exec_output += Sme2OpExecDeclare.subst(substDict)

    def sme2Luti4to8b4RegInst(name, Name, opClass, op):
        global header_output, decoder_output, exec_output
        code = smEnCheckCodeNoZA + '''
            unsigned eCount = ArmStaticInst::getCurSmeVecLen<TPElem>(
                xc->tcBase());
            size_t base = 0;
            '''
        for i in range(0, 4):
            code += op % {'op1': i + 1, 'op2': i // 2 + 1}
            if i % 2 == 1:
                code +='''
            base = 0;'''

        iop = InstObjParams(name, "Sme" + Name, "Sme2Luti4to8b4RegOp",
                            {'code': code, 'op_class': opClass}, [])
        header_output += Sme2Luti4to8b4RegDeclare.subst(iop)
        exec_output += Sme2TemplatedExecute.subst(iop)

        for type in ['uint8_t']:
            substDict = {'targs': type,
                         'class_name': 'Sme' + Name}
            exec_output += Sme2OpExecDeclare.subst(substDict)

    # Generates definitions for SME stride load/store microops
    def emitSmeConseMemInsts(offsetIsImm):
        global header_output, exec_output, decoders
        eaCode = SPAlignmentCheckCode + '''
        int memAccessSize = eCount * sizeof(Element);
        EA = memAccessSize * regIndex + XBase + '''
        if offsetIsImm:
            eaCode += '((int64_t) this->imm * eCount * sizeof(Element))'
        else:
            eaCode += '(XOffset * sizeof(Element));'
        pngDecoder = '''
        uint16_t png = 0;
        for (unsigned b = 0; b < 16; b ++) {
            png = png | ((uint16_t)GpOp_ub[b] << b);
        }
        sveCounterToPredicate(
            auxGpReg, png, sizeof(Element) * eCount, 0, regIndex);
        '''
        loadMemAccCode = '''
        for (int i = 0; i < eCount; i++) {
            if (auxGp[i]) {
                AA64FpDest_x[i] = cSwap<Element>(memDataView[i],
                                        isBigEndian64(xc->tcBase()));
            } else {
                AA64FpDest_x[i] = 0;
            }
        }
        '''
        storeMemAccCode = '''
        for (int i = 0; i < eCount; i++) {
            if (auxGp[i]) {
                memDataView[i] = cSwap<Element>(AA64FpDest_x[i],
                                        isBigEndian64(xc->tcBase()));
            } else {
                memDataView[i] = 0;
                for (int j = 0; j < sizeof(Element); j++) {
                    wrEn[sizeof(Element) * i + j] = false;
                }
            }
        }
        '''
        storeWrEnableCode = '''
        auto wrEn = std::vector<bool>(sizeof(Element) * eCount, true);
        '''
        loadIop = ArmInstObjParams('ldxx',
            ('SmeLoadRegImmPngMicroop' if offsetIsImm else
             'SmeLoadRegRegPngMicroop'),
            'MicroOp',
            {'targs': 'Element',
             'memacc_code': loadMemAccCode,
             'ea_code' : (smEnCheckCodeNoZA + eaCode),
             'fa_code' : load_fa_code,
             'auxgp_code': pngDecoder},
            ['IsLoad', 'IsMicroop'])
        loadNTIop = ArmInstObjParams('ldntxx',
            ('SmeLoadRegImmPngNTMicroop' if offsetIsImm else
             'SmeLoadRegRegPngNTMicroop'),
            'MicroOp',
            {'targs': 'Element',
             'memacc_code': loadMemAccCode,
             'ea_code' : (smEnCheckCodeNoZA + eaCode),
             'fa_code' : load_fa_code,
             'auxgp_code': pngDecoder},
            ['IsLoad', 'IsMicroop'])
        storeIop = ArmInstObjParams('stxx',
            ('SmeStoreRegImmPngMicroop' if offsetIsImm else
             'SmeStoreRegRegPngMicroop'),
            'MicroOp',
            {'targs': 'Element',
             'wren_code': storeWrEnableCode,
             'memacc_code': storeMemAccCode,
             'ea_code' : (smEnCheckCodeNoZA + eaCode),
             'fa_code' : store_fa_code,
             'auxgp_code': pngDecoder},
            ['IsStore', 'IsMicroop'])
        storeNTIop = ArmInstObjParams('stntxx',
            ('SmeStoreRegImmPngNTMicroop' if offsetIsImm else
             'SmeStoreRegRegPngNTMicroop'),
            'MicroOp',
            {'targs': 'Element',
             'wren_code': storeWrEnableCode,
             'memacc_code': storeMemAccCode,
             'ea_code' : (smEnCheckCodeNoZA + eaCode),
             'fa_code' : store_fa_code,
             'auxgp_code': pngDecoder},
            ['IsStore', 'IsMicroop'])
        if offsetIsImm:
            header_output += SveStructMemSIMicroopDeclare.subst(loadIop)
            header_output += SveStructMemSIMicroopDeclare.subst(loadNTIop)
            header_output += SveStructMemSIMicroopDeclare.subst(storeIop)
            header_output += SveStructMemSIMicroopDeclare.subst(storeNTIop)
        else:
            header_output += SveStructMemSSMicroopDeclare.subst(loadIop)
            header_output += SveStructMemSSMicroopDeclare.subst(loadNTIop)
            header_output += SveStructMemSSMicroopDeclare.subst(storeIop)
            header_output += SveStructMemSSMicroopDeclare.subst(storeNTIop)
        exec_output += (
            SveStructLoadExecute.subst(loadIop) +
            SveStructLoadInitiateAcc.subst(loadIop) +
            SveStructLoadCompleteAcc.subst(loadIop) +
            SveStructLoadExecute.subst(loadNTIop) +
            SveStructLoadInitiateAcc.subst(loadNTIop) +
            SveStructLoadCompleteAcc.subst(loadNTIop) +
            SveStructStoreExecute.subst(storeIop) +
            SveStructStoreInitiateAcc.subst(storeIop) +
            SveStructStoreCompleteAcc.subst(storeIop) +
            SveStructStoreExecute.subst(storeNTIop) +
            SveStructStoreInitiateAcc.subst(storeNTIop) +
            SveStructStoreCompleteAcc.subst(storeNTIop))
        tplArgs = ('uint8_t', 'uint16_t', 'uint32_t', 'uint64_t')
        for type in tplArgs:
            substDict = {'targs': type,
                         'class_name': 'SmeLoadRegImmPngMicroop'
                                        if offsetIsImm
                                        else 'SmeLoadRegRegPngMicroop'}
            exec_output += SveStructMemExecDeclare.subst(substDict)
            substDict['class_name'] = ('SmeLoadRegImmPngNTMicroop'
                                       if offsetIsImm
                                       else 'SmeLoadRegRegPngNTMicroop')
            exec_output += SveStructMemExecDeclare.subst(substDict)
            substDict['class_name'] = ('SmeStoreRegImmPngMicroop'
                                       if offsetIsImm
                                       else 'SmeStoreRegRegPngMicroop')
            exec_output += SveStructMemExecDeclare.subst(substDict)
            substDict['class_name'] = ('SmeStoreRegImmPngNTMicroop'
                                       if offsetIsImm
                                       else 'SmeStoreRegRegPngNTMicroop')
            exec_output += SveStructMemExecDeclare.subst(substDict)


    # ADD (array accumulators)
    addBaseOp = 'destElem = srcElem1 + srcElem2;'

    zazBinCode = '''
        auto row%%(op1)s = getHSlice<TPElem>(ZA, row_idx);
        for (int e = 0; e < eCount; ++e) {
            TPElem srcElem1 = row%%(op1)s[e];
            TPElem srcElem2 = AA64FpOp%%(op1)s_x[e];
            TPElem destElem;
            %(op)s
            row%%(op1)s[e] = destElem;
        }
        row_idx += vstride;
    '''

    sme2ZaZNRegInst("add", "AddaI322Reg", "SimdAddOp", ['uint32_t'],
                    zazBinCode % {'op': addBaseOp}, 2)
    sme2ZaZNRegInst("add", "AddaI642Reg", "SimdAddOp", ['uint64_t'],
                    zazBinCode % {'op': addBaseOp}, 2)
    sme2ZaZNRegInst("add", "AddaI324Reg", "SimdAddOp", ['uint32_t'],
                    zazBinCode % {'op': addBaseOp}, 4)
    sme2ZaZNRegInst("add", "AddaI644Reg", "SimdAddOp", ['uint64_t'],
                    zazBinCode % {'op': addBaseOp}, 4)

    # ADD (array results, multiple and single vector)
    multiVecBinCode = '''
        auto row%%(op1)s = getHSlice<TPDElem>(ZA, row_idx);
        for (int e = 0; e < eCount; ++e) {
            TPS1Elem srcElem1 = AA64FpOp%%(op1)s_xs1[e];
            TPS2Elem srcElem2 = AA64FpOp%%(op2)s_xs2[e];
            TPDElem destElem;
            %(op)s
            row%%(op1)s[e] = destElem;
        }
        row_idx += vstride;
    '''

    sme2MultiSglNRegInst("add", "AddI32MSgl2Reg", "SimdAddOp",
                         ['uint32_t'], ['uint32_t'], ['uint32_t'],
                         multiVecBinCode % {'op': addBaseOp}, 2)
    sme2MultiSglNRegInst("add", "AddI64MSgl2Reg", "SimdAddOp",
                         ['uint64_t'], ['uint64_t'], ['uint64_t'],
                         multiVecBinCode % {'op': addBaseOp}, 2)
    sme2MultiSglNRegInst("add", "AddI32MSgl4Reg", "SimdAddOp",
                         ['uint32_t'], ['uint32_t'], ['uint32_t'],
                         multiVecBinCode % {'op': addBaseOp}, 4)
    sme2MultiSglNRegInst("add", "AddI64MSgl4Reg", "SimdAddOp",
                         ['uint64_t'], ['uint64_t'], ['uint64_t'],
                         multiVecBinCode % {'op': addBaseOp}, 4)

    # ADD (array results, multiple vectors)
    sme2MultiVecNRegInst("add", "AddI32MVec2Reg", "SimdAddOp",
                         ['uint32_t'], ['uint32_t'], ['uint32_t'],
                         multiVecBinCode % {'op': addBaseOp}, 2)
    sme2MultiVecNRegInst("add", "AddI64MVec2Reg", "SimdAddOp",
                         ['uint64_t'], ['uint64_t'], ['uint64_t'],
                         multiVecBinCode % {'op': addBaseOp}, 2)
    sme2MultiVecNRegInst("add", "AddI32MVec4Reg", "SimdAddOp",
                         ['uint32_t'], ['uint32_t'], ['uint32_t'],
                         multiVecBinCode % {'op': addBaseOp}, 4)
    sme2MultiVecNRegInst("add", "AddI64MVec4Reg", "SimdAddOp",
                         ['uint64_t'], ['uint64_t'], ['uint64_t'],
                         multiVecBinCode % {'op': addBaseOp}, 4)

    # ADD (to vector)
    destrBinCode = '''
        for (int e = 0; e < eCount; ++e) {
            TPElem srcElem1 = AA64FpDest%%(op1)sMerge_x[e];
            TPElem srcElem2 = AA64FpOp%%(op2)s_x[e];
            TPElem destElem;
            %(op)s
            AA64FpDest%%(op1)s_x[e] = destElem;
        }
    '''

    sme2DestrNx1Inst("add", "AddToVec2Reg", "SimdAddOp",
                     ['uint8_t', 'uint16_t', 'uint32_t', 'uint64_t'],
                     destrBinCode % {'op': addBaseOp}, 2)
    sme2DestrNx1Inst("add", "AddToVec4Reg", "SimdAddOp",
                     ['uint8_t', 'uint16_t', 'uint32_t', 'uint64_t'],
                     destrBinCode % {'op': addBaseOp}, 4)

    # ADDHA
    addCode = '''
        for (int col = 0; col < eCount; ++col) {
            TPElem val = AA64FpOp1_x[col];

            for (int row = 0; row < eCount; ++row) {
                if (!(GpOp1_x[row] && GpOp2_x[col])) {
                    continue;
                }

                tile[row][col] += val;
            }
        }
        '''
    smeAddInst('addha', "AddhaI32", "SimdAddOp", ['int32_t'], addCode)
    smeAddInst('addha', "AddhaI64", "SimdAddOp", ['int64_t'], addCode)

    # ADDSPL
    addSplCode = '''
        unsigned eCount = ArmStaticInst::getCurSmeVecLen<uint8_t>(
                xc->tcBase());
        eCount /= 8;
        XDest = XOp1 + eCount * (int64_t) imm;
    '''
    smeAddVlInst('addspl', "Addspl", "SimdAddOp", addSplCode)

    # ADDSVL
    addSvlCode = '''
        unsigned eCount = ArmStaticInst::getCurSmeVecLen<uint8_t>(
                xc->tcBase());
        XDest = XOp1 + eCount * (int64_t) imm;
    '''
    smeAddVlInst('addsvl', "Addsvl", "SimdAddOp", addSvlCode)

    # ADDVA
    addCode = '''
        for (int row = 0; row < eCount; ++row) {
            TPElem val = AA64FpOp1_x[row];

            for (int col = 0; col < eCount; ++col) {
                if (!(GpOp1_x[row] && GpOp2_x[col])) {
                    continue;
                }

                tile[row][col] += val;
            }
        }
        '''
    smeAddInst('addva', "AddvaI32", "SimdAddOp", ['int32_t'], addCode)
    smeAddInst('addva', "AddvaI64", "SimdAddOp", ['int64_t'], addCode)

    # BFADD
    zazFpBinCode = '''
        auto row%%(op1)s = getHSlice<TPElem>(ZA, row_idx);
        for (int e = 0; e < eCount; ++e) {
            FPSCR fpscr = FpscrExc & ~FpscrAhpMask;
            fpscr.dn = 1;
            FPCR fpcr = (FPCR)Fpcr;

            TPElem srcElem1 = row%%(op1)s[e];
            TPElem srcElem2 = AA64FpOp%%(op1)s_x[e];
            TPElem destElem;
            %(op)s
            row%%(op1)s[e] = destElem;
        }
        row_idx += vstride;
    '''

    bfaddBaseOp = 'destElem = fplibBfAdd(srcElem1, srcElem2, fpscr, fpcr);'

    sme2ZaZNRegInst("bfadd", "Bfadd2Reg", "SimdBf16AddOp", ['uint16_t'],
                    zazFpBinCode % {'op': bfaddBaseOp}, 2)
    sme2ZaZNRegInst("bfadd", "Bfadd4Reg", "SimdBf16AddOp", ['uint16_t'],
                    zazFpBinCode % {'op': bfaddBaseOp}, 4)

    # BFCLAMP
    bfclampCode = '''
        for (int e = 0; e < eCount; ++e) {
            FPSCR fpscr = FpscrExc & ~FpscrAhpMask;
            FPCR fpcr = (FPCR)Fpcr;

            TPElem element1 = AA64FpOp1_x[e];
            TPElem element2 = AA64FpOp2_x[e];
            TPElem element3 = AA64FpDest%(op)sMerge_x[e];
            TPElem res = fplibBfMaxNum(element1, element3, fpscr, fpcr);
            res = fplibBfMinNum(res, element2, fpscr, fpcr);
            AA64FpDest%(op)s_x[e] = res;
            FpscrExc = fpscr;
        }
    '''

    sme2ClampInst("bfclamp", "Bfclamp2Reg", "SimdBf16CmpOp", ['uint16_t'],
                  bfclampCode, 2)
    sme2ClampInst("bfclamp", "Bfclamp4Reg", "SimdBf16CmpOp", ['uint16_t'],
                  bfclampCode, 4)

    # BFCVT (single-precision to BFloat16)
    bfcvtBaseOp = '''
            destElem = fplibConvertBF(srcElem1, FPCRRounding(fpscr),
                                        fpscr, fpcr);'''

    nonDestrFpCvtNCode = '''
        for (int e = 0; e < eCount; ++e) {
            FPSCR fpscr = FpscrExc & ~FpscrAhpMask;
            FPCR fpcr = (FPCR)Fpcr;

            TPSElem srcElem1 = AA64FpOp%%(op1)s_xs[e];
            TPDElem destElem = srcElem1;
            %(op)s
            AA64FpDest_xd[offset + e] = destElem;
            FpscrExc = fpscr;
        }
        offset += eCount;
    '''

    nonDestrFpCvtNInterCode = '''
        for (int e = 0; e < eCount; ++e) {
            FPSCR fpscr = FpscrExc & ~FpscrAhpMask;
            FPCR fpcr = (FPCR)Fpcr;

            TPSElem srcElem1 = AA64FpOp%%(op1)s_xs[e];
            TPDElem destElem = srcElem1;
            %(op)s
            AA64FpDest_xd[%%(numRegs)s * e + offset] = destElem;
            FpscrExc = fpscr;
        }
        offset += 1;
    '''

    sme2NonDestr1xNInst("bfcvt", "Bfcvt2Reg", "SimdBf16CvtOp",
                        ['uint32_t'], ['uint16_t'],
                        nonDestrFpCvtNCode % {'op': bfcvtBaseOp}, 2)

    # BFCVTN
    sme2NonDestr1xNInst("bfcvtn", "Bfcvtn2Reg", "SimdBf16CvtOp",
                        ['uint32_t'], ['uint16_t'],
                        nonDestrFpCvtNInterCode % {'op': bfcvtBaseOp}, 2)

    # BFDOT (multiple and indexed vector)
    multiIdxBfdotCode = '''
        auto row%(op1)s = getHSlice<TPDElem>(ZA, row_idx);
        for (int e = 0; e < eCount; ++e) {
            FPSCR fpscr = FpscrExc & ~FpscrAhpMask;
            fpscr.dn = 1;
            FPCR fpcr = (FPCR)Fpcr;

            TPS1Elem elt1_a = AA64FpOp%(op1)s_xs1[2 * e + 0];
            TPS1Elem elt1_b = AA64FpOp%(op1)s_xs1[2 * e + 1];

            int segmentbase = e - (e %% eltspersegment);
            int s = segmentbase + idx;
            TPS2Elem elt2_a = AA64FpOp%(op2)s_xs2[2 * s + 0];
            TPS2Elem elt2_b = AA64FpOp%(op2)s_xs2[2 * s + 1];

            TPDElem destElem = fplibBfdotAdd(row%(op1)s[e],
                elt1_a, elt1_b, elt2_a, elt2_b, fpscr, fpcr);
            row%(op1)s[e] = destElem;
        }
        row_idx += vstride;
    '''

    sme2MultiIdxNRegInst("bfdot", "BfdotMIdx2Reg", "SimdBf16DotProdOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiIdxBfdotCode, 2)
    sme2MultiIdxNRegInst("bfdot", "BfdotMIdx4Reg", "SimdBf16DotProdOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiIdxBfdotCode, 4)

    # BFDOT (multiple and single vector)
    multiVecBfDotCode = '''
        auto row%(op1)s = getHSlice<TPDElem>(ZA, row_idx);
        for (int e = 0; e < eCount; ++e) {
            FPSCR fpscr = FpscrExc & ~FpscrAhpMask;
            fpscr.dn = 1;
            FPCR fpcr = (FPCR)Fpcr;

            TPS1Elem elt1_a = AA64FpOp%(op1)s_xs1[2 * e + 0];
            TPS1Elem elt1_b = AA64FpOp%(op1)s_xs1[2 * e + 1];

            TPS2Elem elt2_a = AA64FpOp%(op2)s_xs2[2 * e + 0];
            TPS2Elem elt2_b = AA64FpOp%(op2)s_xs2[2 * e + 1];

            TPDElem destElem = fplibBfdotAdd(row%(op1)s[e],
                elt1_a, elt1_b, elt2_a, elt2_b, fpscr, fpcr);
            row%(op1)s[e] = destElem;
        }
        row_idx += vstride;
    '''

    sme2MultiSglNRegInst("fdot", "BfdotMSgl2Reg", "SimdBf16DotProdOp",
                         ['uint16_t'], ['uint16_t'], ['uint32_t'],
                         multiVecBfDotCode, 2)
    sme2MultiSglNRegInst("fdot", "BfdotMSgl4Reg", "SimdBf16DotProdOp",
